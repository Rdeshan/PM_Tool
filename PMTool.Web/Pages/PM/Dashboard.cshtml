@page
@using System.Security.Claims
@model PMTool.Web.Pages.PM.DashboardModel
@{
    ViewData["Title"] = "Project Manager Dashboard";
    var userName = User.FindFirst(ClaimTypes.Email)?.Value ?? "User";
}

@if (!User.Identity?.IsAuthenticated ?? true)
{
    <div class="alert alert-warning" role="alert">
        <h4 class="alert-heading">Access Denied</h4>
        <p>You must be logged in to access this page. <a asp-page="/Auth/Login">Login here</a></p>
    </div>
}
else if (!User.IsInRole("Project Manager"))
{
    <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading">Access Denied</h4>
        <p>Only project managers can access this page.</p>
        <a asp-page="/Admin/Users/Dashboard" class="btn btn-sm btn-secondary mt-2">Go to Dashboard</a>
    </div>
}
else
{
<style>
    :root {
        --pm-green:       #0D6EFD;
        --pm-green-mid:   #0056CA;
        --pm-green-light: #4D94FF;
        --pm-green-pale:  #E7F1FF;
        --pm-bg:          #f4f6f5;
        --pm-card:        #ffffff;
        --pm-text:        #1b2b23;
        --pm-muted:       #6c757d;
        --pm-muted-light: #e9ecef;
    }

    /* ── Stat Cards ── */
    .stat-card {
        background: rgba(255, 255, 255, 0.88);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        box-shadow: 0 2px 16px rgba(0, 119, 182, 0.08), 0 1px 4px rgba(0, 150, 199, 0.04);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: none;
        height: 100%;
        transition: box-shadow 0.2s ease, transform 0.2s ease;
    }
    .stat-card:not(.dark):hover {
        box-shadow: 0 6px 28px rgba(0, 119, 182, 0.13), 0 2px 8px rgba(0, 150, 199, 0.07);
        transform: translateY(-1px);
    }
    .stat-card.dark {
        background: var(--pm-green);
        color: #fff;
    }
    .stat-card .stat-label { font-size: .85rem; color: var(--pm-muted); font-weight: 500; }
    .stat-card.dark .stat-label { color: rgba(255,255,255,.7); }
    .stat-card .stat-value { font-size: 2.4rem; font-weight: 700; line-height: 1.1; margin: .3rem 0; color: var(--pm-text); }
    .stat-card.dark .stat-value { color: #fff; }
    .stat-card .stat-sub { font-size: .78rem; color: var(--pm-green-mid); }
    .stat-card.dark .stat-sub { color: var(--pm-green-pale); }
    .stat-card.clickable { cursor: pointer; transition: box-shadow .15s, transform .15s; }
    .stat-card.clickable:hover { box-shadow: 0 6px 28px rgba(0, 119, 182, 0.16); transform: translateY(-2px); }
    .clickable-card { transition: box-shadow .15s, transform .15s; }
    .clickable-card:hover { box-shadow: 0 8px 24px rgba(0, 119, 182, 0.14); transform: translateY(-2px); }

    /* ── Section Cards ── */
    .section-card {
        background: rgba(255, 255, 255, 0.88);
        border-radius: 14px;
        padding: 1.5rem;
        box-shadow: 0 2px 16px rgba(0, 119, 182, 0.08), 0 1px 4px rgba(0, 150, 199, 0.04);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: none;
        height: 100%;
        transition: box-shadow 0.2s ease;
    }
    .section-card:hover {
        box-shadow: 0 6px 28px rgba(0, 119, 182, 0.13), 0 2px 8px rgba(0, 150, 199, 0.07);
    }
    .section-card .section-title { font-size: 1rem; font-weight: 600; color: var(--pm-text); margin-bottom: 1rem; }

    /* ── Topbar ── */
    .pm-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.75rem;
    }
    .pm-topbar h4 { font-weight: 700; color: var(--pm-text); margin: 0; }
    .pm-topbar .topbar-right { display: flex; gap: .75rem; align-items: center; }

    /* ── Progress donut ── */
    .donut-wrap { position: relative; width: 120px; height: 120px; margin: 0 auto; }
    .donut-wrap svg { transform: rotate(-90deg); }
    .donut-center {
        position: absolute; top: 50%; left: 50%;
        transform: translate(-50%,-50%);
        text-align: center;
    }
    .donut-center .pct   { font-size: 1.5rem; font-weight: 700; color: var(--pm-text); }
    .donut-center .label { font-size: .65rem; color: var(--pm-muted); }

    /* ── Team Collab Hierarchy ── */
    .badge-status {
        font-size: .7rem;
        padding: 2px 8px;
        border-radius: 20px;
        font-weight: 500;
        margin-left: auto;
        flex-shrink: 0;
    }
    .badge-completed  { background: var(--pm-green-pale);  color: var(--pm-green-mid); }
    .badge-inprogress { background: #fff3cd; color: #856404; }
    .badge-pending    { background: #f8d7da; color: #842029; }

    /* ── Daily Task Approval ── */
    .daily-task-row {
        background: #fff;
        transition: box-shadow .15s;
    }
    .daily-task-row:hover { box-shadow: 0 2px 10px rgba(0,0,0,.05); }
    .badge-status.badge-task-pending { background: #fff3cd; color: #856404; }

    .collab-project-row {
        border-bottom: 1px solid #f0f0f0;
        padding-bottom: .2rem;
        margin-bottom: .2rem;
    }
    .collab-project-row:last-child { border-bottom: none; margin-bottom: 0; }

    .collab-proj-header {
        display: flex;
        align-items: center;
        gap: .6rem;
        padding: .45rem .3rem;
        border-radius: 8px;
        cursor: pointer;
        transition: background .15s;
        user-select: none;
    }
    .collab-proj-header:hover { background: #f8f9fa; }

    .collab-proj-icon {
        width: 32px; height: 32px;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: .8rem;
        flex-shrink: 0;
    }
    .collab-proj-name { font-size: .88rem; font-weight: 600; color: var(--pm-text); }
    .collab-proj-due  { font-size: .72rem; color: var(--pm-muted); }

    .collab-chevron {
        font-size: .75rem;
        color: var(--pm-muted);
        transition: transform .25s ease;
        flex-shrink: 0;
    }
    .collab-chevron.open { transform: rotate(180deg); }

    .collab-teams-wrap {
        overflow: hidden;
        max-height: 0;
        transition: max-height .35s ease;
        padding-left: .75rem;
    }
    .collab-teams-wrap.expanded,
    .collab-teams-wrap.hover-expanded { max-height: 1000px; }

    .collab-team-row { margin: .2rem 0; }

    .collab-team-header {
        display: flex;
        align-items: center;
        gap: .45rem;
        padding: .3rem .4rem;
        cursor: pointer;
        border-radius: 6px;
        transition: background .15s;
        user-select: none;
    }
    .collab-team-header:hover { background: #f4f6f5; }

    .team-color-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .collab-team-name  { font-size: .8rem; font-weight: 600; color: var(--pm-text); }
    .collab-team-count { font-size: .7rem; color: var(--pm-muted); }

    .collab-members-wrap {
        overflow: hidden;
        max-height: 0;
        transition: max-height .3s ease;
        padding-left: 1rem;
    }
    .collab-members-wrap.expanded,
    .collab-members-wrap.hover-expanded { max-height: 1000px; }

    .collab-member-row {
        display: flex;
        align-items: flex-start;
        gap: .55rem;
        padding: .4rem .2rem;
        border-bottom: 1px solid #f7f7f7;
    }
    .collab-member-row:last-child { border-bottom: none; }

    .collab-member-avatar {
        width: 30px; height: 30px;
        border-radius: 50%;
        background: var(--pm-green-pale);
        display: flex; align-items: center; justify-content: center;
        font-size: .7rem; font-weight: 700;
        color: var(--pm-green);
        flex-shrink: 0;
        margin-top: 2px;
    }
    .collab-member-name { font-size: .82rem; font-weight: 600; color: var(--pm-text); line-height: 1.25; }
    .collab-member-sub  { font-size: .71rem; color: var(--pm-muted); }

    .collab-member-prog {
        display: flex;
        align-items: center;
        gap: .4rem;
        margin-top: .3rem;
    }
    .collab-prog-bar {
        flex: 1;
        height: 5px;
        background: #e9ecef;
        border-radius: 4px;
        overflow: hidden;
        min-width: 55px;
    }
    .collab-prog-fill {
        height: 100%;
        border-radius: 4px;
        background: var(--pm-green);
        transition: width .6s ease;
    }
    .collab-prog-pct { font-size: .69rem; color: var(--pm-muted); white-space: nowrap; }
</style>

<!-- Main Content -->
<div class="pm-main">
    <!-- Topbar -->
    <div class="pm-topbar">
        <div>
            <h4>Project Manager Dashboard</h4>
            <p class="text-muted mb-0" style="font-size:.85rem;">Welcome back, @userName</p>
        </div>
        <div class="topbar-right">
            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#approveTasksModal">
                <i class="bi bi-check2-square me-1"></i>Approve Tasks
                @if (Model.PendingDailyTasks.Any())
                {
                    <span class="badge rounded-pill bg-danger ms-1">@Model.PendingDailyTasks.Count</span>
                }
            </button>
            <a asp-page="/Account/Settings" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-gear me-1"></i>Settings
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
    {
        <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1090;">
            @if (TempData["SuccessMessage"] != null)
            {
                <div id="pmToastSuccess" class="toast align-items-center text-bg-success border-0 show" role="alert">
                    <div class="d-flex">
                        <div class="toast-body"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]</div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div id="pmToastError" class="toast align-items-center text-bg-danger border-0 show" role="alert">
                    <div class="d-flex">
                        <div class="toast-body"><i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]</div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>
                </div>
            }
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                ['pmToastSuccess', 'pmToastError'].forEach(function (id) {
                    var el = document.getElementById(id);
                    if (el) setTimeout(function () { bootstrap.Toast.getOrCreateInstance(el).hide(); }, 3000);
                });
            });
        </script>
    }

    <!-- ── Stat Cards Row ── -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="stat-card dark clickable" onclick="openProjectModal('total')">
                <span class="stat-label">Total Projects</span>
                <div class="stat-value">@Model.Dashboard.TotalProjects</div>
                <div class="stat-sub"><i class="bi bi-graph-up me-1"></i>Increased from last month</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card clickable" onclick="openProjectModal('ended')">
                <span class="stat-label">Ended Projects</span>
                <div class="stat-value">@Model.Dashboard.CompletedProjects</div>
                <div class="stat-sub"><i class="bi bi-graph-up me-1"></i>Increased from last month</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card clickable" onclick="openProjectModal('running')">
                <span class="stat-label">Running Projects</span>
                <div class="stat-value">@Model.Dashboard.RunningProjects</div>
                <div class="stat-sub"><i class="bi bi-graph-up me-1"></i>Increased from last month</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card clickable" onclick="openProjectModal('pending')">
                <span class="stat-label">Pending Project</span>
                <div class="stat-value">@Model.Dashboard.PendingProjects</div>
                <div class="stat-sub text-muted">On Discuss</div>
            </div>
        </div>
    </div>

    <!-- Bottom Row: Team Collab Hierarchy | Project Progress -->
    <div class="row g-3 mb-4">

        <!-- Team Collaboration (hierarchical: Project → Team → Member) -->
        <div class="col-lg-8">
            <div class="section-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="section-title mb-0">Team Collaboration</span>
                </div>

                @if (Model.CollabData.Any())
                {
                    @foreach (var proj in Model.CollabData)
                    {
                        var sLabel = proj.Status == 3 ? "Completed" : proj.Status == 1 ? "In Progress" : "Pending";
                        var sClass = proj.Status == 3 ? "badge-completed" : proj.Status == 1 ? "badge-inprogress" : "badge-pending";
                        var iconBg  = proj.ColourCode + "22";
                        var projUid = "proj-" + proj.Id.ToString("N");

                        <div class="collab-project-row">
                            <!-- Project header -->
                            <div class="collab-proj-header">
                                <div class="collab-proj-icon" style="background:@iconBg">
                                    <i class="bi bi-folder2-open" style="color:@proj.ColourCode"></i>
                                </div>
                                <div class="overflow-hidden">
                                    <div class="collab-proj-name text-truncate">@proj.Name</div>
                                    <div class="collab-proj-due">Due @proj.DueDate.ToString("MMM d, yyyy")</div>
                                </div>
                                <span class="badge-status @sClass ms-2">@sLabel</span>
                                <i class="bi bi-chevron-down collab-chevron ms-2" id="chevron-@projUid"></i>
                            </div>

                            <!-- Teams (collapsible) -->
                            <div class="collab-teams-wrap" id="@projUid">
                                @if (proj.Teams.Any())
                                {
                                    @foreach (var team in proj.Teams)
                                    {
                                        var teamUid = "team-" + proj.Id.ToString("N") + "-" + team.Id.ToString("N");
                                        <div class="collab-team-row">
                                            <div class="collab-team-header">
                                                <div class="team-color-dot" style="background:@team.ColorCode"></div>
                                                <span class="collab-team-name">@team.Name</span>
                                                <span class="collab-team-count ms-1">(@team.Members.Count)</span>
                                                <i class="bi bi-chevron-down collab-chevron ms-auto" id="chevron-@teamUid"></i>
                                            </div>

                                            <!-- Members (collapsible) -->
                                            <div class="collab-members-wrap" id="@teamUid">
                                                @foreach (var member in team.Members)
                                                {
                                                    var mpct = member.TotalTasks > 0
                                                        ? (int)Math.Round((double)member.CompletedTasks / member.TotalTasks * 100)
                                                        : 0;
                                                    <div class="collab-member-row">
                                                        <div class="collab-member-avatar">@member.Initials</div>
                                                        <div class="flex-grow-1 overflow-hidden">
                                                            <div class="collab-member-name text-truncate">@member.DisplayName</div>
                                                            <div class="collab-member-sub text-truncate">@member.Email &nbsp;&middot;&nbsp; @member.RoleName</div>
                                                            <div class="collab-member-prog">
                                                                <div class="collab-prog-bar">
                                                                    <div class="collab-prog-fill" style="width:@mpct%"></div>
                                                                </div>
                                                                <span class="collab-prog-pct">@member.CompletedTasks/@member.TotalTasks tasks &middot; @mpct%</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <p class="text-muted small ps-2 py-1 mb-0">No members assigned.</p>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">No team activity.</p>
                }
            </div>
        </div>

        <!-- Project Progress -->
        <div class="col-lg-4">
            <div class="section-card clickable-card" onclick="location.href='/Progress'" style="cursor:pointer" title="View full progress overview">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <div class="section-title mb-0">Project Progress</div>
                    <a href="/Progress" class="text-decoration-none small" style="color:var(--pm-green);font-size:.8rem;" onclick="event.stopPropagation()">
                        View details <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                @{
                    int total = Model.Dashboard.TotalProjects > 0 ? Model.Dashboard.TotalProjects : 1;
                    int completed = Model.Dashboard.CompletedProjects;
                    int pct = (int)Math.Round((double)completed / total * 100);
                    double circumference = 2 * Math.PI * 45;
                    double offset = circumference * (1 - pct / 100.0);
                }
                <div class="donut-wrap mx-auto mb-3 mt-2">
                    <svg width="120" height="120" viewBox="0 0 100 100">
                        <circle cx="50" cy="50" r="45" fill="none" stroke="var(--pm-muted-light)" stroke-width="10"/>
                        <circle cx="50" cy="50" r="45" fill="none" stroke="var(--pm-green)" stroke-width="10"
                                stroke-dasharray="@circumference.ToString("F1")"
                                stroke-dashoffset="@offset.ToString("F1")"
                                stroke-linecap="round"/>
                    </svg>
                    <div class="donut-center">
                        <div class="pct">@pct%</div>
                        <div class="label">Done</div>
                    </div>
                </div>
                <div class="d-flex justify-content-around text-center">
                    <div>
                        <div style="font-size:1.1rem; font-weight:700; color:var(--pm-text)">@Model.Dashboard.CompletedProjects</div>
                        <div style="font-size:.72rem; color:var(--pm-muted)">Completed</div>
                    </div>
                    <div>
                        <div style="font-size:1.1rem; font-weight:700; color:var(--pm-text)">@Model.Dashboard.RunningProjects</div>
                        <div style="font-size:.72rem; color:var(--pm-muted)">Running</div>
                    </div>
                    <div>
                        <div style="font-size:1.1rem; font-weight:700; color:var(--pm-text)">@Model.Dashboard.PendingProjects</div>
                        <div style="font-size:.72rem; color:var(--pm-muted)">Pending</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @{
        var projectsJson = System.Text.Json.JsonSerializer.Serialize(
            Model.AllProjects.Select(p => new {
                id       = p.Id,
                name     = p.Name,
                code     = p.ProjectCode,
                client   = p.ClientName,
                status   = p.Status,
                startDate = p.StartDate.ToString("MMM d, yyyy"),
                endDate  = p.ExpectedEndDate.ToString("MMM d, yyyy"),
                colour   = string.IsNullOrEmpty(p.ColourCode) ? "#0D6EFD" : p.ColourCode,
                desc     = (p.Description?.Length > 90 ? p.Description.Substring(0, 90) + "…" : p.Description) ?? ""
            })
        );
    }

    <!-- ── Projects Detail Modal ── -->
    <div class="modal fade" id="projectsModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content" style="border-radius:16px; border:none; box-shadow:0 8px 32px rgba(0,0,0,.14);">
                <div class="modal-header" style="border-bottom:1px solid #f0f0f0; padding:1.25rem 1.5rem;">
                    <div class="d-flex align-items-center gap-2">
                        <h5 class="modal-title mb-0 fw-bold" id="projectsModalTitle" style="color:var(--pm-text);"></h5>
                        <span class="badge rounded-pill" id="projectsModalBadge"
                              style="background:var(--pm-green); font-size:.73rem; padding:4px 10px;"></span>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="padding:1.25rem 1.5rem;">
                    <!-- Search -->
                    <div class="mb-3 position-relative">
                        <i class="bi bi-search position-absolute"
                           style="left:12px; top:50%; transform:translateY(-50%); color:var(--pm-muted); pointer-events:none;"></i>
                        <input type="text" id="projectsSearchInput" class="form-control"
                               placeholder="Search by name, code or client…"
                               style="padding-left:2.3rem; border-radius:10px; border:1.5px solid #dee2e6; font-size:.88rem;">
                    </div>
                    <!-- Project rows -->
                    <div id="projectsModalBody"></div>
                    <div id="projectsNoResults" class="text-center text-muted py-4 d-none">
                        <i class="bi bi-folder-x" style="font-size:2.2rem; opacity:.35;"></i>
                        <p class="mt-2 mb-0 small">No projects match your search.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
    (function () {
        const ALL = @Html.Raw(projectsJson);

        const STATUS = {
            1: { label: 'Active',    bg: '#d1edff', color: '#0056CA' },
            2: { label: 'On Hold',   bg: '#fff3cd', color: '#856404' },
            3: { label: 'Completed', bg: '#d1f5e0', color: '#0a6130' }
        };

        let currentFilter = [];

        window.openProjectModal = function (type) {
            const titles = {
                total:   'All Projects',
                running: 'Running Projects',
                ended:   'Ended Projects',
                pending: 'Pending Projects'
            };
            const filters = {
                total:   null,
                running: 1,
                ended:   3,
                pending: 2
            };

            const statusFilter = filters[type];
            currentFilter = statusFilter === null ? ALL : ALL.filter(p => p.status === statusFilter);

            document.getElementById('projectsModalTitle').textContent = titles[type];
            document.getElementById('projectsModalBadge').textContent = currentFilter.length;
            document.getElementById('projectsSearchInput').value = '';
            renderProjects(currentFilter);

            bootstrap.Modal.getOrCreateInstance(document.getElementById('projectsModal')).show();

            document.getElementById('projectsSearchInput').oninput = function () {
                const q = this.value.toLowerCase();
                const results = currentFilter.filter(p =>
                    p.name.toLowerCase().includes(q) ||
                    p.code.toLowerCase().includes(q) ||
                    p.client.toLowerCase().includes(q)
                );
                document.getElementById('projectsModalBadge').textContent = results.length;
                renderProjects(results);
            };
        };

        function renderProjects(projects) {
            const body = document.getElementById('projectsModalBody');
            const empty = document.getElementById('projectsNoResults');
            if (projects.length === 0) {
                body.innerHTML = '';
                empty.classList.remove('d-none');
                return;
            }
            empty.classList.add('d-none');
            body.innerHTML = projects.map(p => {
                const s = STATUS[p.status] || { label: 'Unknown', bg: '#e9ecef', color: '#6c757d' };
                const initials = p.name.length >= 2 ? p.name.substring(0, 2).toUpperCase() : p.name.toUpperCase();
                return `
                <div class="d-flex align-items-center gap-3 py-2" style="border-bottom:1px solid #f4f4f4;">
                    <div style="width:42px;height:42px;border-radius:10px;background:${p.colour}22;
                                display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <span style="font-weight:700;font-size:.8rem;color:${p.colour};">${initials}</span>
                    </div>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="fw-semibold text-truncate" style="font-size:.9rem;color:var(--pm-text);">${escHtml(p.name)}</div>
                        <div style="font-size:.75rem;color:var(--pm-muted);">${escHtml(p.code)} &middot; ${escHtml(p.client)}</div>
                        ${p.desc ? `<div class="text-truncate" style="font-size:.73rem;color:#999;margin-top:1px;">${escHtml(p.desc)}</div>` : ''}
                    </div>
                    <div class="d-none d-sm-flex flex-column align-items-end" style="flex-shrink:0;">
                        <div style="font-size:.72rem;color:var(--pm-muted);white-space:nowrap;">${p.startDate}</div>
                        <div style="font-size:.72rem;color:var(--pm-muted);white-space:nowrap;">${p.endDate}</div>
                    </div>
                    <span class="badge rounded-pill" style="background:${s.bg};color:${s.color};font-size:.7rem;font-weight:600;white-space:nowrap;flex-shrink:0;">${s.label}</span>
                    <a href="/Projects/Details?id=${p.id}"
                       class="btn btn-sm btn-outline-primary"
                       style="border-radius:8px;font-size:.75rem;padding:3px 11px;white-space:nowrap;flex-shrink:0;">
                        View
                    </a>
                </div>`;
            }).join('');
        }

        function escHtml(str) {
            return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }
    })();
    </script>
</div>

<!-- ── Approve Daily Tasks Modal ── -->
<div class="modal fade" id="approveTasksModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" style="border-radius:16px; border:none; box-shadow:0 8px 32px rgba(0,0,0,.14);">
            <div class="modal-header" style="border-bottom:1px solid #f0f0f0; padding:1.25rem 1.5rem;">
                <div class="d-flex align-items-center gap-2">
                    <h5 class="modal-title mb-0 fw-bold" style="color:var(--pm-text);">Approve Daily Tasks</h5>
                    <span class="badge rounded-pill" style="background:var(--pm-green); font-size:.73rem; padding:4px 10px;">@Model.PendingDailyTasks.Count</span>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:1.25rem 1.5rem;">
                @if (!Model.PendingDailyTasks.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-check2-circle" style="font-size:2.2rem; opacity:.35;"></i>
                        <p class="mt-2 mb-0 small">No pending daily tasks to review.</p>
                    </div>
                }
                else
                {
                    @foreach (var task in Model.PendingDailyTasks)
                    {
                        var submittedBy = task.User != null
                            ? (!string.IsNullOrWhiteSpace(task.User.DisplayName) ? task.User.DisplayName : $"{task.User.FirstName} {task.User.LastName}".Trim())
                            : "Unknown User";
                        <div class="daily-task-row mb-3 p-3" style="border:1px solid #f0f0f0; border-radius:12px;">
                            <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                                <div class="overflow-hidden">
                                    <div class="fw-semibold text-truncate" style="font-size:.95rem; color:var(--pm-text);">@task.TaskName</div>
                                    <div class="text-muted" style="font-size:.78rem;">
                                        <i class="bi bi-person me-1"></i>@submittedBy
                                        &nbsp;&middot;&nbsp;
                                        <i class="bi bi-clock me-1"></i>@task.CreatedAt.ToString("MMM d, yyyy h:mm tt")
                                    </div>
                                    @if (task.ProductBacklog != null)
                                    {
                                        <div class="text-muted" style="font-size:.78rem;">
                                            <i class="bi bi-link-45deg me-1"></i>@task.ProductBacklog.Title
                                        </div>
                                    }
                                </div>
                                <span class="badge-status badge-task-pending">Pending</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(task.Description))
                            {
                                <p class="text-muted mb-2" style="font-size:.85rem;">@task.Description</p>
                            }
                            <div class="d-flex gap-2 align-items-center">
                                <form method="post" asp-page="/PM/Dashboard" asp-page-handler="ApproveDailyTask" class="m-0">
                                    <input type="hidden" name="taskId" value="@task.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="bi bi-check-lg me-1"></i>Approve
                                    </button>
                                </form>
                                <button type="button" class="btn btn-sm btn-outline-warning" onclick="toggleClarifyForm('@task.Id')">
                                    <i class="bi bi-question-circle me-1"></i>Need Clarification
                                </button>
                            </div>
                            <form method="post" asp-page="/PM/Dashboard" asp-page-handler="ClarifyDailyTask" class="mt-2 d-none" id="clarify-form-@task.Id">
                                <input type="hidden" name="taskId" value="@task.Id" />
                                <textarea name="comment" class="form-control form-control-sm mb-2" rows="2" placeholder="What needs clarification?" required></textarea>
                                <button type="submit" class="btn btn-sm btn-warning">Send Back to User</button>
                                <button type="button" class="btn btn-sm btn-link text-muted" onclick="toggleClarifyForm('@task.Id')">Cancel</button>
                            </form>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<script>
    function toggleClarifyForm(id) {
        var form = document.getElementById('clarify-form-' + id);
        if (form) form.classList.toggle('d-none');
    }

    @if (TempData["OpenApproveTasksModal"] != null)
    {
        <text>
        document.addEventListener('DOMContentLoaded', function () {
            bootstrap.Modal.getOrCreateInstance(document.getElementById('approveTasksModal')).show();
        });
        </text>
    }
</script>

<script>
// Track which items are manually expanded (clicked)
const pmManuallyExpanded = new Set();

function togglePmCollab(id) {
    var wrap = document.getElementById(id);
    var chev = document.getElementById('chevron-' + id);
    if (!wrap) return;

    if (pmManuallyExpanded.has(id)) {
        pmManuallyExpanded.delete(id);
        wrap.classList.remove('expanded', 'hover-expanded');
    } else {
        pmManuallyExpanded.add(id);
        wrap.classList.add('expanded');
        wrap.classList.remove('hover-expanded');
    }

    if (chev) chev.classList.toggle('open', pmManuallyExpanded.has(id));
}

function setupPmCollabHoverListeners() {
    const wrappers = document.querySelectorAll('[id^="proj-"], [id^="team-"]');

    wrappers.forEach(wrap => {
        const header = wrap.previousElementSibling;
        if (!header) return;

        header.addEventListener('mouseenter', () => {
            if (!pmManuallyExpanded.has(wrap.id)) {
                wrap.classList.add('hover-expanded');
                const chev = document.getElementById('chevron-' + wrap.id);
                if (chev) chev.classList.add('open');
            }
        });

        header.addEventListener('mouseleave', () => {
            if (!pmManuallyExpanded.has(wrap.id)) {
                wrap.classList.remove('hover-expanded');
                const chev = document.getElementById('chevron-' + wrap.id);
                if (chev) chev.classList.remove('open');
            }
        });

        header.addEventListener('click', (e) => {
            e.stopPropagation();
            togglePmCollab(wrap.id);
        });
    });
}

document.addEventListener('DOMContentLoaded', setupPmCollabHoverListeners);
</script>
}
