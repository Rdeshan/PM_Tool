@page
@using System.Security.Claims
@using PMTool.Application.DTOs.Dashboard
@model DashboardModel
@{
    ViewData["Title"] = "My Dashboard";
    var userName = User.FindFirst(ClaimTypes.Name)?.Value
        ?? User.FindFirst(ClaimTypes.Email)?.Value
        ?? "User";
    var d = Model.Dashboard;

    string StatusLabel(int s) => s switch { 1 => "To Do", 2 => "In Progress", 3 => "In Review", 4 => "Done", _ => "To Do" };
    string StatusBadge(int s) => s switch { 1 => "neutral", 2 => "info", 3 => "accent", 4 => "success", _ => "neutral" };
    string PriorityLabel(int p) => p switch { 1 => "Highest", 2 => "High", 3 => "Medium", 4 => "Low", _ => "Medium" };
    string PriorityColor(int p) => p switch { 1 => "var(--danger-text)", 2 => "var(--warning-text)", 3 => "var(--primary-600)", 4 => "var(--text-muted)", _ => "var(--primary-600)" };
    string TimeAgo(DateTime dt) {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }
}

@if (!User.Identity?.IsAuthenticated ?? true)
{
    <div class="alert alert-warning m-4">
        <p class="mb-0">You must be logged in. <a asp-page="/Auth/Login">Login here</a></p>
    </div>
}
else
{
<style>
    .dash-main { padding: var(--space-6); }

    .dash-header { margin-bottom: var(--space-6); }
    .dash-header h1 { font-size: 1.5rem; font-weight: var(--fw-bold); color: var(--text-heading); margin: 0; }
    .dash-header p  { font-size: var(--fs-sm); color: var(--text-muted); margin: var(--space-1) 0 0; }

    /* Stat cards */
    .stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: var(--space-3); margin-bottom: var(--space-6); }
    @@media (max-width:900px) { .stats-grid { grid-template-columns: repeat(2,1fr); } }
    @@media (max-width:540px) { .stats-grid { grid-template-columns: 1fr; } }

    /* Section card */
    .sec-card {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-xs);
    }
    .sec-card__header {
        display: flex; align-items: center; justify-content: space-between;
        padding: var(--space-4) var(--space-5);
        border-bottom: 1px solid var(--slate-100);
    }
    .sec-card__title {
        font-size: var(--fs-h3); font-weight: var(--fw-semibold);
        color: var(--text-heading);
    }
    .sec-card__body { padding: var(--space-4) var(--space-5); }

    /* Tickets table */
    .tkt-table { width: 100%; border-collapse: collapse; font-size: var(--fs-sm); }
    .tkt-table th {
        text-align: left; font-size: var(--fs-xs); font-weight: var(--fw-semibold);
        text-transform: uppercase; letter-spacing: .04em; color: var(--text-muted);
        padding: var(--space-2) var(--space-3);
        border-bottom: 1px solid var(--border);
        background: var(--slate-50);
    }
    .tkt-table td { padding: var(--space-3); border-bottom: 1px solid var(--slate-100); vertical-align: middle; }
    .tkt-table tr:last-child td { border-bottom: none; }
    .tkt-table tr:hover td { background: var(--slate-50); }
    .tkt-table .tkt-title { font-weight: var(--fw-medium); color: var(--text-heading); max-width: 240px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block; }

    /* Sprint scroll */
    .sprints-scroll { display: flex; flex-direction: column; gap: var(--space-3); max-height: 460px; overflow-y: auto; padding-right: 2px; }
    .sprints-scroll::-webkit-scrollbar { width: 4px; }
    .sprints-scroll::-webkit-scrollbar-thumb { background: var(--slate-200); border-radius: var(--radius-full); }

    /* Sprint card */
    .sprint-card-opms {
        background: var(--primary-800); color: var(--white);
        border-radius: var(--radius-md); padding: var(--space-4) var(--space-5);
    }
    .sprint-card-opms__name { font-family: var(--font-heading); font-weight: var(--fw-bold); font-size: var(--fs-base); margin-bottom: 2px; }
    .sprint-card-opms__dates { font-size: var(--fs-xs); opacity: .75; margin-bottom: var(--space-3); }
    .sprint-card-opms__goal { font-size: var(--fs-xs); opacity: .85; font-style: italic; margin-bottom: var(--space-3); }
    .sprint-pbar { height: 5px; background: rgba(255,255,255,.2); border-radius: var(--radius-full); overflow: hidden; margin-bottom: var(--space-2); }
    .sprint-pbar__fill { height: 100%; background: var(--white); border-radius: var(--radius-full); }
    .sprint-meta { display: flex; justify-content: space-between; align-items: center; font-size: var(--fs-xs); opacity: .8; margin-bottom: var(--space-3); }
    .sprint-stats { display: flex; gap: var(--space-4); font-size: var(--fs-xs); opacity: .8; }

    /* Activity */
    .act-row { display: flex; gap: var(--space-2); padding: var(--space-2) 0; border-bottom: 1px solid var(--slate-100); align-items: flex-start; }
    .act-row:last-child { border-bottom: none; }
    .act-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--primary-400); margin-top: 5px; flex-shrink: 0; }
    .act-dot--done { background: var(--success-solid); }
    .act-dot--prog { background: var(--warning-solid); }
    .act-text { font-size: var(--fs-sm); color: var(--text-body); line-height: 1.35; }
    .act-meta { font-size: var(--fs-xs); color: var(--text-muted); margin-top: 2px; display: flex; align-items: center; gap: 4px; flex-wrap: wrap; }
</style>

<div class="dash-main">
    <!-- Header -->
    <div class="dash-header">
        <h1>My Dashboard</h1>
        <p>Welcome back, <strong>@userName</strong></p>
    </div>

    @if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
    {
        <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1090;">
            @if (TempData["SuccessMessage"] != null)
            {
                <div id="dashToastSuccess" class="toast align-items-center text-bg-success border-0 show" role="alert">
                    <div class="d-flex">
                        <div class="toast-body"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]</div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div id="dashToastError" class="toast align-items-center text-bg-danger border-0 show" role="alert">
                    <div class="d-flex">
                        <div class="toast-body"><i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]</div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>
                </div>
            }
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                ['dashToastSuccess', 'dashToastError'].forEach(function (id) {
                    var el = document.getElementById(id);
                    if (el) setTimeout(function () { bootstrap.Toast.getOrCreateInstance(el).hide(); }, 3000);
                });
            });
        </script>
    }

    <!-- Stat Cards -->
    <div class="stats-grid">
        <div class="opms-stat">
            <div class="opms-stat__top">
                <span class="opms-stat__label">Open Tickets</span>
                <span class="opms-stat__icon opms-stat__icon--primary"><i class="bi bi-ticket-perforated"></i></span>
            </div>
            <div class="opms-stat__value">@d.OpenTickets</div>
            <div class="opms-stat__sub">assigned to me</div>
        </div>
        <div class="opms-stat">
            <div class="opms-stat__top">
                <span class="opms-stat__label">Overdue</span>
                <span class="opms-stat__icon opms-stat__icon--danger"><i class="bi bi-exclamation-circle"></i></span>
            </div>
            <div class="opms-stat__value" style="color:@(d.OverdueTickets > 0 ? "var(--danger-text)" : "var(--text-heading)")">@d.OverdueTickets</div>
            <div class="opms-stat__sub">past due date</div>
        </div>
        <div class="opms-stat">
            <div class="opms-stat__top">
                <span class="opms-stat__label">In Progress</span>
                <span class="opms-stat__icon opms-stat__icon--info"><i class="bi bi-arrow-repeat"></i></span>
            </div>
            <div class="opms-stat__value">@d.InProgressTickets</div>
            <div class="opms-stat__sub">actively working</div>
        </div>
        <div class="opms-stat">
            <div class="opms-stat__top">
                <span class="opms-stat__label">Done This Week</span>
                <span class="opms-stat__icon opms-stat__icon--success"><i class="bi bi-check2-circle"></i></span>
            </div>
            <div class="opms-stat__value" style="color:var(--success-text)">@d.DoneThisWeek</div>
            <div class="opms-stat__sub">completed (&lt;7 days)</div>
        </div>
    </div>

    <!-- Main content -->
    <div class="row g-3">
        <!-- Tickets table -->
        <div class="col-lg-8">
            <div class="sec-card">
                <div class="sec-card__header">
                    <span class="sec-card__title">My Tickets</span>
                    <span class="eyebrow">@d.MyTickets.Count total</span>
                </div>
                <div class="sec-card__body">
                    <!-- Filter pills -->
                    <div class="opms-filter-bar" id="filterPills">
                        <span class="opms-pill active" data-filter="all">All</span>
                        <span class="opms-pill" data-filter="todo">To Do</span>
                        <span class="opms-pill" data-filter="inprog">In Progress</span>
                        <span class="opms-pill" data-filter="inreview">In Review</span>
                        <span class="opms-pill" data-filter="done">Done</span>
                        <span class="opms-pill" data-filter="overdue">Overdue</span>
                    </div>

                    @if (!d.MyTickets.Any())
                    {
                        <div class="opms-empty">
                            <i class="bi bi-inbox"></i>
                            No tickets assigned to you yet.
                        </div>
                    }
                    else
                    {
                        <div style="overflow-x:auto;">
                            <table class="tkt-table" id="ticketsTable">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Status</th>
                                        <th>Priority</th>
                                        <th>Due</th>
                                        <th>Project</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in d.MyTickets)
                                    {
                                        var isOverdue = t.DueDate.HasValue && t.DueDate.Value.Date < DateTime.Today && t.Status != 4;
                                        var isDueSoon = t.DueDate.HasValue && !isOverdue && t.DueDate.Value.Date <= DateTime.Today.AddDays(3) && t.Status != 4;
                                        var filterAttr = t.Status switch { 1 => "todo", 2 => "inprog", 3 => "inreview", 4 => "done", _ => "todo" };
                                        if (isOverdue) filterAttr += " overdue";
                                        <tr data-filter="@filterAttr">
                                            <td><span class="tkt-title">@t.Title</span></td>
                                            <td>
                                                <span class="badge-opms badge-opms--@StatusBadge(t.Status)">
                                                    <span class="dot"></span>@StatusLabel(t.Status)
                                                </span>
                                            </td>
                                            <td>
                                                <span style="color:@PriorityColor(t.Priority);font-weight:var(--fw-semibold);font-size:var(--fs-xs);">
                                                    <i class="bi bi-flag-fill me-1" style="font-size:.65rem;"></i>@PriorityLabel(t.Priority)
                                                </span>
                                            </td>
                                            <td>
                                                @if (t.DueDate.HasValue)
                                                {
                                                    <span style="color:@(isOverdue ? "var(--danger-text)" : isDueSoon ? "var(--warning-text)" : "var(--text-body)");font-weight:@(isOverdue ? "var(--fw-semibold)" : "normal");">
                                                        @t.DueDate.Value.ToString("MMM d")
                                                    </span>
                                                }
                                                else { <span class="text-muted">—</span> }
                                            </td>
                                            <td style="max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                                <span style="font-size:var(--fs-xs);color:var(--text-muted);">@(t.ProductName ?? "—")</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right column -->
        <div class="col-lg-4 d-flex flex-column gap-3">

            <!-- Active Sprints -->
            <div class="sec-card">
                <div class="sec-card__header">
                    <span class="sec-card__title">My Active Sprints</span>
                    @if (d.ActiveSprints.Any())
                    {
                        <span class="badge-opms badge-opms--info">@d.ActiveSprints.Count</span>
                    }
                </div>
                <div class="sec-card__body">
                    @if (!d.ActiveSprints.Any())
                    {
                        <div class="opms-empty" style="padding:var(--space-5) 0;">
                            <i class="bi bi-lightning-charge" style="font-size:1.5rem;"></i>
                            No active sprints assigned to you.
                        </div>
                    }
                    else
                    {
                        <div class="sprints-scroll">
                            @foreach (var sprint in d.ActiveSprints)
                            {
                                var pct = sprint.TotalItems > 0 ? (int)Math.Round(sprint.DoneItems * 100.0 / sprint.TotalItems) : 0;
                                var daysLeft = (sprint.EndDate.Date - DateTime.Today).Days;
                                <div class="sprint-card-opms">
                                    <div class="d-flex align-items-center justify-content-between mb-1">
                                        <div class="sprint-card-opms__name"><i class="bi bi-lightning-charge me-1"></i>@sprint.Name</div>
                                        <span style="font-size:10px;background:rgba(255,255,255,.15);padding:2px 8px;border-radius:var(--radius-full);">Active</span>
                                    </div>
                                    <div class="sprint-card-opms__dates">
                                        @sprint.StartDate.ToString("MMM d") – @sprint.EndDate.ToString("MMM d") ·
                                        @(daysLeft >= 0 ? $"{daysLeft}d left" : $"{-daysLeft}d overdue")
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(sprint.Goal))
                                    {
                                        <div class="sprint-card-opms__goal">"@sprint.Goal"</div>
                                    }
                                    <div class="sprint-pbar">
                                        <div class="sprint-pbar__fill" style="width:@pct%"></div>
                                    </div>
                                    <div class="sprint-meta">
                                        <span>@pct% complete</span>
                                        <span>@sprint.DoneItems / @sprint.TotalItems done</span>
                                    </div>
                                    <div class="sprint-stats">
                                        <span><i class="bi bi-person me-1"></i>@sprint.MyItems my items</span>
                                        <span><i class="bi bi-list-task me-1"></i>@(sprint.TotalItems - sprint.DoneItems) remaining</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="sec-card" style="flex:1;">
                <div class="sec-card__header">
                    <span class="sec-card__title">Recent Activity</span>
                </div>
                <div class="sec-card__body">
                    @if (!d.RecentActivity.Any())
                    {
                        <div class="opms-empty" style="padding:var(--space-5) 0;">
                            <i class="bi bi-clock-history" style="font-size:1.5rem;"></i>
                            No recent activity.
                        </div>
                    }
                    else
                    {
                        @foreach (var a in d.RecentActivity.Take(6))
                        {
                            var dotCls = a.Status == 4 ? "act-dot--done" : a.Status == 2 ? "act-dot--prog" : "";
                            <div class="act-row">
                                <div class="act-dot @dotCls"></div>
                                <div>
                                    <div class="act-text">@a.Title</div>
                                    <div class="act-meta">
                                        <span class="badge-opms badge-opms--@StatusBadge(a.Status)" style="padding:1px 6px;font-size:10px;">@StatusLabel(a.Status)</span>
                                        @if (a.ProductName != null) { <span>· @a.ProductName</span> }
                                        <span>· @TimeAgo(a.UpdatedAt)</span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    document.querySelectorAll('#filterPills .opms-pill').forEach(pill => {
        pill.addEventListener('click', function () {
            document.querySelectorAll('#filterPills .opms-pill').forEach(p => p.classList.remove('active'));
            this.classList.add('active');
            const filter = this.dataset.filter;
            document.querySelectorAll('#ticketsTable tbody tr').forEach(row => {
                if (filter === 'all') {
                    row.style.display = '';
                } else {
                    const rowFilters = (row.dataset.filter || '').split(' ');
                    row.style.display = rowFilters.includes(filter) ? '' : 'none';
                }
            });
        });
    });
</script>
}
