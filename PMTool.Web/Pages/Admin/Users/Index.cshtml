@page
@model PMTool.Web.Pages.Admin.Users.IndexModel
@using PMTool.Application.DTOs.User
@{
    ViewData["Title"] = "User Management";
    var showInactive = Model.ShowInactive;
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>User Management</h1>
            <p class="text-muted">Manage system users and permissions</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="./Invite" class="btn btn-primary">
                <i class="bi bi-person-plus"></i> Invite User
            </a>
            <a asp-page="/Admin/Dashboard" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- Filter Tabs -->
    <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item" role="presentation">
            <a class="nav-link @(!showInactive ? "active" : "")" href="@Url.Page("./Index", new { inactive = false })">
                <i class="bi bi-person-check"></i> Active Users
            </a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link @(showInactive ? "active" : "")" href="@Url.Page("./Index", new { inactive = true })">
                <i class="bi bi-person-x"></i> Inactive Users
            </a>
        </li>
    </ul>

    <!-- Users Table -->
    @if (Model.Users.Any())
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Email</th>
                            <th>Name</th>
                            <th>Roles</th>
                            <th>Teams</th>
                            <th>Status</th>
                            <th>Last Login</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>
                                    <strong>@user.Email</strong>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(user.DisplayName))
                                    {
                                        <span>@user.DisplayName</span>
                                    }
                                    else
                                    {
                                        <span>@user.FirstName @user.LastName</span>
                                    }
                                </td>
                                <td>
                                    @foreach (var role in user.Roles)
                                    {
                                        <span class="badge bg-info">@role</span>
                                    }
                                </td>
                                <td>
                                    @foreach (var team in user.Teams)
                                    {
                                        <span class="badge bg-secondary">@team</span>
                                    }
                                </td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (user.LastLoginAt.HasValue)
                                    {
                                        <small class="text-muted">@user.LastLoginAt.Value.ToString("MMM dd, yyyy HH:mm")</small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">Never</small>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button" class="btn btn-outline-primary" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        @if (user.IsActive)
                                        {
                                            <form method="post" asp-page-handler="Deactivate" style="display: inline;">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit" class="btn btn-outline-warning" title="Deactivate" onclick="return confirm('Deactivate this user?')">
                                                    <i class="bi bi-lock"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form method="post" asp-page-handler="Reactivate" style="display: inline;">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit" class="btn btn-outline-success" title="Reactivate" onclick="return confirm('Reactivate this user?')">
                                                    <i class="bi bi-unlock"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-inbox" style="font-size: 2rem;"></i>
            <p class="mt-3 mb-0">@(showInactive ? "No inactive users" : "No active users")</p>
        </div>
    }
</div>
