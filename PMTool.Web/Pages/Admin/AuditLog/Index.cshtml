@page
@model PMTool.Web.Pages.Admin.AuditLog.IndexModel
@{
    ViewData["Title"] = "Audit Log";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-journal-text"></i> Audit Log</h2>
        <a asp-page="/Admin/Dashboard" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to Admin
        </a>
    </div>

    <!-- Filters -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label fw-semibold">User ID</label>
                    <input type="text" name="FilterUserId" value="@Model.FilterUserId" class="form-control form-control-sm" placeholder="User GUID…" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Entity Type</label>
                    <select name="FilterEntityType" class="form-select form-select-sm">
                        <option value="">All</option>
                        <option value="User" selected="@(Model.FilterEntityType == "User")">User</option>
                        <option value="Project" selected="@(Model.FilterEntityType == "Project")">Project</option>
                        <option value="Sprint" selected="@(Model.FilterEntityType == "Sprint")">Sprint</option>
                        <option value="WorkItem" selected="@(Model.FilterEntityType == "WorkItem")">Work Item</option>
                        <option value="ProductBacklog" selected="@(Model.FilterEntityType == "ProductBacklog")">Product Backlog</option>
                        <option value="ProjectBacklog" selected="@(Model.FilterEntityType == "ProjectBacklog")">Project Backlog</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">From</label>
                    <input type="date" name="FilterDateFrom" value="@Model.FilterDateFrom?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">To</label>
                    <input type="date" name="FilterDateTo" value="@Model.FilterDateTo?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        <i class="bi bi-funnel"></i> Filter
                    </button>
                </div>
                <div class="col-md-2">
                    <a asp-page="./Index" class="btn btn-outline-secondary btn-sm w-100">
                        <i class="bi bi-x-circle"></i> Clear
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Results -->
    <div class="card shadow-sm">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <span class="fw-semibold">
                <i class="bi bi-list-ul"></i> Results
                <span class="badge bg-secondary ms-1">@Model.TotalCount</span>
            </span>
        </div>
        <div class="card-body p-0">
            @if (!Model.Logs.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    No audit records found.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Timestamp (UTC)</th>
                                <th>User</th>
                                <th>Action</th>
                                <th>Entity Type</th>
                                <th>Entity ID</th>
                                <th>Old Value</th>
                                <th>New Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.Logs)
                            {
                                <tr>
                                    <td class="text-nowrap small">@log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td class="small">@log.UserName</td>
                                    <td>
                                        <span class="badge @GetActionBadgeClass(log.Action)">@log.Action</span>
                                    </td>
                                    <td class="small">@log.EntityType</td>
                                    <td class="small font-monospace">@log.EntityId</td>
                                    <td class="small">
                                        @if (!string.IsNullOrEmpty(log.OldValue))
                                        {
                                            <code class="text-danger" title="@log.OldValue">@TruncateJson(log.OldValue)</code>
                                        }
                                    </td>
                                    <td class="small">
                                        @if (!string.IsNullOrEmpty(log.NewValue))
                                        {
                                            <code class="text-success" title="@log.NewValue">@TruncateJson(log.NewValue)</code>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <small class="text-muted">
                            Page @Model.CurrentPage of @Model.TotalPages (@Model.TotalCount total)
                        </small>
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                @if (Model.CurrentPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" asp-page="./Index"
                                           asp-route-CurrentPage="@(Model.CurrentPage - 1)"
                                           asp-route-FilterUserId="@Model.FilterUserId"
                                           asp-route-FilterEntityType="@Model.FilterEntityType"
                                           asp-route-FilterDateFrom="@Model.FilterDateFrom?.ToString("yyyy-MM-dd")"
                                           asp-route-FilterDateTo="@Model.FilterDateTo?.ToString("yyyy-MM-dd")">
                                            &laquo;
                                        </a>
                                    </li>
                                }
                                @for (int p = Math.Max(1, Model.CurrentPage - 2); p <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); p++)
                                {
                                    <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" asp-page="./Index"
                                           asp-route-CurrentPage="@p"
                                           asp-route-FilterUserId="@Model.FilterUserId"
                                           asp-route-FilterEntityType="@Model.FilterEntityType"
                                           asp-route-FilterDateFrom="@Model.FilterDateFrom?.ToString("yyyy-MM-dd")"
                                           asp-route-FilterDateTo="@Model.FilterDateTo?.ToString("yyyy-MM-dd")">
                                            @p
                                        </a>
                                    </li>
                                }
                                @if (Model.CurrentPage < Model.TotalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link" asp-page="./Index"
                                           asp-route-CurrentPage="@(Model.CurrentPage + 1)"
                                           asp-route-FilterUserId="@Model.FilterUserId"
                                           asp-route-FilterEntityType="@Model.FilterEntityType"
                                           asp-route-FilterDateFrom="@Model.FilterDateFrom?.ToString("yyyy-MM-dd")"
                                           asp-route-FilterDateTo="@Model.FilterDateTo?.ToString("yyyy-MM-dd")">
                                            &raquo;
                                        </a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    </div>
                }
            }
        </div>
    </div>
</div>

@functions {
    private static string GetActionBadgeClass(string action) => action switch
    {
        var a when a.StartsWith("Login") => "bg-info text-dark",
        var a when a.StartsWith("Project") => "bg-primary",
        var a when a.StartsWith("Sprint") => "bg-success",
        var a when a.StartsWith("WorkItem") => "bg-warning text-dark",
        var a when a.StartsWith("Role") => "bg-secondary",
        var a when a.StartsWith("Password") || a.StartsWith("TwoFactor") => "bg-danger",
        _ => "bg-dark"
    };

    private static string TruncateJson(string json) =>
        json.Length > 60 ? json[..57] + "…" : json;
}
