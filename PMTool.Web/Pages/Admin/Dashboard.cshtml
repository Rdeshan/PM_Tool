@page
@using System.Security.Claims
@model PMTool.Web.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
    var userName = User.FindFirst(ClaimTypes.Email)?.Value ?? "User";
}

@if (!User.Identity?.IsAuthenticated ?? true)
{
    <div class="alert alert-warning" role="alert">
        <h4 class="alert-heading">Access Denied</h4>
        <p>You must be logged in to access this page. <a asp-page="/Auth/Login">Login here</a></p>
    </div>
}
else if (!User.IsInRole("Administrator"))
{
    <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading">Access Denied</h4>
        <p>Only administrators can access this page.</p>
        <a asp-page="/Dashboard" class="btn btn-sm btn-secondary mt-2">Go to Dashboard</a>
    </div>
}
else
{
<style>
    :root {
        --pm-green:       #1a3c2e;
        --pm-green-mid:   #2d6a4f;
        --pm-green-light: #52b788;
        --pm-green-pale:  #d8f3dc;
        --pm-bg:          #f4f6f5;
        --pm-card:        #ffffff;
        --pm-text:        #1b2b23;
        --pm-muted:       #6c757d;
    }

    body { background: var(--pm-bg); }

    /* ── Sidebar ── */
    .pm-sidebar {
        width: 220px;
        min-height: 100vh;
        background: var(--pm-green);
        color: #fff;
        display: flex;
        flex-direction: column;
        padding: 1.5rem 1rem;
        position: fixed;
        top: 0; left: 0;
        z-index: 100;
    }
    .pm-sidebar .brand { font-size: 1.25rem; font-weight: 700; letter-spacing: .5px; margin-bottom: 2rem; }
    .pm-sidebar .nav-link {
        color: rgba(255,255,255,.7);
        border-radius: 8px;
        padding: .5rem .75rem;
        font-size: .9rem;
        display: flex;
        align-items: center;
        gap: .5rem;
        transition: background .15s, color .15s;
    }
    .pm-sidebar .nav-link:hover,
    .pm-sidebar .nav-link.active {
        background: var(--pm-green-mid);
        color: #fff;
    }
    .pm-sidebar .nav-link i { font-size: 1rem; }

    /* ── Main ── */
    .pm-main { margin-left: 220px; padding: 2rem; }

    /* ── Stat Cards ── */
    .stat-card {
        background: var(--pm-card);
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        border: none;
        height: 100%;
    }
    .stat-card.dark {
        background: var(--pm-green);
        color: #fff;
    }
    .stat-card .stat-label { font-size: .85rem; color: var(--pm-muted); font-weight: 500; }
    .stat-card.dark .stat-label { color: rgba(255,255,255,.7); }
    .stat-card .stat-value { font-size: 2.4rem; font-weight: 700; line-height: 1.1; margin: .3rem 0; color: var(--pm-text); }
    .stat-card.dark .stat-value { color: #fff; }
    .stat-card .stat-sub { font-size: .78rem; color: var(--pm-green-mid); }
    .stat-card.dark .stat-sub { color: var(--pm-green-pale); }
    .stat-card .arrow-btn {
        width: 30px; height: 30px;
        border-radius: 50%;
        border: 1.5px solid #dee2e6;
        display: flex; align-items: center; justify-content: center;
        color: var(--pm-muted);
        font-size: .75rem;
        text-decoration: none;
        transition: border-color .15s, color .15s;
    }
    .stat-card.dark .arrow-btn { border-color: rgba(255,255,255,.3); color: rgba(255,255,255,.7); }
    .stat-card .arrow-btn:hover { border-color: var(--pm-green-light); color: var(--pm-green-mid); }

    /* ── Section Cards ── */
    .section-card {
        background: var(--pm-card);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        border: none;
        height: 100%;
    }
    .section-card .section-title { font-size: 1rem; font-weight: 600; color: var(--pm-text); margin-bottom: 1rem; }

    /* ── Analytics bar chart ── */
    .analytics-bars {
        display: flex;
        align-items: flex-end;
        gap: 8px;
        height: 120px;
    }
    .analytics-bars .bar-wrap {
        display: flex; flex-direction: column; align-items: center; flex: 1; height: 100%;
    }
    .analytics-bars .bar {
        width: 100%;
        border-radius: 20px 20px 8px 8px;
        background: #e9ecef;
        position: relative;
        transition: background .2s;
    }
    .analytics-bars .bar.active { background: var(--pm-green); }
    .analytics-bars .bar.mid   { background: var(--pm-green-light); }
    .analytics-bars .bar-label { font-size: .72rem; color: var(--pm-muted); margin-top: 6px; }
    .analytics-bars .bar-tooltip {
        position: absolute;
        top: -22px; left: 50%;
        transform: translateX(-50%);
        background: var(--pm-green);
        color: #fff;
        font-size: .68rem;
        padding: 1px 5px;
        border-radius: 4px;
        white-space: nowrap;
    }

    /* ── Reminder card ── */
    .reminder-card {
        background: var(--pm-card);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        height: 100%;
    }
    .btn-start-meeting {
        background: var(--pm-green);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: .6rem 1.2rem;
        font-size: .88rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        text-decoration: none;
        transition: background .15s;
    }
    .btn-start-meeting:hover { background: var(--pm-green-mid); color: #fff; }

    /* ── Project list ── */
    .project-list-item {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .5rem 0;
        border-bottom: 1px solid #f0f0f0;
    }
    .project-list-item:last-child { border-bottom: none; }
    .project-icon {
        width: 34px; height: 34px;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: .85rem;
        flex-shrink: 0;
    }
    .project-list-item .proj-name { font-size: .88rem; font-weight: 600; color: var(--pm-text); }
    .project-list-item .proj-due  { font-size: .75rem; color: var(--pm-muted); }

    /* ── Team collab ── */
    .member-row {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .55rem 0;
        border-bottom: 1px solid #f4f4f4;
    }
    .member-row:last-child { border-bottom: none; }
    .member-avatar {
        width: 36px; height: 36px;
        border-radius: 50%;
        object-fit: cover;
        background: var(--pm-green-pale);
        display: flex; align-items: center; justify-content: center;
        font-weight: 700;
        font-size: .8rem;
        color: var(--pm-green);
        flex-shrink: 0;
    }
    .member-info .member-name { font-size: .85rem; font-weight: 600; color: var(--pm-text); }
    .member-info .member-task { font-size: .75rem; color: var(--pm-muted); }
    .badge-status {
        font-size: .7rem;
        padding: 2px 8px;
        border-radius: 20px;
        font-weight: 500;
        margin-left: auto;
        flex-shrink: 0;
    }
    .badge-completed  { background: var(--pm-green-pale);  color: var(--pm-green-mid); }
    .badge-inprogress { background: #fff3cd; color: #856404; }
    .badge-pending    { background: #f8d7da; color: #842029; }

    /* ── Progress donut ── */
    .donut-wrap { position: relative; width: 120px; height: 120px; margin: 0 auto; }
    .donut-wrap svg { transform: rotate(-90deg); }
    .donut-center {
        position: absolute; top: 50%; left: 50%;
        transform: translate(-50%,-50%);
        text-align: center;
    }
    .donut-center .pct   { font-size: 1.5rem; font-weight: 700; color: var(--pm-text); }
    .donut-center .label { font-size: .65rem; color: var(--pm-muted); }

    /* Project list card */
    .dashboard-project-card .project-list-item {
        padding: .65rem 0;
        border-bottom: none;
    }
    .dashboard-project-card .project-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
    }

    /* ── Recent Project Cards ── */
    .proj-card {
        background: var(--pm-card);
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        border: none;
    }

    /* ── Topbar ── */
    .pm-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.75rem;
    }
    .pm-topbar h4 { font-weight: 700; color: var(--pm-text); margin: 0; }
    .pm-topbar .topbar-right { display: flex; gap: .75rem; align-items: center; }
</style>

<!-- Sidebar -->
<div class="pm-sidebar d-none d-lg-flex">
    <div class="brand"><i class="bi bi-grid-3x3-gap-fill me-2"></i>PM Tool</div>
    <nav class="d-flex flex-column gap-1">
        <a href="#" class="nav-link active"><i class="bi bi-speedometer2"></i> Dashboard</a>
        <a asp-page="/Projects/Index" class="nav-link"><i class="bi bi-folder2"></i> Projects</a>
        <a href="#" class="nav-link"><i class="bi bi-people"></i> Team</a>
        <a href="#" class="nav-link"><i class="bi bi-bar-chart"></i> Analytics</a>
        <a asp-page="/Account/Settings" class="nav-link"><i class="bi bi-gear"></i> Settings</a>
    </nav>
    <div class="mt-auto">
        <form method="post">
            <button type="submit" asp-page-handler="Logout" class="nav-link border-0 bg-transparent w-100 text-start">
                <i class="bi bi-box-arrow-left"></i> Logout
            </button>
        </form>
    </div>
</div>

<!-- Main Content -->
<div class="pm-main">
    <!-- Topbar -->
    <div class="pm-topbar">
        <div>
            <h4>Admin Dashboard</h4>
            <p class="text-muted mb-0" style="font-size:.85rem;">Welcome back, @userName</p>
        </div>
        <div class="topbar-right">
            <a asp-page="/Account/Settings" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-gear me-1"></i>Settings
            </a>
            <a asp-page="/Dashboard" class="btn btn-sm btn-outline-secondary">User View</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- ── Stat Cards Row ── -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="stat-card dark">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="stat-label">Total Projects</span>
                    <a href="#" class="arrow-btn"><i class="bi bi-arrow-up-right"></i></a>
                </div>
                <div class="stat-value">@Model.Dashboard.TotalProjects</div>
                <div class="stat-sub"><i class="bi bi-graph-up me-1"></i>Increased from last month</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="stat-label">Ended Projects</span>
                    <a href="#" class="arrow-btn"><i class="bi bi-arrow-up-right"></i></a>
                </div>
                <div class="stat-value">@Model.Dashboard.CompletedProjects</div>
                <div class="stat-sub"><i class="bi bi-graph-up me-1"></i>Increased from last month</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="stat-label">Running Projects</span>
                    <a href="#" class="arrow-btn"><i class="bi bi-arrow-up-right"></i></a>
                </div>
                <div class="stat-value">@Model.Dashboard.RunningProjects</div>
                <div class="stat-sub"><i class="bi bi-graph-up me-1"></i>Increased from last month</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="stat-label">Pending Project</span>
                    <a href="#" class="arrow-btn"><i class="bi bi-arrow-up-right"></i></a>
                </div>
                <div class="stat-value">@Model.Dashboard.PendingProjects</div>
                <div class="stat-sub text-muted">On Discuss</div>
            </div>
        </div>
    </div>

    <!-- ── Middle Row: Analytics | Reminder | Project List ── -->
    @* Removed: legacy analytics, reminders, and small project list row.
    <div class="row g-3 mb-4 d-none">

        <!-- Reminders -->
        <div class="col-lg-4">
            <div class="reminder-card">
                <div class="section-title">Reminders</div>
                <p class="fw-bold" style="font-size:1.05rem; color: var(--pm-text);">Meeting with Arc Company</p>
                <p class="text-muted" style="font-size:.85rem;">Time : 02.00 pm – 04.00 pm</p>
                <a href="#" class="btn-start-meeting mt-2">
                    <i class="bi bi-camera-video-fill"></i> Start Meeting
                </a>
            </div>
        </div>

        <!-- Project List -->
        <div class="col-lg-4">
            <div class="section-card">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="section-title mb-0">Project</span>
                    <a asp-page="/Projects/Create" class="btn btn-sm btn-outline-secondary" style="border-radius:8px; font-size:.78rem;">
                        <i class="bi bi-plus"></i> New
                    </a>
                </div>
                @if (Model.RecentProjects.Any())
                {
                    @foreach (var project in Model.RecentProjects.Take(5))
                    {
                        <div class="project-list-item">
                            <div class="project-icon"
                                 style="background:@(string.IsNullOrEmpty(project.ColourCode) ? "var(--pm-green-pale)" : project.ColourCode + "33")">
                                <i class="bi bi-folder2-open" style="color:@(string.IsNullOrEmpty(project.ColourCode) ? "var(--pm-green-mid)" : project.ColourCode)"></i>
                            </div>
                            <div class="overflow-hidden">
                                <div class="proj-name text-truncate">@project.Name</div>
                                <div class="proj-due">Due date: @project.ExpectedEndDate.ToString("MMM d, yyyy")</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">No projects yet.</p>
                }
            </div>
        </div>
    </div>

    *@

    <!-- Bottom Row: Team Collab | Project Progress | Project List -->
    <div class="row g-3 mb-4">

        <!-- Team Collaboration -->
        <div class="col-lg-5">
            <div class="section-card">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="section-title mb-0">Team Collaboration</span>
                    <a href="#" class="btn btn-sm btn-outline-secondary" style="border-radius:8px; font-size:.78rem;">
                        <i class="bi bi-plus"></i> Add Member
                    </a>
                </div>
                @if (Model.RecentProjects.Any())
                {
                    @foreach (var project in Model.RecentProjects.Take(4))
                    {
                        var status = project.Status;
                        var statusLabel = status == 3 ? "Completed" : status == 1 ? "In Progress" : "Pending";
                        var statusClass = status == 3 ? "badge-completed" : status == 1 ? "badge-inprogress" : "badge-pending";
                        var initials = project.ClientName?.Length > 1 ? project.ClientName.Substring(0, 2).ToUpper() : "??";
                        <div class="member-row">
                            <div class="member-avatar">@initials</div>
                            <div class="member-info overflow-hidden">
                                <div class="member-name text-truncate">@project.ClientName</div>
                                <div class="member-task text-truncate">Working on @project.Name</div>
                            </div>
                            <span class="badge-status @statusClass">@statusLabel</span>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">No team activity.</p>
                }
            </div>
        </div>

        <!-- Project Progress -->
        <div class="col-lg-4">
            <div class="section-card">
                <div class="section-title">Project Progress</div>
                @{
                    int total = Model.Dashboard.TotalProjects > 0 ? Model.Dashboard.TotalProjects : 1;
                    int completed = Model.Dashboard.CompletedProjects;
                    int pct = (int)Math.Round((double)completed / total * 100);
                    double circumference = 2 * Math.PI * 45;
                    double offset = circumference * (1 - pct / 100.0);
                }
                <div class="donut-wrap mx-auto mb-3">
                    <svg width="120" height="120" viewBox="0 0 100 100">
                        <circle cx="50" cy="50" r="45" fill="none" stroke="#e9ecef" stroke-width="10"/>
                        <circle cx="50" cy="50" r="45" fill="none" stroke="#1a3c2e" stroke-width="10"
                                stroke-dasharray="@circumference.ToString("F1")"
                                stroke-dashoffset="@offset.ToString("F1")"
                                stroke-linecap="round"/>
                    </svg>
                    <div class="donut-center">
                        <div class="pct">@pct%</div>
                        <div class="label">Done</div>
                    </div>
                </div>
                <div class="d-flex justify-content-around text-center">
                    <div>
                        <div style="font-size:1.1rem; font-weight:700; color:var(--pm-text)">@Model.Dashboard.CompletedProjects</div>
                        <div style="font-size:.72rem; color:var(--pm-muted)">Completed</div>
                    </div>
                    <div>
                        <div style="font-size:1.1rem; font-weight:700; color:var(--pm-text)">@Model.Dashboard.RunningProjects</div>
                        <div style="font-size:.72rem; color:var(--pm-muted)">Running</div>
                    </div>
                    <div>
                        <div style="font-size:1.1rem; font-weight:700; color:var(--pm-text)">@Model.Dashboard.PendingProjects</div>
                        <div style="font-size:.72rem; color:var(--pm-muted)">Pending</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Project List -->
        <div class="col-lg-3">
            <div class="section-card dashboard-project-card">
                <div class="section-title">Recent Projects</div>
                @if (Model.Dashboard.UpcomingProjects.Any())
                {
                    @foreach (var project in Model.Dashboard.UpcomingProjects.Take(5))
                    {
                        <div class="project-list-item">
                            <div class="project-icon"
                                 style="background:@(string.IsNullOrEmpty(project.ColourCode) ? "var(--pm-green-pale)" : project.ColourCode + "33")">
                                <i class="bi bi-folder2-open" style="color:@(string.IsNullOrEmpty(project.ColourCode) ? "var(--pm-green-mid)" : project.ColourCode)"></i>
                            </div>
                            <div class="overflow-hidden">
                                <div class="proj-name text-truncate">@project.Name</div>
                                <div class="proj-due">Due date: @project.DueDate.ToString("MMM d, yyyy")</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small mb-0">No projects yet.</p>
                }
            </div>
        </div>
    </div>

    @if (false && Model.RecentProjects.Any())
    {
        <div class="mb-2">
            <h6 class="fw-semibold text-muted text-uppercase" style="font-size:.78rem; letter-spacing:.5px;">Recent Projects</h6>
        </div>
        <div class="row g-3 mb-4">
            @foreach (var project in Model.RecentProjects)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card proj-card h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-start justify-content-between mb-2">
                                <div>
                                    <h6 class="card-title mb-0">@project.Name</h6>
                                    <p class="text-muted small mb-0">@project.ProjectCode</p>
                                </div>
                                @if (!string.IsNullOrEmpty(project.ColourCode))
                                {
                                    <div class="rounded" style="background-color:@project.ColourCode; width:28px; height:28px;"></div>
                                }
                            </div>
                            <p class="small text-muted mb-1">@project.ClientName</p>
                            <p class="small text-secondary mb-2">
                                @(project.Description?.Length > 60 ? project.Description.Substring(0, 60) + "…" : project.Description)
                            </p>
                            <div class="small text-muted">
                                <i class="bi bi-calendar3 me-1"></i>
                                @project.StartDate.ToShortDateString() – @project.ExpectedEndDate.ToShortDateString()
                            </div>
                            <div class="mt-2">
                                <span class="badge @GetStatusBadgeClass(project.Status)">@GetStatusLabel(project.Status)</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 pt-0">
                            <div class="btn-group w-100" role="group">
                                <a asp-page="/Projects/Details" asp-route-id="@project.Id" class="btn btn-sm btn-outline-primary">View</a>
                                <a asp-page="/Projects/Edit"    asp-route-id="@project.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form method="post" asp-page-handler="DeleteProject" style="display:inline; width:33.33%;">
                                    <input type="hidden" name="projectId" value="@project.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100"
                                            onclick="return confirm('Delete this project?')">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

}

@functions {
    private string GetStatusLabel(int status) => status switch {
        1 => "Active", 2 => "On Hold", 3 => "Completed", _ => "Unknown"
    };
    private string GetStatusBadgeClass(int status) => status switch {
        1 => "bg-success", 2 => "bg-warning text-dark", 3 => "bg-secondary", _ => "bg-secondary"
    };
}
