@page
@using System.Security.Claims
@using PMTool.Domain.Enums
@model PMTool.Web.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
    var userName = User.FindFirst(ClaimTypes.Email)?.Value ?? "User";
}

@if (!User.Identity?.IsAuthenticated ?? true)
{
    <div class="alert alert-warning" role="alert">
        <h4 class="alert-heading">Access Denied</h4>
        <p>You must be logged in to access this page. <a asp-page="/Auth/Login">Login here</a></p>
    </div>
}
else if (!User.IsInRole("Administrator"))
{
    <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading">Access Denied</h4>
        <p>Only administrators can access this page.</p>
        <a asp-page="/Dashboard" class="btn btn-sm btn-secondary mt-2">Go to Dashboard</a>
    </div>
}
else
{
<style>
    :root {
        --pm-green:       #0D6EFD;
        --pm-green-mid:   #0056CA;
        --pm-green-light: #4D94FF;
        --pm-green-pale:  #E7F1FF;
        --pm-bg:          #f4f6f5;
        --pm-card:        #ffffff;
        --pm-text:        #1b2b23;
        --pm-muted:       #6c757d;
        --pm-muted-light: #e9ecef;
    }

    body { background: var(--pm-bg); }

    /* ── Sidebar ── */
    .pm-sidebar {
        width: 220px;
        min-height: 100vh;
        background: var(--pm-green);
        color: #fff;
        display: flex;
        flex-direction: column;
        padding: 1.5rem 1rem;
        position: fixed;
        top: 0; left: 0;
        z-index: 100;
    }
    .pm-sidebar .brand { font-size: 1.25rem; font-weight: 700; letter-spacing: .5px; margin-bottom: 2rem; }
    .pm-sidebar .nav-link {
        color: rgba(255,255,255,.7);
        border-radius: 8px;
        padding: .5rem .75rem;
        font-size: .9rem;
        display: flex;
        align-items: center;
        gap: .5rem;
        transition: background .15s, color .15s;
    }
    .pm-sidebar .nav-link:hover,
    .pm-sidebar .nav-link.active {
        background: var(--pm-green-mid);
        color: #fff;
    }
    .pm-sidebar .nav-link i { font-size: 1rem; }

    /* ── Main ── */
    .pm-main { margin-left: 0; padding: 0; }

    /* ── Stat Cards ── */
    .stat-card {
        background: var(--pm-card);
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        border: none;
        height: 100%;
    }
    .stat-card.dark {
        background: var(--pm-green);
        color: #fff;
    }
    .stat-card .stat-label { font-size: .85rem; color: var(--pm-muted); font-weight: 500; }
    .stat-card.dark .stat-label { color: rgba(255,255,255,.7); }
    .stat-card .stat-value { font-size: 2.4rem; font-weight: 700; line-height: 1.1; margin: .3rem 0; color: var(--pm-text); }
    .stat-card.dark .stat-value { color: #fff; }
    .stat-card .stat-sub { font-size: .78rem; color: var(--pm-green-mid); }
    .stat-card.dark .stat-sub { color: var(--pm-green-pale); }
    .stat-card.clickable { cursor: pointer; transition: box-shadow .15s, transform .15s; }
    .stat-card.clickable:hover { box-shadow: 0 4px 14px rgba(0,0,0,.1); transform: translateY(-2px); }
    .clickable-card { transition: box-shadow .15s, transform .15s; }
    .clickable-card:hover { box-shadow: 0 6px 18px rgba(0,0,0,.12); transform: translateY(-2px); }

    /* ── Section Cards ── */
    .section-card {
        background: var(--pm-card);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        border: none;
        height: auto;
    }
    .section-card .section-title { font-size: 1rem; font-weight: 600; color: var(--pm-text); margin-bottom: 1rem; }

    /* ── Analytics bar chart ── */
    .analytics-bars {
        display: flex;
        align-items: flex-end;
        gap: 8px;
        height: 120px;
    }
    .analytics-bars .bar-wrap {
        display: flex; flex-direction: column; align-items: center; flex: 1; height: 100%;
    }
    .analytics-bars .bar {
        width: 100%;
        border-radius: 20px 20px 8px 8px;
        background: #e9ecef;
        position: relative;
        transition: background .2s;
    }
    .analytics-bars .bar.active { background: var(--pm-green); }
    .analytics-bars .bar.mid   { background: var(--pm-green-light); }
    .analytics-bars .bar-label { font-size: .72rem; color: var(--pm-muted); margin-top: 6px; }
    .analytics-bars .bar-tooltip {
        position: absolute;
        top: -22px; left: 50%;
        transform: translateX(-50%);
        background: var(--pm-green);
        color: #fff;
        font-size: .68rem;
        padding: 1px 5px;
        border-radius: 4px;
        white-space: nowrap;
    }

    /* ── Reminder card ── */
    .reminder-card {
        background: var(--pm-card);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        height: 100%;
    }
    .btn-start-meeting {
        background: var(--pm-green);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: .6rem 1.2rem;
        font-size: .88rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        text-decoration: none;
        transition: background .15s;
    }
    .btn-start-meeting:hover { background: var(--pm-green-mid); color: #fff; }

    /* ── Project list ── */
    .project-list-item {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .5rem 0;
        border-bottom: 1px solid #f0f0f0;
    }
    .project-list-item:last-child { border-bottom: none; }
    .project-icon {
        width: 34px; height: 34px;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: .85rem;
        flex-shrink: 0;
    }
    .project-list-item .proj-name { font-size: .88rem; font-weight: 600; color: var(--pm-text); }
    .project-list-item .proj-due  { font-size: .75rem; color: var(--pm-muted); }

    /* ── Team collab ── */
    .member-row {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .55rem 0;
        border-bottom: 1px solid #f4f4f4;
    }
    .member-row:last-child { border-bottom: none; }
    .member-avatar {
        width: 36px; height: 36px;
        border-radius: 50%;
        object-fit: cover;
        background: var(--pm-green-pale);
        display: flex; align-items: center; justify-content: center;
        font-weight: 700;
        font-size: .8rem;
        color: var(--pm-green);
        flex-shrink: 0;
    }
    .member-info .member-name { font-size: .85rem; font-weight: 600; color: var(--pm-text); }
    .member-info .member-task { font-size: .75rem; color: var(--pm-muted); }
    .badge-status {
        font-size: .7rem;
        padding: 2px 8px;
        border-radius: 20px;
        font-weight: 500;
        margin-left: auto;
        flex-shrink: 0;
    }
    .badge-completed  { background: var(--pm-green-pale);  color: var(--pm-green-mid); }
    .badge-inprogress { background: #fff3cd; color: #856404; }
    .badge-pending    { background: #f8d7da; color: #842029; }

    /* ── Progress donut ── */
    .donut-wrap { position: relative; width: 120px; height: 120px; margin: 0 auto; }
    .donut-wrap svg { transform: rotate(-90deg); }
    .donut-center {
        position: absolute; top: 50%; left: 50%;
        transform: translate(-50%,-50%);
        text-align: center;
    }
    .donut-center .pct   { font-size: 1.5rem; font-weight: 700; color: var(--pm-text); }
    .donut-center .label { font-size: .65rem; color: var(--pm-muted); }

    /* Project list card */
    .dashboard-project-card .project-list-item {
        padding: .65rem 0;
        border-bottom: none;
    }
    .dashboard-project-card .project-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
    }

    /* ── Recent Project Cards ── */
    .proj-card {
        background: var(--pm-card);
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        border: none;
    }

    /* ── Topbar ── */
    .pm-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.75rem;
    }
    .pm-topbar h4 { font-weight: 700; color: var(--pm-text); margin: 0; }
    .pm-topbar .topbar-right { display: flex; gap: .75rem; align-items: center; }

    /* ── Team Collab Hierarchy ── */
    .collab-project-row {
        border-bottom: 1px solid #f0f0f0;
        padding-bottom: .2rem;
        margin-bottom: .2rem;
    }
    .collab-project-row:last-child { border-bottom: none; margin-bottom: 0; }

    .collab-proj-header {
        display: flex;
        align-items: center;
        gap: .6rem;
        padding: .45rem .3rem;
        border-radius: 8px;
        cursor: pointer;
        transition: background .15s;
        user-select: none;
    }
    .collab-proj-header:hover { background: #f8f9fa; }

    .collab-proj-icon {
        width: 32px; height: 32px;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: .8rem;
        flex-shrink: 0;
    }
    .collab-proj-name { font-size: .88rem; font-weight: 600; color: var(--pm-text); }
    .collab-proj-due  { font-size: .72rem; color: var(--pm-muted); }

    .collab-chevron {
        font-size: .75rem;
        color: var(--pm-muted);
        transition: transform .25s ease;
        flex-shrink: 0;
    }
    .collab-chevron.open { transform: rotate(180deg); }

    .collab-teams-wrap {
        overflow: hidden;
        max-height: 0;
        transition: max-height .35s ease;
        padding-left: .75rem;
    }
    .collab-teams-wrap.expanded,
    .collab-teams-wrap.hover-expanded { max-height: 1000px; }

    .collab-team-row { margin: .2rem 0; }

    .collab-team-header {
        display: flex;
        align-items: center;
        gap: .45rem;
        padding: .3rem .4rem;
        cursor: pointer;
        border-radius: 6px;
        transition: background .15s;
        user-select: none;
    }
    .collab-team-header:hover { background: #f4f6f5; }

    .team-color-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .collab-team-name  { font-size: .8rem; font-weight: 600; color: var(--pm-text); }
    .collab-team-count { font-size: .7rem; color: var(--pm-muted); }

    .collab-members-wrap {
        overflow: hidden;
        max-height: 0;
        transition: max-height .3s ease;
        padding-left: 1rem;
    }
    .collab-members-wrap.expanded,
    .collab-members-wrap.hover-expanded { max-height: 1000px; }

    .collab-member-row {
        display: flex;
        align-items: flex-start;
        gap: .55rem;
        padding: .4rem .2rem;
        border-bottom: 1px solid #f7f7f7;
    }
    .collab-member-row:last-child { border-bottom: none; }

    .collab-member-avatar {
        width: 30px; height: 30px;
        border-radius: 50%;
        background: var(--pm-green-pale);
        display: flex; align-items: center; justify-content: center;
        font-size: .7rem; font-weight: 700;
        color: var(--pm-green);
        flex-shrink: 0;
        margin-top: 2px;
    }
    .collab-member-name { font-size: .82rem; font-weight: 600; color: var(--pm-text); line-height: 1.25; }
    .collab-member-sub  { font-size: .71rem; color: var(--pm-muted); }

    .collab-member-prog {
        display: flex;
        align-items: center;
        gap: .4rem;
        margin-top: .3rem;
    }
    .collab-prog-bar {
        flex: 1;
        height: 5px;
        background: #e9ecef;
        border-radius: 4px;
        overflow: hidden;
        min-width: 55px;
    }
    .collab-prog-fill {
        height: 100%;
        border-radius: 4px;
        background: var(--pm-green);
        transition: width .6s ease;
    }
    .collab-prog-pct { font-size: .69rem; color: var(--pm-muted); white-space: nowrap; }

    /* ── Upcoming Deadlines ── */
    .deadline-item {
        display: flex;
        align-items: center;
        gap: .65rem;
        padding: .55rem 0;
        border-bottom: 1px solid #f0f0f0;
    }
    .deadline-item:last-child { border-bottom: none; }
    .deadline-dot {
        width: 10px; height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .deadline-name {
        font-size: .85rem;
        font-weight: 600;
        color: var(--pm-text);
        flex: 1;
        overflow: hidden;
    }
    .deadline-date {
        font-size: .75rem;
        color: var(--pm-muted);
        white-space: nowrap;
        flex-shrink: 0;
        margin-left: .75rem;
    }
</style>
@* 
