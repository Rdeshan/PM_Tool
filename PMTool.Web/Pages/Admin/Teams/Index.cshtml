@page
@model PMTool.Web.Pages.Admin.Teams.IndexModel
@{
    ViewData["Title"] = "Team Management";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Team Management</h1>
            <p class="text-muted">Manage teams and team members</p>
        </div>
        <div class="col-md-4 text-end">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createTeamModal">
                <i class="bi bi-plus-circle"></i> Create Team
            </button>
            <a asp-page="/Admin/Dashboard" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <!-- Teams List -->
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-people"></i> Teams</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush" style="max-height: 600px; overflow-y: auto;">
                        @if (Model.Teams.Any())
                        {
                            @foreach (var team in Model.Teams)
                            {
                                <button type="button" class="list-group-item list-group-item-action @(Model.SelectedTeamId == team.Id ? "active" : "")" 
                                        onclick="location.href='@Url.Page("./Index", new { teamId = team.Id })'">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="mb-1">@team.Name</h6>
                                            <small class="text-muted">@team.MemberCount members</small>
                                        </div>
                                        @if (team.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </div>
                                </button>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                <p class="mt-3 mb-0">No teams yet</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Team Members -->
        <div class="col-md-7">
            @if (Model.SelectedTeamId.HasValue && Model.SelectedTeamId != Guid.Empty)
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-person-check"></i> Team Members</h5>
                        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addMemberModal">
                            <i class="bi bi-person-plus"></i> Add Member
                        </button>
                    </div>
                    <div class="card-body">
                        @if (Model.TeamMembers.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Roles</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var member in Model.TeamMembers)
                                        {
                                            <tr>
                                                <td>@(string.IsNullOrEmpty(member.DisplayName) ? $"{member.FirstName} {member.LastName}" : member.DisplayName)</td>
                                                <td>
                                                    <small>@member.Email</small>
                                                </td>
                                                <td>
                                                    @foreach (var role in member.Roles)
                                                    {
                                                        <span class="badge bg-info bg-opacity-10 text-info">@role</span>
                                                    }
                                                </td>
                                                <td>
                                                    <form method="post" asp-page-handler="RemoveMember" style="display: inline;">
                                                        <input type="hidden" name="userId" value="@member.Id" />
                                                        <input type="hidden" name="teamId" value="@Model.SelectedTeamId" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Remove from team?')">
                                                            <i class="bi bi-x"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-people-fill" style="font-size: 2rem;"></i>
                                <p class="mt-3 mb-0">No members in this team yet</p>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info py-5 text-center">
                    <i class="bi bi-info-circle" style="font-size: 2rem;"></i>
                    <p class="mt-3 mb-0">Select a team to view members</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Create Team Modal -->
<div class="modal fade" id="createTeamModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create New Team</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="CreateTeam">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="teamName" class="form-label">Team Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="teamName" name="Input.Name" placeholder="e.g., Development, QA, Design" required />
                    </div>
                    <div class="mb-3">
                        <label for="teamDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="teamDescription" name="Input.Description" rows="3" placeholder="Team description..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Team</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Member Modal -->
@if (Model.SelectedTeamId.HasValue && Model.SelectedTeamId != Guid.Empty)
{
    <div class="modal fade" id="addMemberModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Team Member</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="AddMember">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="memberId" class="form-label">Select User <span class="text-danger">*</span></label>
                            <select class="form-select" id="memberId" name="userId" required>
                                <option value="">-- Choose a user --</option>
                                @foreach (var user in Model.AvailableUsers)
                                {
                                    <option value="@user.Id">@user.Email - @user.FirstName @user.LastName</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <input type="hidden" name="teamId" value="@Model.SelectedTeamId" />
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add Member</button>
                    </div>
                                 </form>
                             </div>
                         </div>
                     </div>
                }
