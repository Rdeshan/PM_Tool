@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OPMS</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PMTool.Web.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    
</head>
@* <body class="with-navbar"> *@
<body class="@(User.Identity?.IsAuthenticated == true ? "with-sidebar" : "with-navbar")">

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- Global Sidebar -->
        <div id="pm-global-sidebar" class="pm-global-sidebar">
            <a asp-area="" asp-page="/Dashboard" class="brand">
                <i class="bi bi-kanban me-2"></i>
                <span class="brand-text">OPMS</span>
            </a>
            <nav class="d-flex flex-column gap-1">
                <a asp-page="/Dashboard" class="nav-link"><i class="bi bi-speedometer2"></i> <span class="nav-text">Dashboard</span></a>
                <a asp-page="/Projects/Index" class="nav-link"><i class="bi bi-folder2"></i> <span class="nav-text">Projects</span></a>
                <a asp-page="/Tasks/Index" class="nav-link"><i class="bi bi-list-task"></i> <span class="nav-text">Tasks</span></a>
                @* @if (User.IsInRole("Project Manager"))
                {
                    <a asp-page="/PM/Dashboard" class="nav-link"><i class="bi bi-kanban"></i> <span class="nav-text">PM Dashboard</span></a>
                } *@
                @if (User.IsInRole("Administrator"))
                {
                    <a asp-page="/Admin/Users/Index" class="nav-link"><i class="bi bi-person-badge"></i> <span class="nav-text">Users</span></a>
                    <a asp-page="/Admin/Teams/Index" class="nav-link"><i class="bi bi-people"></i> <span class="nav-text">Teams</span></a>
                }
            </nav>
            <div class="mt-auto">
                <a asp-page="/Account/Settings" class="nav-link"><i class="bi bi-gear"></i> <span class="nav-text">Settings</span></a>
                <form method="post" asp-page="/Dashboard" asp-page-handler="Logout" class="m-0" id="logoutFormSidebar">
                    <button type="button" class="nav-link border-0 bg-transparent w-100 text-start" onclick="confirmLogout('logoutFormSidebar')">
                        <i class="bi bi-box-arrow-left"></i> <span class="nav-text">Logout</span>
                    </button>
                </form>
            </div>
        </div>
    }
    <header class="hover-header">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark fixed-top" style="background-color: #0f172a;">
            @* <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Dashboard">
                    <i class="bi bi-kanban"></i> OPMS
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" *@
                      
            <div class="container-fluid px-3">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button class="btn btn-outline-light border-0 me-3" id="sidebar-toggle" type="button">
                        <i class="bi bi-list fs-4"></i>
                    </button>
                }
                else
                {
                    <a class="navbar-brand" asp-area="" asp-page="/Dashboard">
                        <i class="bi bi-kanban"></i> OPMS
                    </a>
                }
                
                <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                @* <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between"> *@
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        @* <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="" asp-page="/Dashboard">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="" asp-page="/Projects/Index">Projects</a>
                            </li>
                            
                            <li class="nav-item">
                                <a class="nav-link text-light" href="#">Tasks</a>
                            </li>
                            @if (User.IsInRole("Administrator"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-light" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-gear"></i> Admin
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                        <li><a class="dropdown-item" asp-page="/Admin/Users/Index"><i class="bi bi-people"></i> Users</a></li>
                                        <li><a class="dropdown-item" asp-page="/Admin/Teams/Index"><i class="bi bi-diagram-3"></i> Teams</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-page="/Admin/Dashboard"><i class="bi bi-speedometer2"></i> Admin Dashboard</a></li>
                                    </ul>
                                </li>
                            }
                            @if (User.IsInRole("Project Manager"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-light" asp-page="/PM/Dashboard"><i class="bi bi-speedometer2"></i> PM Dashboard</a>
                                </li>
                            }
                        </ul> *@
                        <ul class="navbar-nav ms-auto align-items-center">
                            <li class="nav-item dropdown me-2">
                                <button class="btn nav-link text-light position-relative" id="notificationToggle" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-bell"></i>
                                    <span class="notification-badge" id="notificationCount"></span>
                                </button>
                                <div class="dropdown-menu dropdown-menu-end notification-menu" aria-labelledby="notificationToggle">
                                    <div class="notification-header">Notifications</div>
                                    <div id="notificationList" class="notification-list"></div>
                                    <div id="notificationEmpty" class="notification-empty">No notifications</div>
                                </div>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i> @(User.FindFirst(ClaimTypes.Email)?.Value ?? "User")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" asp-page="/Account/Profile"><i class="bi bi-person"></i> Profile</a></li>
                                    <li><a class="dropdown-item" asp-page="/Account/Settings"><i class="bi bi-sliders"></i> Settings</a></li>
                                    @* <li><a class="dropdown-item" asp-page="/Account/Security"><i class="bi bi-shield-lock"></i> Security</a></li>
                                    <li><a class="dropdown-item" asp-page="/Account/TwoFactor"><i class="bi bi-lock-fill"></i> Two-Factor Auth</a></li> *@
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-page="/Dashboard" asp-page-handler="Logout" style="display:inline;" id="logoutFormNavbar">
                                            <button type="button" class="dropdown-item text-danger" onclick="confirmLogout('logoutFormNavbar')"><i class="bi bi-box-arrow-right"></i> Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-page="/Auth/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-page="/Auth/Register">Register</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    @* <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div> *@

    @* <footer class="border-top footer text-muted mt-5">
        <div class="container">
            &copy; 2026 - PMTool - <a asp-area="" asp-page="/Privacy">Privacy</a> *@
    <div class="@(User.Identity?.IsAuthenticated == true ? "pm-global-main" : "")">
        <div class="pm-global-content container-fluid pt-4 px-4 pb-3">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    @* </footer> *@
        <!-- <footer class="border-top footer text-muted mt-auto">
            <div class="container-fluid px-4 py-3">
                &copy; 2026 - OPMS - <a asp-area="" asp-page="/Privacy">Privacy</a>
            </div>
        </footer> -->
    </div>

    <div class="d-none">
        @Html.AntiForgeryToken()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.5/dist/browser/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function confirmLogout(formId) {
            if (confirm('Are you sure you want to logout?')) {
                document.getElementById(formId).submit();
            }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<style>
    .list-group-item.active {
        background-color: #CCC8C8 !important; /* light ash */
        color: #000 !important;
        border-color: #dee2e6 !important;
    }

    @* .hover-header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 24px;
        z-index: 1040;
    }

    .hover-header .navbar {
        transform: translateY(-100%);
        opacity: 0;
        border-bottom: none;
        box-shadow: none;
        transition: transform 0.25s ease, opacity 0.25s ease, left 0.2s ease, width 0.2s ease;
    }

    .hover-header:hover .navbar,
    .hover-header:focus-within .navbar {
        transform: translateY(0);
        opacity: 1;
    } *@

</style>
