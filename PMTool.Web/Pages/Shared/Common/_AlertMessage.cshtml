@* Common Alert Messages *@
@{
    string message = ViewData["Message"] as string ?? "";
    string type = ViewData["Type"] as string ?? "info"; // info, success, warning, danger
    bool dismissible = (bool?)ViewData["Dismissible"] ?? true;
    
    string alertClass = type switch
    {
        "success" => "alert-success",
        "warning" => "alert-warning",
        "danger" => "alert-danger",
        _ => "alert-info"
    };
    
    string iconClass = type switch
    {
        "success" => "bi-check-circle",
        "warning" => "bi-exclamation-circle",
        "danger" => "bi-exclamation-triangle",
        _ => "bi-info-circle"
    };
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @alertClass @(dismissible ? "alert-dismissible fade show" : "")" role="alert">
        <i class="bi @iconClass"></i>
        @Html.Raw(message)
        @if (dismissible)
        {
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        }
    </div>
}
