@* Common Action Button Group for CRUD Operations *@
@{
    string entityId = ViewData["EntityId"] as string ?? "";
    string viewPage = ViewData["ViewPage"] as string ?? "./Details";
    string editPage = ViewData["EditPage"] as string ?? "./Edit";
    bool showView = (bool?)ViewData["ShowView"] ?? true;
    bool showEdit = (bool?)ViewData["ShowEdit"] ?? true;
    bool showDelete = (bool?)ViewData["ShowDelete"] ?? false;
    bool canEdit = (bool?)ViewData["CanEdit"] ?? true;
    
    string deleteHandler = ViewData["DeleteHandler"] as string ?? "Delete";
}

<div class="btn-group w-100" role="group">
    @if (showView)
    {
        <a asp-page="@viewPage" asp-route-id="@entityId" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-eye"></i> View
        </a>
    }
    
    @if (showEdit && canEdit)
    {
        <a asp-page="@editPage" asp-route-id="@entityId" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-pencil"></i> Edit
        </a>
    }
    else if (showEdit && !canEdit)
    {
        <button class="btn btn-sm btn-outline-secondary disabled" title="You don't have permission to edit">
            <i class="bi bi-pencil"></i> Edit
        </button>
    }
    
    @if (showDelete && canEdit)
    {
        <form method="post" asp-page-handler="@deleteHandler" style="display: inline;">
            <input type="hidden" name="id" value="@entityId" />
            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this item?')">
                <i class="bi bi-trash"></i> Delete
            </button>
        </form>
    }
</div>
