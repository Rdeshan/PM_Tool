@model PMTool.Web.Pages.Projects.DetailsModel

<div class="card-header bg-light">
    <h5 class="mb-0"><i class="bi bi-graph-up"></i> Statistics</h5>
</div>
<div class="card-body">
    <div class="mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span>Project Duration</span>
            <strong>@((Model.Project.ExpectedEndDate - Model.Project.StartDate).Days) days</strong>
        </div>
        <small class="text-muted">
            @{
                var daysRemaining = (Model.Project.ExpectedEndDate - DateTime.Now).Days;
                var statusText = daysRemaining > 0 ? $"{daysRemaining} days remaining" : "Completed";
            }
            <span>@statusText</span>
        </small>
    </div>

    <div class="mb-3">
        <span class="badge bg-secondary">@Model.TeamMembers.Count() Members</span>
        <span class="badge bg-secondary">0 Backlog Items</span>
    </div>

    @if (Model.Project.IsArchived)
    {
        <div class="alert alert-warning alert-sm mb-0">
            <i class="bi bi-archive"></i> This project is archived and read-only
        </div>
    }
</div>