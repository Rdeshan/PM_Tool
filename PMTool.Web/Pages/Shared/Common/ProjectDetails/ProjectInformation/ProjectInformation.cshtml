@model PMTool.Web.Pages.Projects.DetailsModel

@{
    ViewData["Title"] = Model.Project?.Name ?? "Project Details";
    var canEditProject = User.IsInRole("Administrator") || User.IsInRole("Project Manager");
    var canDeleteProject = User.IsInRole("Administrator") || User.IsInRole("Project Manager");
}


<div class="card shadow-sm mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0"><i class="bi bi-info-circle"></i> Project Information</h5>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6">
                <label class="fw-bold text-muted">Client Name</label>
                <p class="mb-0">@Model.Project.ClientName</p>
            </div>
            <div class="col-md-6">
                <label class="fw-bold text-muted">Status</label>
                <p class="mb-0">
                    <span class="badge @GetStatusBadgeClass(Model.Project.Status)">
                        @GetStatusLabel(Model.Project.Status)
                    </span>
                </p>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label class="fw-bold text-muted">Start Date</label>
                <p class="mb-0">@Model.Project.StartDate.ToString("MMMM dd, yyyy")</p>
            </div>
            <div class="col-md-6">
                <label class="fw-bold text-muted">Expected End Date</label>
                <p class="mb-0">@Model.Project.ExpectedEndDate.ToString("MMMM dd, yyyy")</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Project.Description))
        {
            <div class="mb-3">
                <label class="fw-bold text-muted">Description</label>
                <p>@Model.Project.Description</p>
            </div>
        }

        <div class="row">
            <div class="col-md-6">
                <label class="fw-bold text-muted">Created</label>
                <p class="mb-0">@Model.Project.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</p>
            </div>
            <div class="col-md-6">
                <label class="fw-bold text-muted">Last Updated</label>
                <p class="mb-0">@Model.Project.UpdatedAt.ToString("MMMM dd, yyyy HH:mm")</p>
            </div>
        </div>
        <div class="col-md-15 text-end">
           

                @if (canEditProject)
                {
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#editProjectModal">
                        <i class="bi bi-pencil"></i> Edit
                    </button>
                }

            <div class="modal fade" id="editProjectModal" tabindex="-1">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content">

                       
                        <div class="modal-header bg-primary text-white">
    <h6 class="modal-title">Edit Project</h6>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
</div>

                        <div class="modal-body p-0">
                            <iframe src="@Url.Page("/Projects/Edit", new { id = Model.Project.Id, embedded = true })"
                                    title="Edit Project"
                                    style="width:100%; height:750px; border:0;"></iframe>
                        </div>

                    </div>
                </div>
            </div>
            
        </div>
    </div>

                
</div>

@functions {
    private string GetStatusLabel(int status)
    {
        return status switch
        {
            1 => "Active",
            2 => "On Hold",
            3 => "Completed",
            _ => "Unknown"
        };
    }

    private string GetStatusBadgeClass(int status)
    {
        return status switch
        {
            1 => "bg-success",
            2 => "bg-warning",
            3 => "bg-secondary",
            _ => "bg-secondary"
        };
    }
}