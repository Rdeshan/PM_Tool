@model PMTool.Web.Pages.Projects.DetailsModel

@{
    ViewData["Title"] = Model.Project?.Name ?? "Project Details";
    var canEditProject = User.IsInRole("Administrator") || User.IsInRole("Project Manager");
    var canDeleteProject = User.IsInRole("Administrator") || User.IsInRole("Project Manager");
}

<div class="col-md-8">
    <partial name="~/Pages/Shared/Common/ProjectDetails/ProjectInformation/ProjectInformation.cshtml" model="Model" />
                
    <div class="card mb-4">
        <div class="card-header">
            <span class="opms-card__title"><i class="bi bi-file-earmark-text me-2"></i>Project Documents</span>
        </div>
        <div class="card-body">
            <partial name="~/Pages/Shared/Common/ProjectDetails/ProjectAddDocument/ProjectDocumentList.cshtml" model="Model" />
        </div>
    </div>

    <!-- Project Backlog -->
    <!-- <div class="card shadow-sm">
        <partial name="~/Pages/Shared/Common/ProjectDetails/ProjectBacklog/ProjectBacklog.cshtml" model="Model" />

    </div> -->
</div>

<!-- Sidebar -->
<div class="col-md-4">
    <!-- Team Members -->
    <partial name="~/Pages/Shared/Common/ProjectDetails/ProjectTeamMemberCard/ProjectTeamMemberCard.cshtml" model="Model" />
               
    <!-- Project Statistics -->
    <div class="card">
        <partial name="~/Pages/Shared/Common/ProjectDetails/projectStatisticsCard/projectStatisticsCard.cshtml" model="Model" />
    </div>
    <partial name="~/Pages/Shared/Common/ProjectDetails/ProjectAddDocument/ProjectAddDocument.cshtml" model="Model" />
</div>
<div class="col-md-12 text-end">
    @if (canDeleteProject)
    {
        <form method="post" asp-page-handler="Delete" style="display: inline;">
            <input type="hidden" name="id" value="@Model.Project.Id" />
            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this project?')">
                <i class="bi bi-trash"></i> Delete Project
            </button>
        </form>
    }
</div>