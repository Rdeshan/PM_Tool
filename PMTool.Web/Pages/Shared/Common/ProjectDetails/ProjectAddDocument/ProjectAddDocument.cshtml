@model PMTool.Web.Pages.Projects.DetailsModel

<div class="card shadow-sm mt-4">
    <div class="card-header bg-light">
        <h5 class="mb-0"><i class="bi bi-file-earmark-arrow-up"></i> Add Documents</h5>
    </div>
    <div class="card-body">
        <form method="post" asp-page-handler="UploadDocument" enctype="multipart/form-data" class="mb-4">
            <input type="hidden" name="id" value="@Model.Project?.Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">

                <!-- Document Name -->
                <div class="col-md-8">
                    <label asp-for="UploadDocument.DocumentName" class="form-label">
                        Document Name
                    </label>
                    <input asp-for="UploadDocument.DocumentName"
                           class="form-control"
                           placeholder="e.g. System Requirements Spec v1.0" />
                    <span asp-validation-for="UploadDocument.DocumentName" class="text-danger"></span>
                </div>

                <!-- Document Type -->
                <div class="col-md-4">
                    <label asp-for="UploadDocument.DocumentType" class="form-label">
                        Document Type
                    </label>
                    <select asp-for="UploadDocument.DocumentType" class="form-select">
                        <option value="1">BRD — Business Requirements</option>
                        <option value="2">SRS — Software Requirements</option>
                        <option value="3">Other</option>
                    </select>
                </div>

                <!-- File + Button in same row -->
                <div class="col-md-10">
                    <label asp-for="UploadDocument.File" class="form-label">
                        Upload from device
                    </label>
                    <input asp-for="UploadDocument.File" type="file" class="form-control" />
                    <span asp-validation-for="UploadDocument.File" class="text-danger"></span>
                </div>

                <div class="col-md-2 d-grid align-self-end">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-upload"></i> Upload
                    </button>
                </div>

            </div>
        </form>

        
    </div>
</div>
