@model PMTool.Web.Pages.Projects.DetailsModel
@{
    var canEditProject = User.IsInRole("Administrator") || User.IsInRole("Project Manager");
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-people"></i> Team Members (@Model.TeamMembers.Count())</h5>
        @if (canEditProject)
        {
            <a class="btn btn-sm btn-primary" data-bs-toggle = "modal" data-bs-target ="#createUserModal">               
                <i class="bi bi-person-plus"></i>
            </a>
        }
    </div>
    <div class="modal fade" id="createUserModal" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">

                <div class="modal-header">
                    <h6 class="modal-title">Select Team</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    @if (Model.Teams.Any())
                    {
                        @foreach (var team in Model.Teams)
                        {
                            <form method="post" asp-page-handler="AddTeamMembers" class="mb-2">
                                <input type="hidden" name="id" value="@Model.Project?.Id" />
                                <input type="hidden" name="teamId" value="@team.Id" />
                                <button type="submit" class="list-group-item list-group-item-action w-100 text-start border-0 bg-transparent">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="mb-1">@team.Name</h6>
                                            <small class="text-muted">@team.MemberCount members</small>
                                        </div>
                                        @if (team.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </div>
                                </button>
                            </form>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                            <p class="mt-3 mb-0">No teams yet</p>
                        </div>
                    }
                  

                  
                </div>

            </div>
        </div>
    </div>
    <div class="card-body">
        @if (Model.TeamMembers.Any())
        {
            <div class="list-group list-group-flush">
                @foreach (var member in Model.TeamMembers)
                {
                    <div class="list-group-item px-0">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="mb-0">@member.FirstName @member.LastName</h6>
                                <small class="text-muted">@member.Email</small>
                                @if (Model.MemberTeams.TryGetValue(member.Id, out var memberTeams) && memberTeams.Any())
                                {
                                    <div class="mt-1 d-flex flex-wrap gap-1">
                                        @foreach (var memberTeam in memberTeams)
                                        {
                                            <span class="badge" style="background-color: @memberTeam.TeamColorCode; color: #fff;">@memberTeam.TeamName</span>
                                        }
                                    </div>
                                }
                            </div>
                            @if (canEditProject)
                            {
                                <form method="post" asp-page-handler="RemoveTeamMember" style="display:inline;">
                                    <input type="hidden" name="id" value="@Model.Project?.Id" />
                                    <input type="hidden" name="userId" value="@member.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove" onclick="return confirm('Are you sure want to remove this user from this project?')">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted text-center py-4">
                <i class="bi bi-people-fill" style="font-size: 1.5rem;"></i><br />
                No team members yet
            </p>
        }
    </div>
</div>