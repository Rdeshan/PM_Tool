@page
@using PMTool.Domain.Enums
@using PMTool.Domain.Entities
@model PMTool.Web.Pages.Tasks.IndexModel
@{
    ViewData["Title"] = Model.IsAllTasksView ? "All Tasks" : "My Tasks";

    (string label, string cls, string filter) DtStatus(DailyTaskStatus s) => s switch
    {
        DailyTaskStatus.Accepted => ("Approved", "dt-accepted", "approved"),
        DailyTaskStatus.NeedsClarification => ("Needs Clarification", "dt-clarify", "clarify"),
        _ => ("Pending", "dt-pending", "pending")
    };

    string SubmittedBy(DailyTask t) => t.User != null
        ? (!string.IsNullOrWhiteSpace(t.User.DisplayName) ? t.User.DisplayName! : $"{t.User.FirstName} {t.User.LastName}".Trim())
        : "Unknown User";

    var defaultFilter = Model.IsAllTasksView ? "all" : "approved";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

<style>
    :root {
        --pm-green:       #0D6EFD;
        --pm-green-mid:   #0056CA;
        --pm-green-pale:  #E7F1FF;
        --pm-bg:          #f4f6f5;
        --pm-card:        #ffffff;
        --pm-text:        #1b2b23;
        --pm-muted:       #6c757d;
    }
    body { background: var(--pm-bg); }

    .pm-topbar { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.75rem; }
    .pm-topbar h4 { font-weight:700; color:var(--pm-text); margin:0; }
    .pm-topbar .topbar-right { display:flex; gap:.75rem; align-items:center; }

    .section-card {
        background: var(--pm-card);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        border: none;
    }
    .section-card .section-title { font-size:1rem; font-weight:600; color:var(--pm-text); margin-bottom:1rem; }

    .filter-pills { display:flex; gap:.5rem; flex-wrap:wrap; margin-bottom:1.25rem; }
    .filter-pill {
        padding:4px 14px; border-radius:20px; font-size:.8rem; font-weight:500;
        border:1.5px solid #dee2e6; background:#fff; color:var(--pm-muted); cursor:pointer;
        transition:background .15s, color .15s, border-color .15s;
    }
    .filter-pill.active, .filter-pill:hover {
        background:var(--pm-green); color:#fff; border-color:var(--pm-green);
    }

    /* Modern date range filter */
    .date-filter-wrap { margin-bottom:1.25rem; }
    .date-filter-input { position:relative; min-width:240px; }
    .date-filter-input i.bi-calendar3 {
        position:absolute; left:14px; top:50%; transform:translateY(-50%);
        color:var(--pm-muted); font-size:.9rem; pointer-events:none;
    }
    .date-filter-input input {
        width:100%; padding:7px 36px 7px 38px; border-radius:20px;
        border:1.5px solid #dee2e6; font-size:.8rem; background:#fff; color:var(--pm-text);
        transition:border-color .15s, box-shadow .15s;
    }
    .date-filter-input input::placeholder { color:var(--pm-muted); }
    .date-filter-input input:focus {
        outline:none; border-color:var(--pm-green); box-shadow:0 0 0 3px var(--pm-green-pale);
    }
    .date-filter-input .btn-clear-date {
        position:absolute; right:6px; top:50%; transform:translateY(-50%);
        border:none; background:transparent; color:var(--pm-muted); padding:5px;
        line-height:1; cursor:pointer; border-radius:50%; font-size:.7rem; display:none;
    }
    .date-filter-input .btn-clear-date:hover { background:#f1f3f5; color:var(--pm-text); }
    .date-filter-input.has-value .btn-clear-date { display:inline-flex; }

    /* Flatpickr theme tweaks to match palette */
    .flatpickr-day.selected, .flatpickr-day.startRange, .flatpickr-day.endRange,
    .flatpickr-day.selected.inRange, .flatpickr-day.startRange.inRange, .flatpickr-day.endRange.inRange,
    .flatpickr-day.selected:hover, .flatpickr-day.startRange:hover, .flatpickr-day.endRange:hover {
        background:var(--pm-green); border-color:var(--pm-green);
    }
    .flatpickr-day.inRange {
        background:var(--pm-green-pale); border-color:var(--pm-green-pale);
        box-shadow:-5px 0 0 var(--pm-green-pale), 5px 0 0 var(--pm-green-pale);
    }
    .flatpickr-day.today { border-color:var(--pm-green); }
    .flatpickr-months .flatpickr-month,
    .flatpickr-current-month .flatpickr-monthDropdown-months,
    span.flatpickr-weekday {
        background:var(--pm-green); fill:#fff; color:#fff;
    }
    .flatpickr-current-month .flatpickr-monthDropdown-months option { background:#fff; color:#000; }
    .flatpickr-months .flatpickr-prev-month svg, .flatpickr-months .flatpickr-next-month svg { fill:#fff; }
    .flatpickr-current-month input.cur-year { color:#fff; }

    .pill-status { display:inline-block; padding:2px 10px; border-radius:20px; font-size:.72rem; font-weight:600; flex-shrink:0; }
    .dt-pending  { background:#fff3cd; color:#856404; }
    .dt-accepted { background:#dcfce7; color:#166534; }
    .dt-clarify  { background:#dbeafe; color:#1d4ed8; }

    .daily-task-item {
        border:1px solid #f0f0f0; border-radius:12px; padding:1rem 1.1rem; margin-bottom:.75rem;
        transition: box-shadow .15s;
    }
    .daily-task-item:last-child { margin-bottom:0; }
    .daily-task-item:hover { box-shadow: 0 2px 10px rgba(0,0,0,.05); }
    .daily-task-item .dt-name { font-weight:600; font-size:.95rem; color:var(--pm-text); }
    .daily-task-item .dt-desc { font-size:.85rem; color:var(--pm-muted); margin-top:.25rem; }
    .daily-task-item .dt-meta { font-size:.75rem; color:var(--pm-muted); margin-top:.4rem; }
    .daily-task-item .dt-comment {
        font-size:.8rem; color:var(--pm-text); background:#f8f9fa; border-radius:8px;
        padding:.5rem .75rem; margin-top:.6rem;
    }

    .empty-state { text-align:center; padding:2.5rem 1rem; color:var(--pm-muted); font-size:.88rem; }
    .empty-state i { font-size:2rem; display:block; margin-bottom:.5rem; opacity:.4; }
</style>

<div class="pm-main">
    <div class="pm-topbar">
        <div>
            <h4>@(Model.IsAllTasksView ? "All Tasks" : "My Tasks")</h4>
            <p class="text-muted mb-0" style="font-size:.85rem;">
                @(Model.IsAllTasksView
                    ? "Daily tasks submitted by all team members and their review status"
                    : "Daily tasks you've submitted and their review status")
            </p>
        </div>
        @if (!Model.IsAllTasksView)
        {
            <div class="topbar-right">
                <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="offcanvas" data-bs-target="#taskOffcanvas">
                    <i class="bi bi-plus-lg me-1"></i> Add Task
                </button>
            </div>
        }
    </div>

    @if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
    {
        <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1090;">
            @if (TempData["SuccessMessage"] != null)
            {
                <div id="dashToastSuccess" class="toast align-items-center text-bg-success border-0 show" role="alert">
                    <div class="d-flex">
                        <div class="toast-body"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]</div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div id="dashToastError" class="toast align-items-center text-bg-danger border-0 show" role="alert">
                    <div class="d-flex">
                        <div class="toast-body"><i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]</div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>
                </div>
            }
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                ['dashToastSuccess', 'dashToastError'].forEach(function (id) {
                    var el = document.getElementById(id);
                    if (el) setTimeout(function () { bootstrap.Toast.getOrCreateInstance(el).hide(); }, 3000);
                });
            });
        </script>
    }

    <div class="section-card">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="section-title mb-0">Daily Tasks</div>
            <span class="text-muted" style="font-size:.8rem;">@Model.MyTasks.Count total</span>
        </div>

        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
            <div class="filter-pills mb-0" id="taskFilterPills">
                <span class="filter-pill @(defaultFilter == "all" ? "active" : "")" data-filter="all">All</span>
                <span class="filter-pill @(defaultFilter == "approved" ? "active" : "")" data-filter="approved">Approved</span>
                <span class="filter-pill" data-filter="pending">Pending</span>
                <span class="filter-pill" data-filter="clarify">Needs Clarification</span>
            </div>

            <div class="date-filter-wrap mb-0">
                <div class="date-filter-input" id="dateFilterWrap">
                    <i class="bi bi-calendar3"></i>
                    <input type="text" id="dateRangeFilter" class="form-control" placeholder="Filter by date range" autocomplete="off" />
                    <button type="button" id="clearDateFilter" class="btn-clear-date" title="Clear date filter"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>
        </div>

        @if (!Model.MyTasks.Any())
        {
            <div class="empty-state">
                <i class="bi bi-list-task"></i>
                @(Model.IsAllTasksView ? "No daily tasks have been submitted yet." : "You haven't submitted any daily tasks yet.")
            </div>
        }
        else
        {
            <div id="taskListContainer">
                @foreach (var task in Model.MyTasks)
                {
                    var (label, cls, filter) = DtStatus(task.Status);
                    <div class="daily-task-item" data-filter="@filter" data-date="@task.CreatedAt.ToString("yyyy-MM-dd")">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div class="overflow-hidden">
                                <div class="dt-name">@task.TaskName</div>
                                @if (!string.IsNullOrWhiteSpace(task.Description))
                                {
                                    <div class="dt-desc">@task.Description</div>
                                }
                                @if (task.ProductBacklog != null)
                                {
                                    <div class="dt-meta"><i class="bi bi-link-45deg me-1"></i>Linked to: @task.ProductBacklog.Title</div>
                                }
                                @if (Model.IsAllTasksView)
                                {
                                    <div class="dt-meta"><i class="bi bi-person me-1"></i>@SubmittedBy(task)</div>
                                }
                                <div class="dt-meta">
                                    Submitted @task.CreatedAt.ToString("MMM d, yyyy h:mm tt")
                                    @if (task.ReviewedAt.HasValue)
                                    {
                                        <span> &middot; Reviewed @task.ReviewedAt.Value.ToString("MMM d, yyyy h:mm tt")</span>
                                    }
                                </div>
                            </div>
                            <div class="d-flex flex-column align-items-end gap-2 flex-shrink-0">
                                <span class="pill-status @cls">@label</span>
                                @if (!Model.IsAllTasksView && (task.Status == DailyTaskStatus.Pending || task.Status == DailyTaskStatus.NeedsClarification))
                                {
                                    <button type="button" class="btn btn-sm btn-outline-primary py-0 px-2"
                                            data-bs-toggle="modal" data-bs-target="#editTaskModal"
                                            data-task-id="@task.Id"
                                            data-task-name="@task.TaskName"
                                            data-description="@task.Description"
                                            data-backlog-id="@task.ProductBacklogId"
                                            style="font-size:.75rem;">
                                        <i class="bi bi-pencil-square me-1"></i>Edit
                                    </button>
                                }
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(task.PMComment))
                        {
                            <div class="dt-comment"><i class="bi bi-chat-left-text me-1"></i>@task.PMComment</div>
                        }
                    </div>
                }
            </div>
            <div id="taskNoResults" class="empty-state d-none">
                <i class="bi bi-inbox"></i>
                No tasks match the selected filters.
            </div>
        }
    </div>

    @if (!Model.IsAllTasksView)
    {
        <div class="offcanvas offcanvas-end shadow" tabindex="-1" id="taskOffcanvas" aria-labelledby="taskOffcanvasLabel" style="width: 450px;">
            <div class="offcanvas-header border-bottom">
                <h5 class="offcanvas-title fw-bold" id="taskOffcanvasLabel">Add Daily Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body">
                <form method="post" asp-page="/Tasks/Index" asp-page-handler="AddDailyTask">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold text-uppercase">Task Name</label>
                        <input type="text" class="form-control" name="taskName" placeholder="Enter task name" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold text-uppercase">Description</label>
                        <textarea class="form-control" name="description" rows="4" placeholder="Enter task details..."></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold text-uppercase">Link Backlog Item</label>
                        <select class="form-select" name="backlogItemId">
                            <option value="">-- Select Backlog Item --</option>
                            @foreach (var item in Model.BacklogItems)
                            {
                                <option value="@item.Id">@item.Title</option>
                            }
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-semibold">Save Task</button>
                </form>
            </div>
        </div>

        <div class="modal fade" id="editTaskModal" tabindex="-1" aria-labelledby="editTaskModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold" id="editTaskModalLabel">Edit Task</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form method="post" asp-page="/Tasks/Index" asp-page-handler="EditDailyTask">
                        <div class="modal-body">
                            <input type="hidden" name="taskId" id="editTaskId" />
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold text-uppercase">Task Name</label>
                                <input type="text" class="form-control" name="taskName" id="editTaskName" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold text-uppercase">Description</label>
                                <textarea class="form-control" name="description" id="editTaskDescription" rows="4"></textarea>
                            </div>
                            <div class="mb-0">
                                <label class="form-label text-muted small fw-bold text-uppercase">Link Backlog Item</label>
                                <select class="form-select" name="backlogItemId" id="editTaskBacklogId">
                                    <option value="">-- Select Backlog Item --</option>
                                    @foreach (var item in Model.BacklogItems)
                                    {
                                        <option value="@item.Id">@item.Title</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-link text-muted" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary fw-semibold">Save &amp; Resubmit</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
    let currentStatusFilter = '@defaultFilter';
    let currentDateRange = null;

    document.querySelectorAll('#taskFilterPills .filter-pill').forEach(pill => {
        pill.addEventListener('click', function () {
            document.querySelectorAll('#taskFilterPills .filter-pill').forEach(p => p.classList.remove('active'));
            this.classList.add('active');
            currentStatusFilter = this.dataset.filter;
            applyFilters();
        });
    });

    function toIsoDate(d) {
        const y = d.getFullYear();
        const m = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        return `${y}-${m}-${day}`;
    }

    const dateFilterWrap = document.getElementById('dateFilterWrap');
    const dateInput = document.getElementById('dateRangeFilter');

    const datePicker = flatpickr(dateInput, {
        mode: 'range',
        dateFormat: 'M j, Y',
        onChange: function (selectedDates) {
            if (selectedDates.length === 2) {
                currentDateRange = { from: toIsoDate(selectedDates[0]), to: toIsoDate(selectedDates[1]) };
                dateFilterWrap.classList.add('has-value');
            } else {
                currentDateRange = null;
                dateFilterWrap.classList.remove('has-value');
            }
            applyFilters();
        }
    });

    document.getElementById('clearDateFilter').addEventListener('click', function () {
        datePicker.clear();
        currentDateRange = null;
        dateFilterWrap.classList.remove('has-value');
        applyFilters();
    });

    function applyFilters() {
        const items = document.querySelectorAll('#taskListContainer .daily-task-item');
        let visibleCount = 0;
        items.forEach(item => {
            const statusMatch = currentStatusFilter === 'all' || item.dataset.filter === currentStatusFilter;
            let dateMatch = true;
            if (currentDateRange) {
                const itemDate = item.dataset.date;
                dateMatch = itemDate >= currentDateRange.from && itemDate <= currentDateRange.to;
            }
            const show = statusMatch && dateMatch;
            item.style.display = show ? '' : 'none';
            if (show) visibleCount++;
        });
        const noResults = document.getElementById('taskNoResults');
        if (noResults) noResults.classList.toggle('d-none', visibleCount !== 0);
    }

    document.addEventListener('DOMContentLoaded', function () {
        applyFilters();
    });

    var editTaskModal = document.getElementById('editTaskModal');
    if (editTaskModal) {
        editTaskModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('editTaskId').value = button.getAttribute('data-task-id');
            document.getElementById('editTaskName').value = button.getAttribute('data-task-name');
            document.getElementById('editTaskDescription').value = button.getAttribute('data-description');
            document.getElementById('editTaskBacklogId').value = button.getAttribute('data-backlog-id') || '';
        });
    }

    @if (TempData["OpenDailyTaskPanel"] != null)
    {
        <text>
        document.addEventListener('DOMContentLoaded', function () {
            bootstrap.Offcanvas.getOrCreateInstance(document.getElementById('taskOffcanvas')).show();
        });
        </text>
    }
</script>
