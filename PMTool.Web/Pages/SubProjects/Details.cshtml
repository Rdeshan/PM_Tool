@page "{id:guid}/{productId:guid}"
@model PMTool.Web.Pages.SubProjects.DetailsModel
@{
    ViewData["Title"] = Model.SubProject?.Name ?? "Sub-Project Details";
}

@if (Model.SubProject == null)
{
    <div class="container mt-4">
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle"></i> Sub-project not found.
        </div>
    </div>
}
else
{
    <div class="container-fluid mt-4">
        <!-- Header Section -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h1>@Model.SubProject.Name</h1>
                        <small class="text-muted">
                            <i class="bi bi-person-circle"></i> Owner: @Model.SubProject.ModuleOwnerName
                        </small>
                    </div>
                    <div>
                        <span class="badge @Model.GetStatusBadgeClass(Model.SubProject.Status) fs-6">
                            @Model.GetStatusName(Model.SubProject.Status)
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Description and Meta Info -->
        <div class="row mb-4">
            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Overview</h5>
                        <p class="card-text">@Model.SubProject.Description</p>

                        <!-- Progress Section -->
                        <div class="mt-4">
                            <h6 class="mb-2">Progress</h6>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>@Model.SubProject.CompletedTicketCount / @Model.SubProject.TicketCount tickets completed</span>
                                <strong>@Model.SubProject.Progress%</strong>
                            </div>
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar @Model.GetProgressBarClass(Model.SubProject.Progress)" 
                                     role="progressbar" 
                                     style="width: @Model.SubProject.Progress%"
                                     aria-valuenow="@Model.SubProject.Progress" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100">
                                </div>
                            </div>
                        </div>

                        <!-- Timeline -->
                        <div class="mt-4 pt-4 border-top">
                            <h6 class="mb-3">Timeline</h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <small class="text-muted d-block">Start Date</small>
                                        @if (Model.SubProject.StartDate.HasValue)
                                        {
                                            <strong>@Model.SubProject.StartDate.Value.ToString("MMMM dd, yyyy")</strong>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not set</span>
                                        }
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <small class="text-muted d-block">Due Date</small>
                                        @if (Model.SubProject.DueDate.HasValue)
                                        {
                                            <strong>@Model.SubProject.DueDate.Value.ToString("MMMM dd, yyyy")</strong>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not set</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Teams Section -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Assigned Teams</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.SubProject.Teams.Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Team Name</th>
                                            <th>Role</th>
                                            <th>Assigned Date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var team in Model.SubProject.Teams)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@team.TeamName</strong>
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(team.Role))
                                                    {
                                                        <span class="badge bg-light text-dark">@team.Role</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    <small class="text-muted">@team.AssignedDate.ToString("MMM dd, yyyy")</small>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No teams assigned to this sub-project.</p>
                        }
                    </div>
                </div>

                <!-- Dependencies Section -->
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0">Dependencies</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.SubProject.Dependencies.Count > 0)
                        {
                            <div class="list-group">
                                @foreach (var dep in Model.SubProject.Dependencies)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <strong>@dep.DependsOnSubProjectName</strong>
                                            @if (!string.IsNullOrEmpty(dep.Notes))
                                            {
                                                <br />
                                                <small class="text-muted">@dep.Notes</small>
                                            }
                                        </div>
                                        @if (Model.CanEdit)
                                        {
                                            <form method="post" asp-page-handler="RemoveDependency" class="ms-2">
                                                <input type="hidden" name="dependencyId" value="@dep.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove dependency">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No dependencies for this sub-project.</p>
                        }

                        @if (Model.CanEdit)
                        {
                            <hr class="my-3" />
                            <h6>Add Dependency</h6>
                            <form method="post" asp-page-handler="AddDependency" asp-route-id="@Model.SubProject.Id" asp-route-productId="@Model.ProductId" class="mt-3">
                                <div class="row">
                                    <div class="col-md-8 mb-3">
                                        <label for="dependsOnSubProjectId" class="form-label">Depends On</label>
                                        <select id="dependsOnSubProjectId" name="dependsOnSubProjectId" class="form-select" required>
                                            <option value="">-- Select Sub-Project --</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4 d-flex align-items-end">
                                        <button type="submit" class="btn btn-primary w-100">
                                            <i class="bi bi-plus"></i> Add
                                        </button>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label for="notes" class="form-label">Notes (Optional)</label>
                                    <textarea id="notes" name="notes" class="form-control" rows="2" placeholder="Why this dependency exists..."></textarea>
                                </div>
                            </form>
                        }
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Quick Actions -->
                @if (Model.CanEdit)
                {
                    <div class="card shadow-sm mb-4">
                        <div class="card-header">
                            <h6 class="mb-0">Actions</h6>
                        </div>
                        <div class="card-body d-flex flex-column gap-2">
                            <a href="/SubProjects/Edit/@Model.SubProject.Id" class="btn btn-warning text-dark">
                                <i class="bi bi-pencil-square"></i> Edit Sub-Project
                            </a>
                            <button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                <i class="bi bi-trash"></i> Delete Sub-Project
                            </button>
                        </div>
                    </div>
                }

                <!-- Information Card -->
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h6 class="mb-0">Information</h6>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-6">Created</dt>
                            <dd class="col-sm-6">
                                <small>@Model.SubProject.CreatedAt.ToString("MMM dd, yyyy")</small>
                            </dd>
                            <dt class="col-sm-6">Last Updated</dt>
                            <dd class="col-sm-6">
                                <small>@Model.SubProject.UpdatedAt.ToString("MMM dd, yyyy")</small>
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <!-- Back Button -->
         <div class="row mt-4 mb-4">
             <div class="col-12">
                 <a href="/SubProjects/@Model.ProductId" class="btn btn-secondary">
                     <i class="bi bi-arrow-left"></i> Back to Sub-Projects
                 </a>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Delete Sub-Project</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this sub-project?</p>
                    <p class="mb-0"><strong>@Model.SubProject.Name</strong></p>
                    <p class="text-danger small mt-2">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@Model.SubProject.Id" asp-route-productId="@Model.ProductId" class="d-inline">
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
