@page "{productId:guid}"
@model PMTool.Web.Pages.SubProjects.IndexModel



<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h1>Sub-Projects</h1>
                @if (User.IsInRole("Administrator") || User.IsInRole("Project Manager"))
                {
                    <a href="/SubProjects/Create/@Model.ProductId" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> New Sub-Project
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Status Filter Tabs -->
    <div class="row mb-4">
        <div class="col-12">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <a class="nav-link @(Model.StatusFilter == "All" ? "active" : "")" 
                       href="/SubProjects/@Model.ProductId?status=All">
                        All <span class="badge bg-primary">@Model.SubProjects.Count</span>
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link @(Model.StatusFilter == "Not Started" ? "active" : "")" 
                       href="/SubProjects/@Model.ProductId?status=Not Started">
                        Not Started <span class="badge bg-secondary">@Model.SubProjects.Count(sp => sp.Status == 1)</span>
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link @(Model.StatusFilter == "In Progress" ? "active" : "")" 
                       href="/SubProjects/@Model.ProductId?status=In Progress">
                        In Progress <span class="badge bg-info">@Model.SubProjects.Count(sp => sp.Status == 2)</span>
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link @(Model.StatusFilter == "In Review" ? "active" : "")" 
                       href="/SubProjects/@Model.ProductId?status=In Review">
                        In Review <span class="badge bg-warning">@Model.SubProjects.Count(sp => sp.Status == 3)</span>
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link @(Model.StatusFilter == "Completed" ? "active" : "")" 
                       href="/SubProjects/@Model.ProductId?status=Completed">
                        Completed <span class="badge bg-success">@Model.SubProjects.Count(sp => sp.Status == 4)</span>
                    </a>
                </li>
            </ul>
        </div>
    </div>

    @if (Model.SubProjects.Count == 0)
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle"></i> No sub-projects found.
                    @if (User.IsInRole("Administrator") || User.IsInRole("Project Manager"))
                    {
                        <a href="/SubProjects/Create/@Model.ProductId" class="alert-link">Create one now</a>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var subProject in Model.SubProjects)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header d-flex justify-content-between align-items-start">
                            <div>
                                <h5 class="card-title mb-1">@subProject.Name</h5>
                                <small class="text-muted">Owner: @subProject.ModuleOwnerName</small>
                            </div>
                            <span class="badge @Model.GetStatusBadgeClass(subProject.Status)">
                                @(subProject.Status switch
                                {
                                    1 => "Not Started",
                                    2 => "In Progress",
                                    3 => "In Review",
                                    4 => "Completed",
                                    _ => "Unknown"
                                })
                            </span>
                        </div>

                        <div class="card-body">
                            <p class="card-text text-muted small">@subProject.Description</p>

                            <!-- Progress Bar -->
                            <div class="mb-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <small class="text-muted">Progress</small>
                                    <small class="badge bg-light text-dark">@subProject.Progress%</small>
                                </div>
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar @Model.GetProgressBarClass(subProject.Progress)" 
                                         role="progressbar" 
                                         style="width: @subProject.Progress%"
                                         aria-valuenow="@subProject.Progress" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100">
                                    </div>
                                </div>
                            </div>

                            <!-- Tickets Info -->
                            <div class="row text-center mb-3 mt-3">
                                <div class="col-6">
                                    <small class="text-muted d-block">Tickets</small>
                                    <strong class="text-primary">@subProject.TicketCount</strong>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">Completed</small>
                                    <strong class="text-success">@subProject.CompletedTicketCount</strong>
                                </div>
                            </div>

                            <!-- Timeline -->
                            @if (subProject.StartDate.HasValue || subProject.DueDate.HasValue)
                            {
                                <div class="mb-2">
                                    <small class="text-muted d-block">Timeline</small>
                                    @if (subProject.StartDate.HasValue)
                                    {
                                        <small class="d-block">
                                            <i class="bi bi-calendar-event"></i> Start: @subProject.StartDate.Value.ToString("MMM dd, yyyy")
                                        </small>
                                    }
                                    @if (subProject.DueDate.HasValue)
                                    {
                                        <small class="d-block">
                                            <i class="bi bi-calendar-check"></i> Due: @subProject.DueDate.Value.ToString("MMM dd, yyyy")
                                        </small>
                                    }
                                </div>
                            }

                            <!-- Teams -->
                            @if (subProject.Teams.Count > 0)
                            {
                                <div class="mb-2">
                                    <small class="text-muted d-block mb-1">Teams</small>
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var team in subProject.Teams.Take(3))
                                        {
                                            <span class="badge bg-light text-dark">
                                                @team.TeamName
                                                @if (!string.IsNullOrEmpty(team.Role))
                                                {
                                                    <span class="text-muted ms-1">(@team.Role)</span>
                                                }
                                            </span>
                                        }
                                        @if (subProject.Teams.Count > 3)
                                        {
                                            <span class="badge bg-light text-dark">+@(subProject.Teams.Count - 3) more</span>
                                        }
                                    </div>
                                </div>
                            }

                            <!-- Dependencies -->
                            @if (subProject.Dependencies.Count > 0)
                            {
                                <div class="alert alert-warning alert-sm py-1 px-2 mb-0">
                                    <small class="text-dark">
                                        <i class="bi bi-link-45deg"></i> @subProject.Dependencies.Count dependency(ies)
                                    </small>
                                </div>
                            }
                        </div>

                        <div class="card-footer bg-white d-flex gap-2">
                            <a href="/SubProjects/@subProject.Id/@Model.ProductId" 
                               class="btn btn-sm btn-outline-primary flex-grow-1">
                                <i class="bi bi-eye"></i> View
                            </a>
                            @if (User.IsInRole("Administrator") || User.IsInRole("Project Manager"))
                            {
                                 <button type="button"
                                    class="btn btn-sm btn-outline-secondary flex-grow-1"
                                    onclick="openEditSubProjectModal('@subProject.Id', '@Html.Raw(subProject.Name)', '@Html.Raw(subProject.Description)', '@subProject.Status', '@subProject.ModuleOwnerId', '@(subProject.StartDate?.ToString("yyyy-MM-dd") ?? "")', '@(subProject.DueDate?.ToString("yyyy-MM-dd") ?? "")', '@string.Join(",", subProject.Teams.Select(t => t.TeamId))')">
                                    <i class="bi bi-pencil"></i> Edit
                                 </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary flex-grow-1 disabled" title="Only Administrators and Project Managers can edit">
                                    <i class="bi bi-pencil"></i> Edit
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (User.IsInRole("Administrator") || User.IsInRole("Project Manager"))
{
    <div class="modal fade" id="editSubProjectModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title"><i class="bi bi-pencil-square"></i> Edit Sub-Project</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="UpdateSubProject" asp-route-productId="@Model.ProductId">
                    <input type="hidden" name="subProjectId" id="editSubProjectId" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Sub-Project Name <span class="text-danger">*</span></label>
                            <input type="text" name="request.Name" id="editSubProjectName" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="request.Description" id="editSubProjectDescription" class="form-control" rows="4"></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Status <span class="text-danger">*</span></label>
                                    <select name="request.Status" id="editSubProjectStatus" class="form-select" required>
                                        <option value="1">Not Started</option>
                                        <option value="2">In Progress</option>
                                        <option value="3">In Review</option>
                                        <option value="4">Completed</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Module Owner <span class="text-danger">*</span></label>
                                    <select name="request.ModuleOwnerId" id="editSubProjectOwner" class="form-select" required>
                                        <option value="">-- Select Module Owner --</option>
                                        @foreach (var owner in Model.ModuleOwners)
                                        {
                                            <option value="@owner.Value">@owner.Text</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Start Date</label>
                                    <input type="date" name="request.StartDate" id="editSubProjectStartDate" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Due Date</label>
                                    <input type="date" name="request.DueDate" id="editSubProjectDueDate" class="form-control" />
                                </div>
                            </div>
                        </div>

                        <div class="mb-0">
                            <label class="form-label">Teams</label>
                            <div class="row row-cols-2">
                                @foreach (var team in Model.Teams)
                                {
                                    <div class="col mb-2">
                                        <div class="form-check">
                                            <input class="form-check-input edit-team-checkbox" type="checkbox" name="request.TeamIds" value="@team.Value" id="edit_team_@team.Value">
                                            <label class="form-check-label small" for="edit_team_@team.Value">
                                                @team.Text
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-warning text-dark">Update Sub-Project</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Auto-update progress bars
        document.addEventListener('DOMContentLoaded', function () {
            // Could add real-time progress updates here
        });

        function openEditSubProjectModal(id, name, description, status, ownerId, startDate, dueDate, teamIds) {
            document.getElementById('editSubProjectId').value = id;
            document.getElementById('editSubProjectName').value = name;
            document.getElementById('editSubProjectDescription').value = description;
            document.getElementById('editSubProjectStatus').value = status;
            document.getElementById('editSubProjectOwner').value = ownerId;
            document.getElementById('editSubProjectStartDate').value = startDate;
            document.getElementById('editSubProjectDueDate').value = dueDate;

            const selectedTeamIds = teamIds ? teamIds.split(',') : [];
            document.querySelectorAll('.edit-team-checkbox').forEach(cb => {
                cb.checked = selectedTeamIds.includes(cb.value);
            });

            const modal = new bootstrap.Modal(document.getElementById('editSubProjectModal'));
            modal.show();
        }
    </script>
}
