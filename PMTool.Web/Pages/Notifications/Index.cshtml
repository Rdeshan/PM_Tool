@page
@model PMTool.Web.Pages.Notifications.IndexModel
@{
    ViewData["Title"] = "Notifications";
}

<style>
    .notif-wrap { max-width: 680px; margin: 0 auto; padding: var(--space-6); }
    .notif-item {
        display: flex; gap: var(--space-3); align-items: flex-start;
        padding: var(--space-3) 0; border-bottom: 1px solid var(--slate-100);
    }
    .notif-item:last-child { border-bottom: none; }
    .notif-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: var(--primary-500); flex-shrink: 0; margin-top: 6px;
    }
    .notif-msg { font-size: var(--fs-sm); color: var(--text-body); line-height: 1.5; }
    .notif-time { font-size: var(--fs-xs); color: var(--text-muted); margin-top: 2px; }
    .btn-dismiss {
        margin-left: auto; background: transparent; border: none;
        color: var(--text-faint); padding: 2px 4px; border-radius: var(--radius-sm);
        cursor: pointer; flex-shrink: 0; transition: color .12s, background .12s;
    }
    .btn-dismiss:hover { color: var(--danger-text); background: var(--danger-bg); }
</style>

<div class="notif-wrap">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 style="font-family:var(--font-heading);font-size:var(--fs-display);font-weight:var(--fw-bold);color:var(--text-heading);margin:0;">Notifications</h1>
            <p style="font-size:var(--fs-sm);color:var(--text-muted);margin:var(--space-1) 0 0;">Your recent alerts and updates</p>
        </div>
        <a asp-page="/Admin/Users/Dashboard" class="btn-opms btn-opms--secondary btn-opms--sm">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
    </div>

    <div class="opms-card opms-card--pad">
        <div id="notif-list">
            <div class="opms-empty">
                <div class="spinner-border spinner-border-sm" role="status" style="color:var(--primary-500);"></div>
                <span style="display:block;margin-top:var(--space-3);">Loading notifications…</span>
            </div>
        </div>
    </div>
</div>

<script>
    async function loadNotifications() {
        const res = await fetch('?handler=List', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        const list = await res.json();
        const container = document.getElementById('notif-list');

        if (!list.length) {
            container.innerHTML = `
                <div class="opms-empty">
                    <i class="bi bi-bell-slash"></i>
                    You have no notifications.
                </div>`;
            return;
        }

        container.innerHTML = list.map(n => `
            <div class="notif-item" id="notif-${n.id}">
                <div class="notif-dot"></div>
                <div style="flex:1;">
                    <div class="notif-msg">${escHtml(n.message)}</div>
                    <div class="notif-time">${timeAgo(n.createdAt)}</div>
                </div>
                <button class="btn-dismiss" title="Dismiss" onclick="dismiss('${n.id}')">
                    <i class="bi bi-x-lg" style="font-size:.75rem;"></i>
                </button>
            </div>`).join('');
    }

    async function dismiss(id) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        const res = await fetch(`?handler=Delete&id=${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': token, 'X-Requested-With': 'XMLHttpRequest' }
        });
        const data = await res.json();
        if (data.success) {
            document.getElementById(`notif-${id}`)?.remove();
            if (!document.querySelector('.notif-item')) {
                document.getElementById('notif-list').innerHTML = `
                    <div class="opms-empty">
                        <i class="bi bi-bell-slash"></i>
                        You have no notifications.
                    </div>`;
            }
        }
    }

    function timeAgo(dateStr) {
        const diff = (Date.now() - new Date(dateStr).getTime()) / 1000;
        if (diff < 60) return 'just now';
        if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
        if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
        return `${Math.floor(diff / 86400)}d ago`;
    }

    function escHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    loadNotifications();
</script>
<form id="csrf-form" method="post">@Html.AntiForgeryToken()</form>
