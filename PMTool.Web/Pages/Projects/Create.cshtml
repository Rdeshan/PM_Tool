@page
@model PMTool.Web.Pages.Projects.CreateModel
@{
    ViewData["Title"] = "Create Project";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Create New Project</h4>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-circle"></i> @Model.ErrorMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle"></i> @Model.SuccessMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div class="alert alert-info alert-sm mb-3">
                        <i class="bi bi-shield-lock"></i>
                        <strong>Project Creation</strong> is restricted to Administrators and Project Managers only.
                    </div>

                    <form method="post">
                        <!-- Project Name -->
                        <div class="mb-3">
                            <label asp-for="Input.Name" class="form-label">Project Name <span class="text-danger">*</span></label>
                            <input asp-for="Input.Name" class="form-control form-control-lg" placeholder="e.g., User Management System" />
                            <span asp-validation-for="Input.Name" class="text-danger small"></span>
                        </div>

                        <!-- Project Code -->
                        <div class="mb-3">
                            <label asp-for="Input.ProjectCode" class="form-label">Project Code <span class="text-danger">*</span></label>
                            <input asp-for="Input.ProjectCode" class="form-control form-control-lg" placeholder="e.g., UMS (3-20 uppercase letters/numbers)" />
                            <span asp-validation-for="Input.ProjectCode" class="text-danger small"></span>
                            <small class="form-text text-muted">Used as prefix for ticket IDs (e.g., UMS-001)</small>
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label asp-for="Input.Description" class="form-label">Description</label>
                            <textarea asp-for="Input.Description" class="form-control" rows="3" placeholder="Brief description of the project"></textarea>
                            <span asp-validation-for="Input.Description" class="text-danger small"></span>
                        </div>

                        <!-- Client Name -->
                        <div class="mb-3">
                            <label asp-for="Input.ClientName" class="form-label">Client Name <span class="text-danger">*</span></label>
                            <input asp-for="Input.ClientName" class="form-control form-control-lg" placeholder="e.g., ABC Corporation" />
                            <span asp-validation-for="Input.ClientName" class="text-danger small"></span>
                        </div>

                        <!-- Start Date -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Input.StartDate" class="form-label">Start Date <span class="text-danger">*</span></label>
                                    <input asp-for="Input.StartDate" type="date" class="form-control form-control-lg" />
                                    <span asp-validation-for="Input.StartDate" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Input.ExpectedEndDate" class="form-label">Expected End Date <span class="text-danger">*</span></label>
                                    <input asp-for="Input.ExpectedEndDate" type="date" class="form-control form-control-lg" />
                                    <span asp-validation-for="Input.ExpectedEndDate" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Colour Code -->
                        <div class="mb-3">
                            <label asp-for="Input.ColourCode" class="form-label">Project Colour</label>
                            <div class="input-group">
                                <input asp-for="Input.ColourCode" type="color" class="form-control form-control-color" title="Choose project colour" />
                                <input asp-for="Input.ColourCode" type="text" class="form-control" placeholder="#FF5733" readonly />
                            </div>
                            <span asp-validation-for="Input.ColourCode" class="text-danger small"></span>
                        </div>

                        <!-- Submit -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-page="./Index" class="btn btn-secondary btn-lg">Cancel</a>
                            <button type="submit" class="btn btn-primary btn-lg">Create Project</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Update hex input when color picker changes
        document.addEventListener('DOMContentLoaded', function () {
            const colorPicker = document.querySelector('input[type="color"]');
            const hexInput = document.querySelector('input[type="text"][name="Input.ColourCode"]');

            if (colorPicker && hexInput) {
                colorPicker.addEventListener('change', function () {
                    hexInput.value = this.value;
                });

                // Set color picker from hex input if available
                if (hexInput.value) {
                    colorPicker.value = hexInput.value;
                }
            }
        });
    </script>
}
