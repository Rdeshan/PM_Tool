@page
@model PMTool.Web.Pages.Projects.DetailsModel
@using System.Security.Claims
@{
    ViewData["Title"] = Model.Project?.Name ?? "Project Details";
    var canEditProject = User.IsInRole("Administrator") || User.IsInRole("Project Manager");
}

<div class="container-fluid mt-4">
    @if (Model.Project != null)
    {
        <!-- Project Header -->
        <div class="row mb-4">
            <div class="col-md-8">
                <div class="d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(Model.Project.ColourCode))
                    {
                        <div style="background-color: @Model.Project.ColourCode; width: 60px; height: 60px; border-radius: 8px;"></div>
                    }
                    <div>
                        <h1 class="mb-0">@Model.Project.Name</h1>
                        <p class="text-muted mb-0"><strong>Code:</strong> @Model.Project.ProjectCode</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-end">
                @if (canEditProject)
                {
                    <a asp-page="./Edit" asp-route-id="@Model.Project.Id" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <form method="post" asp-page-handler="Delete" style="display: inline;">
                        <input type="hidden" name="id" value="@Model.Project.Id" />
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this project?')">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </form>
                }
                <a asp-page="./Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle"></i> @Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="row">
            <!-- Project Information -->
            <div class="col-md-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="bi bi-info-circle"></i> Project Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="fw-bold text-muted">Client Name</label>
                                <p class="mb-0">@Model.Project.ClientName</p>
                            </div>
                            <div class="col-md-6">
                                <label class="fw-bold text-muted">Status</label>
                                <p class="mb-0">
                                    <span class="badge @GetStatusBadgeClass(Model.Project.Status)">
                                        @GetStatusLabel(Model.Project.Status)
                                    </span>
                                </p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="fw-bold text-muted">Start Date</label>
                                <p class="mb-0">@Model.Project.StartDate.ToString("MMMM dd, yyyy")</p>
                            </div>
                            <div class="col-md-6">
                                <label class="fw-bold text-muted">Expected End Date</label>
                                <p class="mb-0">@Model.Project.ExpectedEndDate.ToString("MMMM dd, yyyy")</p>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Project.Description))
                        {
                            <div class="mb-3">
                                <label class="fw-bold text-muted">Description</label>
                                <p>@Model.Project.Description</p>
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6">
                                <label class="fw-bold text-muted">Created</label>
                                <p class="mb-0">@Model.Project.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</p>
                            </div>
                            <div class="col-md-6">
                                <label class="fw-bold text-muted">Last Updated</label>
                                <p class="mb-0">@Model.Project.UpdatedAt.ToString("MMMM dd, yyyy HH:mm")</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Project Backlog -->
                <div class="card shadow-sm">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-list-check"></i> Project Backlog</h5>
                        @if (canEditProject)
                        {
                            <a href="#" class="btn btn-sm btn-primary">
                                <i class="bi bi-plus-circle"></i> Add Item
                            </a>
                        }
                    </div>
                    <div class="card-body">
                        <p class="text-muted text-center py-5">
                            <i class="bi bi-inbox" style="font-size: 2rem;"></i><br />
                            Backlog items will appear here
                        </p>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-md-4">
                <!-- Team Members -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-people"></i> Team Members (@Model.TeamMembers.Count())</h5>
                        @if (canEditProject)
                        {
                            <a href="#" class="btn btn-sm btn-primary">
                                <i class="bi bi-person-plus"></i>
                            </a>
                        }
                    </div>
                    <div class="card-body">
                        @if (Model.TeamMembers.Any())
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var member in Model.TeamMembers)
                                {
                                    <div class="list-group-item px-0">
                                        <div class="d-flex align-items-center justify-content-between">
                                            <div>
                                                <h6 class="mb-0">@member.FirstName @member.LastName</h6>
                                                <small class="text-muted">@member.Email</small>
                                            </div>
                                            @if (canEditProject)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-danger" title="Remove">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center py-4">
                                <i class="bi bi-people-fill" style="font-size: 1.5rem;"></i><br />
                                No team members yet
                            </p>
                        }
                    </div>
                </div>

                <!-- Project Statistics -->
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="bi bi-graph-up"></i> Statistics</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>Project Duration</span>
                                <strong>@((Model.Project.ExpectedEndDate - Model.Project.StartDate).Days) days</strong>
                            </div>
                            <small class="text-muted">
                                @{
                                    var daysRemaining = (Model.Project.ExpectedEndDate - DateTime.Now).Days;
                                    var statusText = daysRemaining > 0 ? $"{daysRemaining} days remaining" : "Completed";
                                }
                                <span>@statusText</span>
                            </small>
                        </div>

                        <div class="mb-3">
                            <span class="badge bg-secondary">@Model.TeamMembers.Count() Members</span>
                            <span class="badge bg-secondary">0 Backlog Items</span>
                        </div>

                        @if (Model.Project.IsArchived)
                        {
                            <div class="alert alert-warning alert-sm mb-0">
                                <i class="bi bi-archive"></i> This project is archived and read-only
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> Project not found
        </div>
    }
</div>

@functions {
    private string GetStatusLabel(int status)
    {
        return status switch
        {
            1 => "Active",
            2 => "On Hold",
            3 => "Completed",
            _ => "Unknown"
        };
    }

    private string GetStatusBadgeClass(int status)
    {
        return status switch
        {
            1 => "bg-success",
            2 => "bg-warning",
            3 => "bg-secondary",
            _ => "bg-secondary"
        };
    }
}
