@page
@model PMTool.Web.Pages.Projects.DetailsModel
@using System.Security.Claims
@{
    ViewData["Title"] = Model.Project?.Name ?? "Project Details";
    var canEditProject = User.IsInRole("Administrator") || User.IsInRole("Project Manager");
    var canDeleteProject = User.IsInRole("Administrator") || User.IsInRole("Project Manager");
}

<div class="container-fluid mt-4">
    @if (Model.Project != null)
    {
        <!-- Project Header -->
        <div class="row mb-3 align-items-center">
            <div class="col-md-4">
                <div class="d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(Model.Project.ColourCode))
                    {
                        <div style="background-color: @Model.Project.ColourCode; width: 60px; height: 60px; border-radius: 8px;"></div>
                    }
                    <div>
                        <h1 class="mb-0">@Model.Project.Name</h1>
                        <p class="text-muted mb-0"><strong>Code:</strong> @Model.Project.ProjectCode</p>
                    </div>
                </div>
            </div>
            <div class="col-md-5">
                <ul class="nav nav-tabs border-0 project-detail-tabs" id="projectDetailsTabs" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active fw-semibold rounded-0 px-2 me-3" id="summary-tab" data-bs-toggle="tab" data-bs-target="#summary-pane" type="button" role="tab" aria-controls="summary-pane" aria-selected="true">
                            Summary
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link text-dark rounded-0 px-2 me-3" id="backlog-tab" data-bs-toggle="tab" data-bs-target="#backlog-pane" type="button" role="tab" aria-controls="backlog-pane" aria-selected="false">
                            Project_Backlog
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link text-dark rounded-0 px-2 me-3" id="products-tab" data-bs-toggle="tab" data-bs-target="#products-pane" type="button" role="tab" aria-controls="products-pane" aria-selected="false">
                            Products
                        </button>
                    </li>
                </ul>
            </div>
            <div class="col-md-3 text-end">
                
                <a asp-page="./Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle"></i> @Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="tab-content" id="projectDetailsTabsContent">
            <div class="tab-pane fade show active" id="summary-pane" role="tabpanel" aria-labelledby="summary-tab" tabindex="0">
                <div class="row">
                    <partial name="~/Pages/Shared/Common/ProjectDetails/ProjectDetailsSummary.cshtml" model="Model" />
                </div>
            </div>

            <div class="tab-pane fade" id="backlog-pane" role="tabpanel" aria-labelledby="backlog-tab" tabindex="0">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span class="opms-card__title"><i class="bi bi-list-check me-2"></i>Project Backlog</span>
                    </div>
                    <div class="card-body p-0">
                        <iframe src="@Url.Page("/Backlog/Index", new { projectId = Model.Project.Id, embedded = true })" title="Project Backlog" style="width:100%; height:900px; border:0;"></iframe>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="products-pane" role="tabpanel" aria-labelledby="products-tab" tabindex="0">
                <iframe src="@Url.Page("/Products/Index", new { projectId = Model.Project.Id, embedded = true })" title="Project Products" style="width:100%; height:900px; border:0;"></iframe>
            </div>

        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> Project not found
        </div>
    }

    @if (Model.Project != null && canEditProject)
    {
        <div class="modal fade" id="editProjectModal" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h6 class="modal-title">Edit Project</h6>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-0">
                        <iframe src="@Url.Page("/Projects/Edit", new { id = Model.Project.Id, embedded = true })"
                                title="Edit Project"
                                style="width:100%; height:750px; border:0;"></iframe>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="createUserModal" tabindex="-1">
            <div class="modal-dialog modal-sm">
                <div class="modal-content">
                    <div class="modal-header">
                        <h6 class="modal-title">Select Team</h6>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        @if (Model.Teams.Any())
                        {
                            @foreach (var team in Model.Teams)
                            {
                                <form method="post" asp-page-handler="AddTeamMembers" class="mb-2">
                                    <input type="hidden" name="id" value="@Model.Project?.Id" />
                                    <input type="hidden" name="teamId" value="@team.Id" />
                                    <button type="submit" class="list-group-item list-group-item-action w-100 text-start border-0 bg-transparent">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="mb-1">@team.Name</h6>
                                                <small class="text-muted">@team.MemberCount members</small>
                                            </div>
                                            @if (team.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Inactive</span>
                                            }
                                        </div>
                                    </button>
                                </form>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                <p class="mt-3 mb-0">No teams yet</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .project-detail-tabs .nav-link {
        border: 0;
        border-bottom: 2px solid transparent;
        color: var(--text-muted);
        font-weight: var(--fw-medium);
        transition: color .15s;
    }
    .project-detail-tabs .nav-link:hover { color: var(--text-body); }
    .project-detail-tabs .nav-link.active {
        color: var(--primary-600);
        border-bottom-color: var(--primary-600);
        font-weight: var(--fw-semibold);
    }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Read ?tab= from the URL and activate that tab
            const params = new URLSearchParams(window.location.search);
            const tabParam = params.get('tab');

            if (tabParam) {
                // Map param value to the tab button ID
                const tabMap = {
                    'summary':  'summary-tab',
                    'backlog':  'backlog-tab',
                    'products': 'products-tab'
                };
                const tabId = tabMap[tabParam.toLowerCase()];
                if (tabId) {
                    const tabEl = document.getElementById(tabId);
                    if (tabEl) {
                        const bsTab = new bootstrap.Tab(tabEl);
                        bsTab.show();
                    }
                }
            }
        });
    </script>
}
