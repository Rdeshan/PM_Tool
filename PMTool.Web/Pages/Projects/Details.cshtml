@page
@model PMTool.Web.Pages.Projects.DetailsModel
@using System.Security.Claims
@{
    ViewData["Title"] = Model.Project?.Name ?? "Project Details";
    var canEditProject = User.IsInRole("Administrator") || User.IsInRole("Project Manager");
    var canDeleteProject = User.IsInRole("Administrator") || User.IsInRole("Project Manager");
}

<div class="container-fluid mt-4">
    @if (Model.Project != null)
    {
        <!-- Project Header -->
        <div class="row mb-3 align-items-center">
            <div class="col-md-4">
                <div class="d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(Model.Project.ColourCode))
                    {
                        <div style="background-color: @Model.Project.ColourCode; width: 60px; height: 60px; border-radius: 8px;"></div>
                    }
                    <div>
                        <h1 class="mb-0">@Model.Project.Name</h1>
                        <p class="text-muted mb-0"><strong>Code:</strong> @Model.Project.ProjectCode</p>
                    </div>
                </div>
            </div>
            <div class="col-md-5">
                <ul class="nav nav-tabs border-0 project-detail-tabs" id="projectDetailsTabs" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active fw-semibold rounded-0 px-2 me-3" id="summary-tab" data-bs-toggle="tab" data-bs-target="#summary-pane" type="button" role="tab" aria-controls="summary-pane" aria-selected="true">
                            Summary
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link text-dark rounded-0 px-2 me-3" id="backlog-tab" data-bs-toggle="tab" data-bs-target="#backlog-pane" type="button" role="tab" aria-controls="backlog-pane" aria-selected="false">
                            Project_Backlog
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link text-dark rounded-0 px-2" id="products-tab" data-bs-toggle="tab" data-bs-target="#products-pane" type="button" role="tab" aria-controls="products-pane" aria-selected="false">
                            Products
                        </button>
                    </li>
                </ul>
            </div>
            <div class="col-md-3 text-end">
                
                <a asp-page="./Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle"></i> @Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="tab-content" id="projectDetailsTabsContent">
            <div class="tab-pane fade show active" id="summary-pane" role="tabpanel" aria-labelledby="summary-tab" tabindex="0">
                <div class="row">
                    <partial name="~/Pages/Shared/Common/ProjectDetails/ProjectDetailsSummary.cshtml" model="Model" />
                </div>
            </div>

            <div class="tab-pane fade" id="backlog-pane" role="tabpanel" aria-labelledby="backlog-tab" tabindex="0">
                <div class="card shadow-sm">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-list-check"></i> Project Backlog</h5>
                        
                    </div>
                    <div class="card-body p-0">
                        <iframe src="@Url.Page("/Backlog/Index", new { projectId = Model.Project.Id, embedded = true })" title="Project Backlog" style="width:100%; height:900px; border:0;"></iframe>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="products-pane" role="tabpanel" aria-labelledby="products-tab" tabindex="0">
                <iframe src="@Url.Page("/Products/Index", new { projectId = Model.Project.Id, embedded = true })" title="Project Products" style="width:100%; height:900px; border:0;"></iframe>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> Project not found
        </div>
    }
</div>

<style>
    .project-detail-tabs .nav-link {
        border: 0;
        border-bottom: 3px solid transparent;
    }

    .project-detail-tabs .nav-link.active {
        border-bottom-color: #dc3545;
    }
</style>


