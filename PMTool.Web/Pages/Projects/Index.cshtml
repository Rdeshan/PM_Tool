@page
@model PMTool.Web.Pages.Projects.IndexModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Projects";
    var canEditProject = User.IsInRole("Administrator") || User.IsInRole("Project Manager");
    var isOnHoldTab = !Model.ShowArchived && Model.FilterStatus == "2";
    var isActiveTab = !Model.ShowArchived && !isOnHoldTab;
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-0">Projects</h1>
        </div>
        <div class="col-md-4 text-end">
            @if (canEditProject)
            {
                <button type="button" class="btn btn-primary me-2" data-bs-toggle="modal" data-bs-target="#createProjectModal">
                    <i class="bi bi-plus-circle"></i> New Project
                </button>
            }
            <!-- @if (User.IsInRole("Administrator"))
            {
                <a asp-page="/Admin/Dashboard" class="btn btn-primary">
                    <i class="bi bi-speedometer2"></i> Admin Dashboard
                </a>
            }
            else if (User.IsInRole("Project Manager"))
            {
                <a asp-page="/PM/Dashboard" class="btn btn-info">
                    <i class="bi bi-speedometer2"></i> PM Dashboard
                </a>
            } -->
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="opms-tabs mb-4">
        <a class="opms-tab @(isActiveTab ? "active" : "")" href="@Url.Page("./Index", new { archived = false })">
            Active Projects
        </a>
        <a class="opms-tab @(isOnHoldTab ? "active" : "")" href="@Url.Page("./Index", new { archived = false, status = 2 })">
            On Hold
        </a>
        <a class="opms-tab @(Model.ShowArchived ? "active" : "")" href="@Url.Page("./Index", new { archived = true })">
            Archived
        </a>
    </div>

    <!-- Projects Grid -->
    @if (Model.Projects.Any())
    {
        <div class="row g-4">
            @foreach (var project in Model.Projects)
            {
                <div class="col-md-6 col-lg-4">
                    <a asp-page="./Details" 
                    asp-route-id="@project.Id"
                    class="text-decoration-none text-dark">
                        
                        <div class="opms-card h-100 project-card" style="cursor:pointer;">
                            <div class="opms-card__header">
                                <div>
                                    <div class="opms-card__title">@project.Name</div>
                                    <span class="chip-opms chip-opms--team mt-1">@project.ProjectCode</span>
                                </div>
                                @if (!string.IsNullOrEmpty(project.ColourCode))
                                {
                                    <div style="background-color: @project.ColourCode; width: 36px; height: 36px; border-radius: var(--radius-md); flex-shrink:0;"></div>
                                }
                            </div>
                            <div class="opms-card--pad">
                                <p class="eyebrow mb-1">@project.ClientName</p>
                                <p style="font-size: var(--fs-sm); color: var(--text-body); margin-bottom: var(--space-4); min-height: 2.5em;">@project.Description</p>
                                <div style="font-size: var(--fs-xs); color: var(--text-muted); margin-bottom: var(--space-3);">
                                    <i class="bi bi-calendar3 me-1"></i>@project.StartDate.ToShortDateString() – @project.ExpectedEndDate.ToShortDateString()
                                </div>
                                <div class="d-flex align-items-center justify-content-between">
                                    <span class="badge-opms badge-opms--@(project.Status == 1 ? "success" : project.Status == 2 ? "warning" : "neutral")">
                                        <span class="dot"></span>@GetStatusLabel(project.Status)
                                    </span>
                                    @if (!Model.ShowArchived && canEditProject)
                                    {
                                        <form method="post" asp-page-handler="Archive" style="display:inline;" onclick="event.stopPropagation();">
                                            <input type="hidden" name="projectId" value="@project.Id" />
                                            <button type="submit" class="btn-opms btn-opms--ghost btn-opms--sm" onclick="return confirm('Archive this project?')">
                                                <i class="bi bi-archive"></i> Archive
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="opms-empty">
            <i class="bi bi-folder2-open"></i>
            No projects found.
        </div>
    }
</div>

@functions {
    private string GetStatusLabel(int status)
    {
        return status switch
        {
            1 => "Active",
            2 => "On Hold",
            3 => "Completed",
            _ => "Unknown"
        };
    }
}

<style>
    .project-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .project-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 32px rgba(0, 119, 182, 0.16), 0 3px 10px rgba(0, 150, 199, 0.08) !important;
    }
</style>

<!-- Create Project Modal -->
<div class="modal fade" id="createProjectModal" tabindex="-1" aria-labelledby="createProjectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(90deg, #03045e 0%, #0077b6 100%); color: #fff;">
                <h5 class="modal-title" id="createProjectModalLabel" style="color:#fff;">Add New Project</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <iframe src="@Url.Page("./Create", new { embedded = true })"
                        title="Create Project"
                        style="width:100%; height:600px; border:0;"></iframe>
            </div>
        </div>
    </div>
</div>
