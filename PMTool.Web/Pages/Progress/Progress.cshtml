@page "/Progress"
@model PMTool.Web.Pages.Progress.ProgressModel
@{
    ViewData["Title"] = "Project Progress";
    Layout = "_Layout";
}

<style>
    .project-card-header {
        cursor: pointer;
        user-select: none;
        border-radius: 8px;
        transition: background .15s;
    }
    .project-card-header:hover {
        background: rgba(0,0,0,.04);
    }
    .project-card-header .chevron-icon {
        transition: transform .2s ease;
        color: #6c757d;
    }
    .project-card-header.expanded .chevron-icon {
        transform: rotate(180deg);
    }
    .product-row {
        transition: background .12s;
        border-radius: 8px;
    }
    .product-row:hover {
        background: rgba(0,0,0,.03);
    }
</style>

<div class="container-fluid px-4 py-3">

    @* ── Header ────────────────────────────────────────────────────── *@
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Dashboard" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <p class="text-uppercase text-muted small fw-semibold mb-0" style="letter-spacing:.05em">Overview</p>
            <h4 class="fw-bold mb-0">Project Progress</h4>
        </div>
    </div>

    @* ── Metric cards ──────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-3 d-flex align-items-center justify-content-center bg-primary bg-opacity-10" style="width:44px;height:44px">
                            <i class="bi bi-folder2-open text-primary fs-5"></i>
                        </div>
                        <div>
                            <p class="text-muted small mb-0">Total Projects</p>
                            <h4 class="fw-bold mb-0">@Model.Data.TotalProjects</h4>
                        </div>
                    </div>
                    <p class="text-muted small mb-0 mt-2">@Model.Data.ProductCount product versions</p>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-3 d-flex align-items-center justify-content-center bg-success bg-opacity-10" style="width:44px;height:44px">
                            <i class="bi bi-graph-up text-success fs-5"></i>
                        </div>
                        <div>
                            <p class="text-muted small mb-0">Avg Completion</p>
                            <h4 class="fw-bold mb-0">@Model.Data.AvgCompletionPct%</h4>
                        </div>
                    </div>
                    <div class="progress mt-2" style="height:4px">
                        <div class="progress-bar bg-success" style="width:@Model.Data.AvgCompletionPct%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 border-start border-danger border-3">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-3 d-flex align-items-center justify-content-center bg-danger bg-opacity-10" style="width:44px;height:44px">
                            <i class="bi bi-exclamation-triangle text-danger fs-5"></i>
                        </div>
                        <div>
                            <p class="text-muted small mb-0">Overdue Items</p>
                            <h4 class="fw-bold mb-0 text-danger">@Model.Data.OverdueItemCount</h4>
                        </div>
                    </div>
                    <p class="text-danger small mb-0 mt-2">Needs attention</p>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 border-start border-warning border-3">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-3 d-flex align-items-center justify-content-center bg-warning bg-opacity-10" style="width:44px;height:44px">
                            <i class="bi bi-lightning text-warning fs-5"></i>
                        </div>
                        <div>
                            <p class="text-muted small mb-0">Blocked Sprints</p>
                            <h4 class="fw-bold mb-0 text-warning">@Model.Data.BlockedSprintCount</h4>
                        </div>
                    </div>
                    <p class="text-warning small mb-0 mt-2">Active sprints at risk</p>
                </div>
            </div>
        </div>
    </div>

    @* ── Project list ──────────────────────────────────────────────── *@
    @if (!Model.Data.Projects.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-folder-x fs-1 text-muted opacity-50"></i>
                <p class="text-muted mt-3 mb-0">No projects to show yet</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var project in Model.Data.Projects)
        {
            var panelId = $"proj-{project.ProjectId:N}";
            var headerId = $"hdr-{project.ProjectId:N}";
            var color = project.ColourCode ?? "#0d6efd";
            var hasProducts = project.Products.Any();

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body py-3">

                    @* ── Clickable project header row ── *@
                    @if (hasProducts)
                    {
                        <div class="project-card-header d-flex align-items-center gap-3 px-2 py-2"
                             id="@headerId"
                             data-bs-toggle="collapse"
                             data-bs-target="#@panelId"
                             aria-expanded="false"
                             aria-controls="@panelId">
                            <div class="rounded-circle flex-shrink-0"
                                 style="width:12px;height:12px;background:@color"></div>
                            <div class="flex-grow-1 min-w-0">
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    <span class="fw-semibold text-truncate">@project.ProjectName</span>
                                    <span class="badge @ProgressModel.StatusBadgeClass(project.Status) rounded-pill">
                                        @ProgressModel.StatusLabel(project.Status)
                                    </span>
                                </div>
                                <small class="text-muted">@project.ClientName</small>
                            </div>
                            <div class="position-relative d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:56px;height:56px">
                                @Html.Raw(ProgressModel.ProgressRingHtml(project.OverallProgressPct, 56, 6, color))
                                <span class="position-absolute fw-bold" style="font-size:.7rem">@project.OverallProgressPct%</span>
                            </div>
                            <i class="bi bi-chevron-down chevron-icon fs-6 flex-shrink-0"></i>
                        </div>
                    }
                    else
                    {
                        <div class="project-card-header d-flex align-items-center gap-3 px-2 py-2">
                            <div class="rounded-circle flex-shrink-0"
                                 style="width:12px;height:12px;background:@color"></div>
                            <div class="flex-grow-1 min-w-0">
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    <span class="fw-semibold text-truncate">@project.ProjectName</span>
                                    <span class="badge @ProgressModel.StatusBadgeClass(project.Status) rounded-pill">
                                        @ProgressModel.StatusLabel(project.Status)
                                    </span>
                                </div>
                                <small class="text-muted">@project.ClientName</small>
                            </div>
                            <div class="position-relative d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:56px;height:56px">
                                @Html.Raw(ProgressModel.ProgressRingHtml(project.OverallProgressPct, 56, 6, color))
                                <span class="position-absolute fw-bold" style="font-size:.7rem">@project.OverallProgressPct%</span>
                            </div>
                        </div>
                    }

                    @* ── Product list (collapsed) ── *@
                    @if (hasProducts)
                    {
                        <div class="collapse" id="@panelId">
                            <div class="mt-2 pt-2 border-top">
                                @foreach (var product in project.Products)
                                {
                                    var isOverdue = product.DueDate.HasValue && product.DueDate.Value.Date < DateTime.Today;
                                    var dueDateClass = isOverdue ? "text-danger" : "text-muted";
                                    var dueDateLabel = product.DueDate.HasValue
                                        ? product.DueDate.Value.ToString("MMM d, yyyy")
                                        : "No due date";

                                    <div class="product-row px-2 py-3 border-bottom border-light-subtle">

                                        @* Top line: name + sprint badge + analysis link *@
                                        <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                                            <div class="d-flex flex-wrap align-items-center gap-2">
                                                <span class="fw-semibold">@product.ProductName</span>
                                                @if (product.SprintStatus == "Active")
                                                {
                                                    <span class="badge bg-success-subtle text-success border border-success-subtle small">
                                                        <i class="bi bi-lightning-fill me-1"></i>@product.ActiveSprintName
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light text-secondary border small">No active sprint</span>
                                                }
                                            </div>
                                            <a href="/Progress/Analysis?productId=@product.ProductId"
                                               class="btn btn-sm btn-outline-primary flex-shrink-0">
                                                <i class="bi bi-graph-up me-1"></i>View analysis
                                            </a>
                                        </div>

                                        @* Description *@
                                        @if (!string.IsNullOrWhiteSpace(product.Description))
                                        {
                                            <p class="text-muted small mb-2" style="line-height:1.45;max-width:720px">
                                                @product.Description
                                            </p>
                                        }

                                        @* Progress bar (full width) *@
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                            <div class="progress flex-grow-1" style="height:8px;border-radius:4px">
                                                <div class="progress-bar" style="width:@product.ProgressPct%;background:@color;border-radius:4px"></div>
                                            </div>
                                            <span class="fw-semibold small" style="min-width:36px;text-align:right">@product.ProgressPct%</span>
                                        </div>

                                        @* Meta row: items count + due date *@
                                        <div class="d-flex flex-wrap gap-3">
                                            <small class="text-muted">
                                                <i class="bi bi-list-task me-1"></i>@product.WorkItemCount items
                                            </small>
                                            <small class="@dueDateClass">
                                                <i class="bi bi-calendar-event me-1"></i>Due: @dueDateLabel
                                                @if (isOverdue)
                                                {
                                                    <span class="ms-1 badge bg-danger-subtle text-danger border border-danger-subtle" style="font-size:.65rem">Overdue</span>
                                                }
                                            </small>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@section Scripts {
<script>
    document.querySelectorAll('.project-card-header[data-bs-toggle="collapse"]').forEach(header => {
        const target = document.querySelector(header.dataset.bsTarget);
        if (!target) return;
        target.addEventListener('show.bs.collapse', () => header.classList.add('expanded'));
        target.addEventListener('hide.bs.collapse', () => header.classList.remove('expanded'));
    });
</script>
}
