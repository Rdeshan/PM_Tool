@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<style>
    body.with-navbar { background: var(--primary-800) !important; }
    .auth-wrap { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:var(--space-6); }
    .auth-card { background:var(--bg-surface); border-radius:var(--radius-xl); box-shadow:var(--shadow-lg); border:1px solid var(--border); width:100%; max-width:420px; padding:var(--space-10) var(--space-8); }
    .auth-logo { display:flex; align-items:center; justify-content:center; gap:var(--space-2); margin-bottom:var(--space-6); }
    .auth-logo i { font-size:1.75rem; color:var(--primary-600); }
    .auth-logo-name { font-family:var(--font-heading); font-size:1.5rem; font-weight:var(--fw-bold); color:var(--primary-800); letter-spacing:-.02em; }
    .auth-icon { width:56px; height:56px; border-radius:var(--radius-xl); background:var(--primary-50); display:flex; align-items:center; justify-content:center; margin:0 auto var(--space-4); }
    .auth-icon i { font-size:1.5rem; color:var(--primary-600); }
    .auth-title { font-family:var(--font-heading); font-size:var(--fs-h2); font-weight:var(--fw-bold); color:var(--text-heading); text-align:center; margin-bottom:var(--space-1); }
    .auth-subtitle { font-size:var(--fs-sm); color:var(--text-muted); text-align:center; margin-bottom:var(--space-6); line-height:1.6; }
    .field-group { margin-bottom:var(--space-4); }
    .field-group label { display:block; font-size:var(--fs-sm); font-weight:var(--fw-medium); color:var(--text-body); margin-bottom:6px; }
    .field-group .form-control { border-color:var(--border); border-radius:var(--radius-sm); font-size:var(--fs-base); padding:10px 12px; color:var(--text-body); }
    .field-group .form-control:focus { border-color:var(--primary-500); box-shadow:0 0 0 3px var(--primary-100); }
    .btn-submit { width:100%; padding:11px 16px; background:var(--primary-600); color:var(--white); border:none; border-radius:var(--radius-md); font-family:var(--font-body); font-size:var(--fs-base); font-weight:var(--fw-semibold); cursor:pointer; transition:background .15s; margin-bottom:var(--space-3); }
    .btn-submit:hover { background:var(--primary-700); }
    .auth-back { display:flex; align-items:center; justify-content:center; gap:var(--space-2); font-size:var(--fs-sm); color:var(--text-muted); margin-top:var(--space-2); }
    .auth-back a { color:var(--primary-600); font-weight:var(--fw-semibold); }
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo">
            <i class="bi bi-kanban"></i>
            <span class="auth-logo-name">OPMS</span>
        </div>

        <div class="auth-icon">
            <i class="bi bi-lock"></i>
        </div>

        <h1 class="auth-title">Forgot password?</h1>
        <p class="auth-subtitle">Enter your email address and we'll send you a link to reset your password.</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="d-flex align-items-center gap-2 mb-4 p-3"
                 style="background:var(--danger-bg);color:var(--danger-text);border-radius:var(--radius-md);font-size:var(--fs-sm);">
                <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                <span>@Model.ErrorMessage</span>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="d-flex align-items-center gap-2 mb-4 p-3"
                 style="background:var(--success-bg);color:var(--success-text);border-radius:var(--radius-md);font-size:var(--fs-sm);">
                <i class="bi bi-check-circle-fill flex-shrink-0"></i>
                <span>@Model.SuccessMessage</span>
            </div>
        }

        <form method="post">
            <div class="field-group">
                <label asp-for="Email">Email address</label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
            </div>
            <button type="submit" class="btn-submit">Send reset link</button>
        </form>

        <div class="auth-back">
            <i class="bi bi-arrow-left" style="font-size:.8rem;"></i>
            <a asp-page="./Login">Back to sign in</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
