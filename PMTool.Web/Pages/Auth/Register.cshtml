@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<style>
    body.with-navbar { background: var(--primary-800) !important; }
    .auth-wrap { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:var(--space-6); }
    .auth-card { background:var(--bg-surface); border-radius:var(--radius-xl); box-shadow:var(--shadow-lg); border:1px solid var(--border); width:100%; max-width:480px; padding:var(--space-8); }
    .auth-logo { display:flex; align-items:center; justify-content:center; gap:var(--space-2); margin-bottom:var(--space-5); }
    .auth-logo i { font-size:1.75rem; color:var(--primary-600); }
    .auth-logo-name { font-family:var(--font-heading); font-size:1.5rem; font-weight:var(--fw-bold); color:var(--primary-800); letter-spacing:-.02em; }
    .auth-title { font-family:var(--font-heading); font-size:var(--fs-h2); font-weight:var(--fw-bold); color:var(--text-heading); text-align:center; margin-bottom:var(--space-1); }
    .auth-subtitle { font-size:var(--fs-sm); color:var(--text-muted); text-align:center; margin-bottom:var(--space-5); }
    .field-group { margin-bottom:var(--space-4); }
    .field-group label { display:block; font-size:var(--fs-sm); font-weight:var(--fw-medium); color:var(--text-body); margin-bottom:6px; }
    .field-group .form-control { border-color:var(--border); border-radius:var(--radius-sm); font-size:var(--fs-base); padding:10px 12px; color:var(--text-body); }
    .field-group .form-control:focus { border-color:var(--primary-500); box-shadow:0 0 0 3px var(--primary-100); }
    .field-hint { font-size:var(--fs-xs); color:var(--text-muted); margin-top:4px; }
    .btn-submit { width:100%; padding:11px 16px; background:var(--primary-600); color:var(--white); border:none; border-radius:var(--radius-md); font-family:var(--font-body); font-size:var(--fs-base); font-weight:var(--fw-semibold); cursor:pointer; transition:background .15s; margin-bottom:var(--space-4); }
    .btn-submit:hover { background:var(--primary-700); }
    .auth-footer { text-align:center; font-size:var(--fs-sm); color:var(--text-muted); margin-top:var(--space-3); }
    .auth-footer a { color:var(--primary-600); font-weight:var(--fw-semibold); }
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo">
            <i class="bi bi-kanban"></i>
            <span class="auth-logo-name">OPMS</span>
        </div>

        <h1 class="auth-title">Create your account</h1>
        <p class="auth-subtitle">Join OPMS to manage your projects</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="d-flex align-items-center gap-2 mb-4 p-3"
                 style="background:var(--danger-bg);color:var(--danger-text);border-radius:var(--radius-md);font-size:var(--fs-sm);border:1px solid #fca5a5;">
                <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                <span>@Model.ErrorMessage</span>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="d-flex align-items-center gap-2 mb-4 p-3"
                 style="background:var(--success-bg);color:var(--success-text);border-radius:var(--radius-md);font-size:var(--fs-sm);">
                <i class="bi bi-check-circle-fill flex-shrink-0"></i>
                <span>@Model.SuccessMessage</span>
            </div>
        }

        <form method="post">
            <div class="row g-3 mb-1">
                <div class="col-6">
                    <div class="field-group" style="margin-bottom:0;">
                        <label asp-for="Input.FirstName">First name</label>
                        <input asp-for="Input.FirstName" class="form-control" placeholder="John" />
                        <span asp-validation-for="Input.FirstName" class="field-hint" style="color:var(--danger-text);"></span>
                    </div>
                </div>
                <div class="col-6">
                    <div class="field-group" style="margin-bottom:0;">
                        <label asp-for="Input.LastName">Last name</label>
                        <input asp-for="Input.LastName" class="form-control" placeholder="Doe" />
                        <span asp-validation-for="Input.LastName" class="field-hint" style="color:var(--danger-text);"></span>
                    </div>
                </div>
            </div>

            <div class="field-group" style="margin-top:var(--space-4);">
                <label asp-for="Input.Email">Email address</label>
                <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="field-hint" style="color:var(--danger-text);"></span>
            </div>

            <div class="field-group">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" type="password" class="form-control" placeholder="Min. 8 characters" autocomplete="new-password" />
                <span class="field-hint">Must include uppercase, lowercase, number &amp; special character</span>
                <span asp-validation-for="Input.Password" class="field-hint" style="color:var(--danger-text);display:block;"></span>
            </div>

            <div class="field-group">
                <label asp-for="Input.ConfirmPassword">Confirm password</label>
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Repeat password" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="field-hint" style="color:var(--danger-text);"></span>
            </div>

            <button type="submit" class="btn-submit">Create account</button>
        </form>

        <div class="auth-footer">
            Already have an account? <a asp-page="./Login">Sign in</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
