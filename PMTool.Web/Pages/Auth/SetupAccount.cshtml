@page
@model PMTool.Web.Pages.Auth.SetupAccountModel
@{
    ViewData["Title"] = "Complete Account Setup";
}

<style>
    body.with-navbar { background: var(--primary-800) !important; }
    .auth-wrap { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:var(--space-6); }
    .auth-card { background:var(--bg-surface); border-radius:var(--radius-xl); box-shadow:var(--shadow-lg); border:1px solid var(--border); width:100%; max-width:460px; padding:var(--space-8); }
    .auth-logo { display:flex; align-items:center; justify-content:center; gap:var(--space-2); margin-bottom:var(--space-5); }
    .auth-logo i { font-size:1.75rem; color:var(--primary-600); }
    .auth-logo-name { font-family:var(--font-heading); font-size:1.5rem; font-weight:var(--fw-bold); color:var(--primary-800); letter-spacing:-.02em; }
    .auth-title { font-family:var(--font-heading); font-size:var(--fs-h2); font-weight:var(--fw-bold); color:var(--text-heading); text-align:center; margin-bottom:var(--space-1); }
    .auth-subtitle { font-size:var(--fs-sm); color:var(--text-muted); text-align:center; margin-bottom:var(--space-5); }
    .field-group { margin-bottom:var(--space-4); }
    .field-group label { display:block; font-size:var(--fs-sm); font-weight:var(--fw-medium); color:var(--text-body); margin-bottom:6px; }
    .field-group .form-control { border-color:var(--border); border-radius:var(--radius-sm); font-size:var(--fs-base); padding:10px 12px; }
    .field-group .form-control:focus { border-color:var(--primary-500); box-shadow:0 0 0 3px var(--primary-100); }
    .field-group .form-control:disabled { background:var(--slate-50); color:var(--text-muted); }
    .field-hint { font-size:var(--fs-xs); color:var(--text-muted); margin-top:4px; display:block; }
    .field-hint ul { padding-left:1.2rem; margin:var(--space-1) 0 0; }
    .btn-submit { width:100%; padding:11px 16px; background:var(--primary-600); color:var(--white); border:none; border-radius:var(--radius-md); font-family:var(--font-body); font-size:var(--fs-base); font-weight:var(--fw-semibold); cursor:pointer; transition:background .15s; }
    .btn-submit:hover { background:var(--primary-700); }
    .auth-back { text-align:center; font-size:var(--fs-sm); color:var(--text-muted); margin-top:var(--space-4); }
    .auth-back a { color:var(--primary-600); font-weight:var(--fw-semibold); }
    .info-note { display:flex; gap:var(--space-2); padding:var(--space-3); background:var(--info-bg); border-radius:var(--radius-md); font-size:var(--fs-xs); color:var(--info-text); margin-top:var(--space-4); }
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo">
            <i class="bi bi-kanban"></i>
            <span class="auth-logo-name">OPMS</span>
        </div>

        <h1 class="auth-title">Complete your setup</h1>
        <p class="auth-subtitle">Set your password and finish your profile</p>

        @if (Model.IsTokenValid == false)
        {
            <div class="d-flex gap-2 p-3 mb-4"
                 style="background:var(--danger-bg);color:var(--danger-text);border-radius:var(--radius-md);font-size:var(--fs-sm);">
                <i class="bi bi-exclamation-circle-fill flex-shrink-0 mt-1"></i>
                <div>
                    <strong>Invalid or expired link</strong>
                    <p class="mb-0" style="margin-top:2px;">This setup link is no longer valid. Contact your administrator for a new invitation.</p>
                </div>
            </div>
        }
        else if (Model.IsTokenValid == true && Model.IsLoading)
        {
            <div class="d-flex gap-2 p-3 mb-4"
                 style="background:var(--info-bg);color:var(--info-text);border-radius:var(--radius-md);font-size:var(--fs-sm);">
                <div class="spinner-border spinner-border-sm flex-shrink-0 mt-1" role="status"></div>
                <span>Verifying your invitation…</span>
            </div>
        }
        else if (Model.IsTokenValid == true)
        {
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="d-flex align-items-center gap-2 mb-4 p-3"
                     style="background:var(--danger-bg);color:var(--danger-text);border-radius:var(--radius-md);font-size:var(--fs-sm);">
                    <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="d-flex align-items-center gap-2 mb-4 p-3"
                     style="background:var(--success-bg);color:var(--success-text);border-radius:var(--radius-md);font-size:var(--fs-sm);">
                    <i class="bi bi-check-circle-fill flex-shrink-0"></i>
                    <span>@Model.SuccessMessage</span>
                </div>
            }

            <form method="post" class="needs-validation" novalidate>
                <input type="hidden" name="token" value="@Model.Token" />
                <input type="hidden" name="email" value="@Model.Email" />

                <div class="field-group">
                    <label for="email">Email address</label>
                    <input type="email" class="form-control" id="email" value="@Model.Email" disabled />
                    <span class="field-hint">This is the email used for your invitation</span>
                </div>

                <div class="row g-3 mb-1">
                    <div class="col-6">
                        <div class="field-group" style="margin-bottom:0;">
                            <label for="firstName">First name</label>
                            <input type="text"
                                   class="form-control@(ModelState.ContainsKey("Input.FirstName") && !ModelState.IsValid ? " is-invalid" : "")"
                                   id="firstName" name="Input.FirstName" value="@Model.Input.FirstName" required />
                            @if (ModelState.ContainsKey("Input.FirstName"))
                            {
                                <span class="field-hint" style="color:var(--danger-text);">@ModelState["Input.FirstName"].Errors.FirstOrDefault()?.ErrorMessage</span>
                            }
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="field-group" style="margin-bottom:0;">
                            <label for="lastName">Last name</label>
                            <input type="text"
                                   class="form-control@(ModelState.ContainsKey("Input.LastName") && !ModelState.IsValid ? " is-invalid" : "")"
                                   id="lastName" name="Input.LastName" value="@Model.Input.LastName" required />
                            @if (ModelState.ContainsKey("Input.LastName"))
                            {
                                <span class="field-hint" style="color:var(--danger-text);">@ModelState["Input.LastName"].Errors.FirstOrDefault()?.ErrorMessage</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="field-group" style="margin-top:var(--space-4);">
                    <label for="password">Password</label>
                    <input type="password"
                           class="form-control@(ModelState.ContainsKey("Input.Password") && !ModelState.IsValid ? " is-invalid" : "")"
                           id="password" name="Input.Password" required />
                    <span class="field-hint">
                        At least 8 characters with uppercase, lowercase, number &amp; special character
                        <ul>
                            <li>One uppercase letter</li>
                            <li>One lowercase letter</li>
                            <li>One number &amp; one special character (!, @@, #, $…)</li>
                        </ul>
                    </span>
                    @if (ModelState.ContainsKey("Input.Password"))
                    {
                        <span class="field-hint" style="color:var(--danger-text);">@ModelState["Input.Password"].Errors.FirstOrDefault()?.ErrorMessage</span>
                    }
                </div>

                <div class="field-group">
                    <label for="confirmPassword">Confirm password</label>
                    <input type="password"
                           class="form-control@(ModelState.ContainsKey("Input.ConfirmPassword") && !ModelState.IsValid ? " is-invalid" : "")"
                           id="confirmPassword" name="Input.ConfirmPassword" required />
                    @if (ModelState.ContainsKey("Input.ConfirmPassword"))
                    {
                        <span class="field-hint" style="color:var(--danger-text);">@ModelState["Input.ConfirmPassword"].Errors.FirstOrDefault()?.ErrorMessage</span>
                    }
                </div>

                <button type="submit" class="btn-submit">
                    <i class="bi bi-check-lg me-1"></i> Complete setup &amp; continue
                </button>
            </form>

            <div class="info-note">
                <i class="bi bi-info-circle-fill flex-shrink-0"></i>
                <span>After setup you'll be redirected to the login page to sign in with your new credentials.</span>
            </div>
        }

        <div class="auth-back">
            <a href="@Url.Page("/Auth/Login")">Back to login</a>
        </div>
    </div>
</div>

<script>
    (function () {
        'use strict';
        window.addEventListener('load', function () {
            var forms = document.getElementsByClassName('needs-validation');
            Array.prototype.filter.call(forms, function (form) {
                form.addEventListener('submit', function (event) {
                    if (form.checkValidity() === false) { event.preventDefault(); event.stopPropagation(); }
                    form.classList.add('was-validated');
                }, false);
            });
        }, false);
    })();

    document.getElementById('password')?.addEventListener('change', function () {
        var cp = document.getElementById('confirmPassword');
        if (cp.value && cp.value !== this.value) cp.setCustomValidity('Passwords do not match');
        else cp.setCustomValidity('');
    });

    document.getElementById('confirmPassword')?.addEventListener('change', function () {
        this.setCustomValidity(this.value !== document.getElementById('password').value ? 'Passwords do not match' : '');
    });
</script>
