@page
@model LoginModel
@using Microsoft.AspNetCore.Hosting
@inject IWebHostEnvironment Environment
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-lg">
            <div class="card-body p-5">
                <h1 class="card-title text-center mb-4">Login to PMTool</h1>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @Model.ErrorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">Email Address</label>
                        <input asp-for="Input.Email" class="form-control form-control-lg" placeholder="Enter your email" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">Password</label>
                        <input asp-for="Input.Password" type="password" class="form-control form-control-lg" placeholder="Enter your password" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">Login</button>
                </form>

                <hr />

                @if (Environment.IsDevelopment())
                {
                    <div class="alert alert-info alert-dismissible fade show" role="alert">
                        <strong>⚡ Quick Login (Development Only)</strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>

                    <div class="row g-2 mb-3">
                        <form method="post" asp-page-handler="QuickLogin" class="col-6">
                            <input type="hidden" name="email" value="admin@pmtool.com" />
                            <input type="hidden" name="password" value="Admin@123" />
                            <button type="submit" class="btn btn-outline-danger btn-sm w-100">Admin</button>
                        </form>
                        <form method="post" asp-page-handler="QuickLogin" class="col-6">
                            <input type="hidden" name="email" value="pm@pmtool.com" />
                            <input type="hidden" name="password" value="PM@123" />
                            <button type="submit" class="btn btn-outline-primary btn-sm w-100">PM</button>
                        </form>
                    </div>

                    <div class="row g-2 mb-3">
                        <form method="post" asp-page-handler="QuickLogin" class="col-6">
                            <input type="hidden" name="email" value="dev@pmtool.com" />
                            <input type="hidden" name="password" value="Dev@123" />
                            <button type="submit" class="btn btn-outline-success btn-sm w-100">Developer</button>
                        </form>
                        <form method="post" asp-page-handler="QuickLogin" class="col-6">
                            <input type="hidden" name="email" value="qa@pmtool.com" />
                            <input type="hidden" name="password" value="QA@123" />
                            <button type="submit" class="btn btn-outline-warning btn-sm w-100">QA</button>
                        </form>
                    </div>

                    <div class="row g-2 mb-3">
                        <form method="post" asp-page-handler="QuickLogin" class="col-6">
                            <input type="hidden" name="email" value="ba@pmtool.com" />
                            <input type="hidden" name="password" value="BA@123" />
                            <button type="submit" class="btn btn-outline-info btn-sm w-100">BA</button>
                        </form>
                        <form method="post" asp-page-handler="QuickLogin" class="col-6">
                            <input type="hidden" name="email" value="viewer@pmtool.com" />
                            <input type="hidden" name="password" value="Viewer@123" />
                            <button type="submit" class="btn btn-outline-secondary btn-sm w-100">Viewer</button>
                        </form>
                    </div>

                    <div class="row g-2 mb-3">
                        <form method="post" asp-page-handler="QuickLogin" class="col-6">
                            <input type="hidden" name="email" value="guest@pmtool.com" />
                            <input type="hidden" name="password" value="Guest@123" />
                            <button type="submit" class="btn btn-outline-dark btn-sm w-100">Guest</button>
                        </form>
                    </div>

                    <hr />
                }

                <div class="text-center">
                    <p class="mb-2">Don't have an account? <a asp-page="./Register" class="text-primary fw-bold">Register here</a></p>
                    <p><a asp-page="./ForgotPassword" class="text-muted">Forgot your password?</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
