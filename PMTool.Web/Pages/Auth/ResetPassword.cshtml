@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<style>
    body.with-navbar { background: var(--primary-800) !important; }
    .auth-wrap { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:var(--space-6); }
    .auth-card { background:var(--bg-surface); border-radius:var(--radius-xl); box-shadow:var(--shadow-lg); border:1px solid var(--border); width:100%; max-width:420px; padding:var(--space-10) var(--space-8); }
    .auth-logo { display:flex; align-items:center; justify-content:center; gap:var(--space-2); margin-bottom:var(--space-6); }
    .auth-logo i { font-size:1.75rem; color:var(--primary-600); }
    .auth-logo-name { font-family:var(--font-heading); font-size:1.5rem; font-weight:var(--fw-bold); color:var(--primary-800); letter-spacing:-.02em; }
    .auth-icon { width:56px; height:56px; border-radius:var(--radius-xl); display:flex; align-items:center; justify-content:center; margin:0 auto var(--space-4); }
    .auth-title { font-family:var(--font-heading); font-size:var(--fs-h2); font-weight:var(--fw-bold); color:var(--text-heading); text-align:center; margin-bottom:var(--space-1); }
    .auth-subtitle { font-size:var(--fs-sm); color:var(--text-muted); text-align:center; margin-bottom:var(--space-6); }
    .field-group { margin-bottom:var(--space-4); }
    .field-group label { display:block; font-size:var(--fs-sm); font-weight:var(--fw-medium); color:var(--text-body); margin-bottom:6px; }
    .field-group .form-control { border-color:var(--border); border-radius:var(--radius-sm); font-size:var(--fs-base); padding:10px 12px; }
    .field-group .form-control:focus { border-color:var(--primary-500); box-shadow:0 0 0 3px var(--primary-100); }
    .field-hint { font-size:var(--fs-xs); color:var(--text-muted); margin-top:4px; }
    .btn-submit { width:100%; padding:11px 16px; background:var(--primary-600); color:var(--white); border:none; border-radius:var(--radius-md); font-family:var(--font-body); font-size:var(--fs-base); font-weight:var(--fw-semibold); cursor:pointer; transition:background .15s; }
    .btn-submit:hover { background:var(--primary-700); }
    .btn-cta { display:inline-flex; align-items:center; gap:var(--space-2); padding:11px 24px; border-radius:var(--radius-md); font-family:var(--font-body); font-size:var(--fs-base); font-weight:var(--fw-semibold); cursor:pointer; text-decoration:none; border:none; transition:background .15s; }
    .btn-cta--primary { background:var(--primary-600); color:var(--white); }
    .btn-cta--primary:hover { background:var(--primary-700); color:var(--white); }
    .btn-cta--danger { background:var(--danger-bg); color:var(--danger-text); border:1px solid var(--danger-bg); }
    .btn-cta--danger:hover { background:#fecaca; }
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo">
            <i class="bi bi-kanban"></i>
            <span class="auth-logo-name">OPMS</span>
        </div>

        @if (Model.IsSuccess)
        {
            <div class="auth-icon" style="background:var(--success-bg);">
                <i class="bi bi-check-circle-fill" style="font-size:1.5rem;color:var(--success-text);"></i>
            </div>
            <h1 class="auth-title">Password reset!</h1>
            <p class="auth-subtitle">Your password has been reset successfully. You can now sign in.</p>
            <div class="text-center">
                <a asp-page="./Login" class="btn-cta btn-cta--primary">Sign in with new password</a>
            </div>
        }
        else if (Model.IsInvalid)
        {
            <div class="auth-icon" style="background:var(--danger-bg);">
                <i class="bi bi-x-circle-fill" style="font-size:1.5rem;color:var(--danger-text);"></i>
            </div>
            <h1 class="auth-title">Invalid link</h1>
            <p class="auth-subtitle">This password reset link is invalid or has expired. Please request a new one.</p>
            <div class="text-center">
                <a asp-page="./ForgotPassword" class="btn-cta btn-cta--danger">Request new link</a>
            </div>
        }
        else
        {
            <div class="auth-icon" style="background:var(--primary-50);">
                <i class="bi bi-shield-lock" style="font-size:1.5rem;color:var(--primary-600);"></i>
            </div>
            <h1 class="auth-title">Set new password</h1>
            <p class="auth-subtitle">Choose a strong password for your account</p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="d-flex align-items-center gap-2 mb-4 p-3"
                     style="background:var(--danger-bg);color:var(--danger-text);border-radius:var(--radius-md);font-size:var(--fs-sm);">
                    <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            <form method="post">
                <input type="hidden" asp-for="Token" />
                <input type="hidden" asp-for="Email" />

                <div class="field-group">
                    <label asp-for="Password">New password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Min. 8 characters" />
                    <span class="field-hint">Must include uppercase, lowercase, number &amp; special character</span>
                    <span asp-validation-for="Password" class="field-hint" style="color:var(--danger-text);display:block;"></span>
                </div>

                <div class="field-group">
                    <label asp-for="ConfirmPassword">Confirm new password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat password" />
                    <span asp-validation-for="ConfirmPassword" class="field-hint" style="color:var(--danger-text);"></span>
                </div>

                <button type="submit" class="btn-submit">Reset password</button>
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
