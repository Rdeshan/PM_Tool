@page "{productId:guid?}"
@using PMTool.Domain.Enums
@model PMTool.Web.Pages.Backlog.IndexModel
@{
    var isEmbedded = string.Equals(Request.Query["embedded"], "true", StringComparison.OrdinalIgnoreCase);
    if (isEmbedded)
    {
        Layout = "_EmbeddedLayout";
    }

    ViewData["Title"] = "Backlog";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center gap-2">
            <button id="createIssueBtn" class="btn btn-sm btn-primary">
                <i class="bi bi-plus-circle"></i> Create issue...
            </button>
            <button id="bulkDeleteBtn" class="btn btn-sm btn-outline-danger d-none" type="button" title="Delete selected">
                <i class="bi bi-trash"></i>
            </button>
        </div>
    </div>

    <form method="get" asp-page="/Backlog/Index" class="row g-2 mb-3">
        @if (Model.SelectedProjectId != Guid.Empty)
        {
            <input type="hidden" name="projectId" value="@Model.SelectedProjectId" />
        }
        @if (isEmbedded)
        {
            <input type="hidden" name="embedded" value="true" />
        }
        <div class="col-md-6">
            <label class="form-label">Product</label>
            <select name="productId" id="productFilter" class="form-select" onchange="this.form.submit()">
                <option value="">Project-level backlog</option>
                @foreach (var product in Model.Products)
                {
                    <option value="@product.Id" selected="@(Model.SelectedProductId == product.Id)">@product.VersionName</option>
                }
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label">Status</label>
            <select name="status" id="statusFilter" class="form-select" onchange="this.form.submit()">
                <option value="">All</option>
                <option value="1" selected="@(Model.SelectedStatus == 1)">Draft</option>
                <option value="2" selected="@(Model.SelectedStatus == 2)">Approved</option>
                <option value="3" selected="@(Model.SelectedStatus == 3)">In Progress</option>
                <option value="4" selected="@(Model.SelectedStatus == 4)">Done</option>
            </select>
        </div>
    </form>

    <div id="toast" class="alert d-none py-2 px-3 mb-2"></div>

    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle" id="backlogTable"
               data-project-id="@Model.SelectedProjectId"
               data-product-id="@Model.SelectedProductId">
            <thead class="table-light">
                <tr>
                    <th style="width:32px;"><input type="checkbox" id="selectAll" /></th>
                    <th style="width:36px;"></th>
                   <th class="title-column">Title</th>
                    <th class="type-column">Type</th>
                    <th>Status</th>
                    <th>Owner</th>
                    <th class="parent-column d-none">Parent</th>
                    @* <th style="width:110px;">Priority</th> *@
                    <th style="width:90px;"></th>
                </tr>
            </thead>
            <tbody id="createRow" class="d-none">
                <tr>
                    <td></td>
                    <td></td>
                    <td>
                        <input class="form-control form-control-sm" id="newTitle" placeholder="Issue title" />
                        <div id="bulkInputsContainer" class="mt-2"></div>
                        <div id="newDescriptionWrap" class="mt-2 d-none">
                            <textarea id="newDescription" class="form-control form-control-sm" rows="2" placeholder="Use case description (optional)"></textarea>
                        </div>
                        <div class="mt-2">
                            <select class="form-select form-select-sm" id="newParent">
                                <option value="">No Parent</option>
                                @foreach (var brd in Model.Brds)
                                {
                                    var brdCode = Model.GetItemDisplayCode(brd);
                                    var brdParentLabel = string.IsNullOrWhiteSpace(brdCode) ? "BR" : brdCode.Replace("BRD-", "BR-");
                                    <option value="@brd.Id">@brdParentLabel</option>
                                }
                                @foreach (var epic in Model.Epics)
                                {
                                    <option value="@epic.Id">Epic: @epic.Title</option>
                                }
                            </select>
                        </div>
                    </td>
                    <td>
                        <select class="form-select form-select-sm" id="newType">
                            <option value="1">BRD</option>
                            <option value="2">UserStory</option>
                            <option value="3">UseCase</option>
                            <option value="4" selected>Epic</option>
                            <option value="5">ChangeRequest</option>
                        </select>
                    </td>
                    <td>
                        <select class="form-select form-select-sm" id="newStatus">
                            <option value="1" selected>Draft</option>
                            <option value="2">Approved</option>
                            <option value="3">In Progress</option>
                            <option value="4">Done</option>
                        </select>
                    </td>
                    <td>
                        <select class="form-select form-select-sm" id="newOwner">
                            <option value="">Unassigned</option>
                            @foreach (var owner in Model.Owners)
                            {
                                <option value="@owner.Id">@owner.FirstName @owner.LastName</option>
                            }
                        </select>
                    </td>
                    <td class="parent-column d-none"></td>
                    @* <td>-</td> *@
                    <td class="text-end">
                        <div class="d-inline-flex align-items-center gap-2">
                            <button id="saveNewIssue" class="btn btn-sm btn-success" type="button">Save</button>
                            <button id="addBulkInputBtn" class="btn btn-sm btn-outline-primary" type="button" title="Add another issue input">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
            <tbody id="skeletonRows">
                @for (var i = 0; i < 4; i++)
                {
                    <tr>
                        <td colspan="9"><div class="skeleton-line"></div></td>
                    </tr>
                }
            </tbody>
            <tbody id="rows" class="d-none">
                @foreach (var item in Model.OrderedItems)
                {
                    <tr draggable="true" data-id="@item.Id" data-type="@item.Type" data-parent-id="@item.ParentBacklogItemId" data-level="@Model.GetIndentLevel(item)">
                        <td><input type="checkbox" class="row-check" /></td>
                        <td class="text-muted drag-handle"><i class="bi bi-grip-vertical"></i></td>
                        <td class="editable" data-field="title" style="padding-left:@(0.75 + (Model.GetIndentLevel(item) * 1.25) + (item.Type == (int)BacklogItemType.UseCase ? 1.85 : 0))rem;">
                            @if (!string.IsNullOrWhiteSpace(Model.GetItemDisplayCode(item)))
                            {
                                <span class="item-code badge bg-light text-dark border me-1">@Model.GetItemDisplayCode(item)</span>
                            }
                            @if (Model.HasChildren(item))
                            {
                                <button type="button" class="btn btn-sm p-0 me-4 fold-toggle" data-row-id="@item.Id" title="Collapse/Expand">
                                    <i class="bi bi-caret-down-fill"></i>
                                </button>
                            }
                            @if (Model.GetIndentLevel(item) > 0)
                            {
                                <span class="text-muted me-1 hierarchy-indicator">↳</span>
                            }
                            <span class="item-title-text" title="@item.Title">@item.Title</span>
                            @if (item.Type == (int)BacklogItemType.UseCase)
                            {
                                <button type="button" class="btn btn-sm p-0 ms-2 usecase-desc-toggle" data-description="@item.Description" title="View description">
                                    <i class="bi bi-three-dots"></i>
                                </button>
                            }
                        </td>
                        <td class="editable-select" data-field="type" data-value="@item.Type">
                            <span class="badge @Model.GetTypeBadgeClass(item.Type)">@item.TypeName</span>
                        </td>
                        <td class="editable-select" data-field="status" data-value="@item.Status">@item.StatusName</td>
                        <td class="editable-select" data-field="owner" data-value="@item.OwnerId">@(string.IsNullOrWhiteSpace(item.OwnerName) ? "Unassigned" : item.OwnerName)</td>
                        <td class="editable-select parent-column d-none" data-field="parentbacklogitemid" data-value="@item.ParentBacklogItemId">@(Model.Items.FirstOrDefault(x => x.Id == item.ParentBacklogItemId)?.Title ?? "None")</td>
                        @* <td class="priority-cell">@Model.GetDisplayPriorityLabel(item)</td> *@
                        <td class="text-end action-cell">
                            <button class="btn btn-sm btn-outline-danger delete-btn" type="button" title="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@Html.AntiForgeryToken()

@section Styles {
    <style>
        #backlogTable {
            background: #fff;
            border: 1px solid #e9ecef;
            border-radius: 8px;
            overflow: hidden;
        }
        #backlogTable thead th {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.02em;
            color: #6c757d;
        }
        #backlogTable tbody tr:hover {
            background-color: #f8fbff;
        }
        #backlogTable .delete-btn {
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.15s ease;
            padding: 0.15rem 0.35rem;
            line-height: 1;
        }
        #backlogTable tbody tr:hover .delete-btn {
            opacity: 1;
            visibility: visible;
        }
        #createRow tr {
            background-color: #f5faff;
        }
        .editable, .editable-select {
            cursor: pointer;
        }
        .item-code {
            font-size: 0.72rem;
            font-weight: 600;
            vertical-align: middle;
        }
        #backlogTable th.title-column,
        #backlogTable td.editable {
            width: 800px;
            max-width: 800px;
        }
        #backlogTable td.editable {
            white-space: nowrap;
            overflow: hidden;
        }
        .item-title-text {
            display: inline-block;
            max-width: calc(100% - 150px);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            vertical-align: middle;
        }
        #backlogTable th.type-column,
        #backlogTable td[data-field="type"] {
            padding-left: 0.9rem;
        }
        .skeleton-line { height: 18px; border-radius: 6px; background: linear-gradient(90deg,#ececec 25%,#f8f8f8 37%,#ececec 63%); background-size: 400% 100%; animation: shimmer 1.2s infinite; }
        @@keyframes shimmer { 0% { background-position: 100% 0; } 100% { background-position: 0 0; } }
        .drag-over { outline: 2px dashed #0d6efd; }
        .drag-handle { cursor: move; }
        .bg-purple { background-color: #6f42c1 !important; }
        .fold-toggle {
            color: #6c757d;
            border: 0;
            background: transparent;
            vertical-align: middle;
        }
        .fold-toggle:hover {
            color: #0d6efd;
        }
        .fold-hidden {
            display: none;
        }
        .usecase-desc-toggle {
            color: #6c757d;
            border: 0;
            background: transparent;
            vertical-align: middle;
        }
        .usecase-desc-toggle:hover {
            color: #0d6efd;
        }
        #usecaseDescCard {
            position: fixed;
            z-index: 1055;
            width: min(320px, calc(100vw - 2rem));
            display: none;
        }

    </style>
}

@section Scripts {
<script>
(() => {
    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
    const createBtn = document.getElementById('createIssueBtn');
    const createRow = document.getElementById('createRow');
    const saveNewBtn = document.getElementById('saveNewIssue');
    const newType = document.getElementById('newType');
    const newParent = document.getElementById('newParent');
    const newDescriptionWrap = document.getElementById('newDescriptionWrap');
    const newDescription = document.getElementById('newDescription');
    const bulkInputsContainer = document.getElementById('bulkInputsContainer');
    const addBulkInputBtn = document.getElementById('addBulkInputBtn');
    const selectAll = document.getElementById('selectAll');
    const bulkDeleteBtn = document.getElementById('bulkDeleteBtn');
    const rowsBody = document.getElementById('rows');
    const skeleton = document.getElementById('skeletonRows');
    const table = document.getElementById('backlogTable');
    const collapsedRows = new Set();
    const usecaseDescCard = document.createElement('div');
    usecaseDescCard.id = 'usecaseDescCard';
    usecaseDescCard.className = 'card shadow-sm';
    usecaseDescCard.innerHTML = '<div class="card-body py-2 px-3"><small class="text-muted d-block mb-1">Use Case Description</small><div id="usecaseDescText"></div></div>';
    document.body.appendChild(usecaseDescCard);

    const MAX_BULK_INPUTS = 10;

    const getAllTitleInputs = () => [
        document.getElementById('newTitle'),
        ...bulkInputsContainer.querySelectorAll('.bulk-title-input')
    ];

    const getTitleInputCount = () => getAllTitleInputs().length;

    const createBulkTitleInput = (index) => {
        const wrapper = document.createElement('div');
        wrapper.className = 'mt-2 bulk-input-row';

        const topRow = document.createElement('div');
        topRow.className = 'd-flex align-items-center gap-2';

        const input = document.createElement('input');
        input.className = 'form-control form-control-sm bulk-title-input';
        input.placeholder = `Issue title ${index}`;

        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'btn btn-sm btn-outline-danger';
        removeBtn.title = 'Remove';
        removeBtn.innerHTML = '<i class="bi bi-x-lg"></i>';
        removeBtn.addEventListener('click', () => {
            wrapper.remove();
            toggleAddBulkBtnState();
            refreshBulkInputPlaceholders();
        });

        const descWrap = document.createElement('div');
        descWrap.className = 'mt-2 bulk-desc-wrap d-none';

        const desc = document.createElement('textarea');
        desc.className = 'form-control form-control-sm bulk-description-input';
        desc.rows = 2;
        desc.placeholder = `Use case description ${index} (optional)`;
        descWrap.appendChild(desc);

        topRow.appendChild(input);
        topRow.appendChild(removeBtn);
        wrapper.appendChild(topRow);
        wrapper.appendChild(descWrap);
        return wrapper;
    };

    const refreshBulkInputPlaceholders = () => {
        const rows = [...bulkInputsContainer.querySelectorAll('.bulk-input-row')];
        rows.forEach((row, idx) => {
            const position = idx + 2;
            const titleInput = row.querySelector('.bulk-title-input');
            const descInput = row.querySelector('.bulk-description-input');
            if (titleInput) {
                titleInput.placeholder = `Issue title ${position}`;
            }
            if (descInput) {
                descInput.placeholder = `Use case description ${position} (optional)`;
            }
        });
    };

    const toggleDescriptionInputsByType = () => {
        const isUseCase = parseInt(newType.value) === 3;
        newDescriptionWrap.classList.toggle('d-none', !isUseCase);
        if (!isUseCase) {
            newDescription.value = '';
        }

        bulkInputsContainer.querySelectorAll('.bulk-desc-wrap').forEach(wrap => {
            wrap.classList.toggle('d-none', !isUseCase);
            if (!isUseCase) {
                const descInput = wrap.querySelector('.bulk-description-input');
                if (descInput) {
                    descInput.value = '';
                }
            }
        });
    };

    const toggleAddBulkBtnState = () => {
        addBulkInputBtn.disabled = getTitleInputCount() >= MAX_BULK_INPUTS;
    };

    const clearBulkCreateInputs = () => {
        document.getElementById('newTitle').value = '';
        newDescription.value = '';
        bulkInputsContainer.innerHTML = '';
        toggleAddBulkBtnState();
    };

    setTimeout(() => { skeleton.classList.add('d-none'); rowsBody.classList.remove('d-none'); }, 300);

    const notify = (message, ok = true) => {
        const toast = document.getElementById('toast');
        toast.className = `alert ${ok ? 'alert-success' : 'alert-danger'} py-2 px-3 mb-2`;
        toast.textContent = message;
        toast.classList.remove('d-none');
        setTimeout(() => toast.classList.add('d-none'), 1800);
    };

    const postJson = async (handler, payload) => {
        const response = await fetch(`?handler=${handler}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
            body: JSON.stringify(payload)
        });
        return response.json();
    };

    const getChildRows = (parentId) => [...rowsBody.querySelectorAll(`tr[data-parent-id="${parentId}"]`)];

    const hideDescendants = (parentId) => {
        const children = getChildRows(parentId);
        children.forEach(child => {
            child.classList.add('fold-hidden');
            hideDescendants(child.dataset.id);
        });
    };

    const showDescendants = (parentId) => {
        const children = getChildRows(parentId);
        children.forEach(child => {
            child.classList.remove('fold-hidden');
            if (collapsedRows.has(child.dataset.id)) {
                hideDescendants(child.dataset.id);
            } else {
                showDescendants(child.dataset.id);
            }
        });
    };

    const setToggleIcon = (btn, collapsed) => {
        const icon = btn.querySelector('i');
        if (!icon) return;
        icon.className = collapsed ? 'bi bi-caret-right-fill' : 'bi bi-caret-down-fill';
    };

    const getSelectedRows = () => [...rowsBody.querySelectorAll('.row-check:checked')].map(c => c.closest('tr'));

    const syncSelectionUi = () => {
        const allChecks = [...rowsBody.querySelectorAll('.row-check')];
        const checked = allChecks.filter(c => c.checked);
        selectAll.checked = allChecks.length > 0 && checked.length === allChecks.length;
        bulkDeleteBtn.classList.toggle('d-none', checked.length === 0);
    };

    selectAll.addEventListener('change', () => {
        const checked = selectAll.checked;
        rowsBody.querySelectorAll('.row-check').forEach(c => c.checked = checked);
        syncSelectionUi();
    });

    bulkDeleteBtn.addEventListener('click', async () => {
        const selectedRows = getSelectedRows();
        if (selectedRows.length === 0) {
            bulkDeleteBtn.classList.add('d-none');
            return;
        }

        const confirmed = confirm(`Delete ${selectedRows.length} selected item(s)?`);
        if (!confirmed) return;

        const itemIds = selectedRows.map(r => r.dataset.id);
        const result = await postJson('DeleteMany', { itemIds });
        notify(result.message, result.success);

        if (result.success) {
            selectedRows.forEach(r => r.remove());
            location.reload();
            syncSelectionUi();
        }
    });

    createBtn.addEventListener('click', () => {
        createRow.classList.toggle('d-none');
        refreshCreateParentOptions();
        const input = document.getElementById('newTitle');
        input.focus();
    });

    addBulkInputBtn.addEventListener('click', () => {
        const nextIndex = getTitleInputCount() + 1;
        if (nextIndex > MAX_BULK_INPUTS) {
            notify(`Maximum ${MAX_BULK_INPUTS} issue inputs allowed.`, false);
            return;
        }

        const inputRow = createBulkTitleInput(nextIndex);
        bulkInputsContainer.appendChild(inputRow);
        toggleAddBulkBtnState();
        inputRow.querySelector('.bulk-title-input')?.focus();
    });

    rowsBody.addEventListener('change', (e) => {
        if (e.target.classList.contains('row-check')) {
            syncSelectionUi();
        }
    });

    rowsBody.addEventListener('click', (e) => {
        const toggleBtn = e.target.closest('.fold-toggle');
        if (!toggleBtn) return;

        e.preventDefault();
        e.stopPropagation();

        const rowId = toggleBtn.dataset.rowId;
        if (!rowId) return;

        const isCollapsed = collapsedRows.has(rowId);
        if (isCollapsed) {
            collapsedRows.delete(rowId);
            setToggleIcon(toggleBtn, false);
            showDescendants(rowId);
        } else {
            collapsedRows.add(rowId);
            setToggleIcon(toggleBtn, true);
            hideDescendants(rowId);
        }
    });

    newType.addEventListener('change', refreshCreateParentOptions);

    function refreshCreateParentOptions() {
        const type = parseInt(newType.value);
        const options = [{ value: '', label: 'No Parent' }];
        toggleDescriptionInputsByType();

        if (type === 4) {
            @foreach (var brd in Model.Brds)
            {
                var brdCode = Model.GetItemDisplayCode(brd);
                var brdParentLabel = string.IsNullOrWhiteSpace(brdCode) ? "BR" : brdCode.Replace("BRD-", "BR-");
                @:options.push({ value: '@brd.Id', label: '@brdParentLabel' });
            }
        }

        if (type === 2) {
            @foreach (var epic in Model.Epics)
            {
                @:options.push({ value: '@epic.Id', label: 'Epic: @epic.Title' });
            }
        }

        if (type === 3) {
            @foreach (var story in Model.UserStories)
            {
                @:options.push({ value: '@story.Id', label: 'Story: @story.Title' });
            }
        }

        if (type === 5) {
            @foreach (var story in Model.UserStories)
            {
                @:options.push({ value: '@story.Id', label: 'Story: @story.Title' });
            }
        }

        newParent.innerHTML = '';
        options.forEach(o => {
            const option = document.createElement('option');
            option.value = o.value;
            option.textContent = o.label;
            newParent.appendChild(option);
        });
    }

    document.getElementById('newTitle').addEventListener('keydown', async (e) => {
        if (e.key === 'Enter') {
            e.preventDefault();
            saveNewBtn.click();
        }
        if (e.key === 'Escape') {
            createRow.classList.add('d-none');
        }
    });

    saveNewBtn.addEventListener('click', async () => {
        const entries = [];

        const firstTitle = document.getElementById('newTitle').value.trim();
        if (firstTitle) {
            entries.push({
                title: firstTitle,
                description: parseInt(newType.value) === 3 ? (newDescription.value || '').trim() : ''
            });
        }

        bulkInputsContainer.querySelectorAll('.bulk-input-row').forEach(row => {
            const titleInput = row.querySelector('.bulk-title-input');
            const descInput = row.querySelector('.bulk-description-input');
            const title = titleInput?.value?.trim() ?? '';
            if (!title) return;

            entries.push({
                title,
                description: parseInt(newType.value) === 3 ? (descInput?.value || '').trim() : ''
            });
        });

        if (entries.length === 0) {
            notify('Title is required.', false);
            return;
        }

        let successCount = 0;
        let firstErrorMessage = '';

        for (const entry of entries) {
            const payload = {
                projectId: table.dataset.projectId,
                productId: table.dataset.productId || null,
                title: entry.title,
                type: parseInt(document.getElementById('newType').value),
                status: parseInt(document.getElementById('newStatus').value),
                ownerId: document.getElementById('newOwner').value || null,
                parentBacklogItemId: document.getElementById('newParent').value || null,
                description: entry.description
            };

            const result = await postJson('Create', payload);
            if (result.success) {
                successCount++;
            } else if (!firstErrorMessage) {
                firstErrorMessage = result.message || 'Failed to create one or more issues.';
            }
        }

        if (successCount === entries.length) {
            notify(`Created ${successCount} issue(s).`, true);
            location.reload();
            return;
        }

        if (successCount > 0) {
            notify(`Created ${successCount}/${entries.length} issue(s). ${firstErrorMessage}`, false);
            location.reload();
        } else {
            notify(firstErrorMessage || 'Failed to create issues.', false);
        }
    });

    const startEditText = (cell) => {
        if (cell.querySelector('input')) return;
        const existingCodeBadge = cell.querySelector('.item-code');
        const codeText = existingCodeBadge?.textContent?.trim() ?? '';
        const existingFoldToggle = cell.querySelector('.fold-toggle');
        const foldRowId = existingFoldToggle?.dataset.rowId;
        const existingUsecaseDescToggle = cell.querySelector('.usecase-desc-toggle');
        const usecaseDescription = existingUsecaseDescToggle?.dataset.description ?? '';
        const hasIndicator = !!cell.querySelector('.hierarchy-indicator');
        const titleTextEl = cell.querySelector('.item-title-text');
        const original = titleTextEl?.textContent?.trim() ?? '';
        const input = document.createElement('input');
        input.className = 'form-control form-control-sm';
        input.value = original;
        cell.textContent = '';
        cell.appendChild(input);
        input.focus();

        const setCellText = (text) => {
            cell.innerHTML = '';

            if (codeText) {
                const code = document.createElement('span');
                code.className = 'item-code badge bg-light text-dark border me-1'
                code.textContent = codeText;
                cell.appendChild(code);
            }

            if (foldRowId) {
                const toggle = document.createElement('button');
                toggle.type = 'button';
                toggle.className = 'btn btn-sm p-0 me-4 fold-toggle';
                toggle.dataset.rowId = foldRowId;
                toggle.title = 'Collapse/Expand';

                const icon = document.createElement('i');
                icon.className = collapsedRows.has(foldRowId) ? 'bi bi-caret-right-fill' : 'bi bi-caret-down-fill';
                toggle.appendChild(icon);

                cell.appendChild(toggle);
            }

            if (hasIndicator) {
                const indicator = document.createElement('span');
                indicator.className = 'text-muted me-1 hierarchy-indicator';
                indicator.textContent = '↳';
                cell.appendChild(indicator);
            }
            const titleSpan = document.createElement('span');
            titleSpan.className = 'item-title-text';
            titleSpan.title = text;
            titleSpan.textContent = text;
            cell.appendChild(titleSpan);

            if (existingUsecaseDescToggle) {
                const descToggle = document.createElement('button');
                descToggle.type = 'button';
                descToggle.className = 'btn btn-sm p-0 ms-2 usecase-desc-toggle';
                descToggle.dataset.description = usecaseDescription;
                descToggle.title = 'View description';

                const descIcon = document.createElement('i');
                descIcon.className = 'bi bi-three-dots';
                descToggle.appendChild(descIcon);

                cell.appendChild(descToggle);
            }
        };

        const save = async () => {
            const row = cell.closest('tr');
            const field = cell.dataset.field;
            const value = input.value.trim();

            if (value === original) {
                setCellText(original);
                return;
            }

            setCellText(value);
            const result = await postJson('UpdateField', { itemId: row.dataset.id, field, value });
            notify(result.message, result.success);
        };

        input.addEventListener('blur', save);
        input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') save();
            if (e.key === 'Escape') setCellText(original);
        });
    };

    const getSelectOptions = (field, rowType) => {
        if (field === 'type') {
            return [
                { value: 1, label: 'BRD' },
                { value: 2, label: 'UserStory' },
                { value: 3, label: 'UseCase' },
                { value: 4, label: 'Epic' },
                { value: 5, label: 'ChangeRequest' }
            ];
        }
        if (field === 'status') {
            return [
                { value: 1, label: 'Draft' },
                { value: 2, label: 'Approved' },
                { value: 3, label: 'InProgress' },
                { value: 4, label: 'Done' }
            ];
        }
        if (field === 'owner') {
            const owners = [{ value: '', label: 'Unassigned' }];
            @foreach (var owner in Model.Owners)
            {
                @:owners.push({ value: '@owner.Id', label: '@owner.FirstName @owner.LastName' });
            }
            return owners;
        }
        if (field === 'parentbacklogitemid') {
            const parents = [{ value: '', label: 'None' }];
            if (rowType === 4) {
                @foreach (var brd in Model.Brds)
                {
                    var brdCode = Model.GetItemDisplayCode(brd);
                    var brdParentLabel = string.IsNullOrWhiteSpace(brdCode) ? "BR" : brdCode.Replace("BRD-", "BR-");
                    @:parents.push({ value: '@brd.Id', label: '@brdParentLabel' });
                }
            }
            if (rowType === 2) {
                @foreach (var epic in Model.Epics)
                {
                    @:parents.push({ value: '@epic.Id', label: 'Epic: @epic.Title' });
                }
            }
            if (rowType === 3) {
                @foreach (var story in Model.UserStories)
                {
                    @:parents.push({ value: '@story.Id', label: 'Story: @story.Title' });
                }
            }
            if (rowType === 5) {
                @foreach (var story in Model.UserStories)
                {
                    @:parents.push({ value: '@story.Id', label: 'Story: @story.Title' });
                }
            }
            if (rowType !== 2 && rowType !== 3 && rowType !== 4 && rowType !== 5)
            {
                return [{ value: '', label: 'None' }];
            }
            return parents;
        }
        return [];
    };

    const startEditSelect = (cell) => {
        if (cell.querySelector('select')) return;
        const row = cell.closest('tr');
        const field = cell.dataset.field;
        const rowType = parseInt(row.dataset.type || '0');
        const current = (cell.dataset.value || '') + '';
        const originalText = cell.textContent.trim();
        const select = document.createElement('select');
        select.className = 'form-select form-select-sm';
        let saved = false;

        const options = getSelectOptions(field, rowType);
        options.forEach(o => {
            const option = document.createElement('option');
            option.value = o.value;
            option.textContent = o.label;
            if ((o.value + '') === (current + '')) option.selected = true;
            select.appendChild(option);
        });

        cell.innerHTML = '';
        cell.appendChild(select);
        select.focus();

        const save = async () => {
            if (saved) return;
            const value = select.value;

            if ((value + '') === current) {
                cell.dataset.value = current;
                cell.textContent = originalText;
                return;
            }

            saved = true;
            const label = select.options[select.selectedIndex].text;
            cell.dataset.value = value;
            cell.textContent = label;
            const result = await postJson('UpdateField', { itemId: row.dataset.id, field, value });
            notify(result.message, result.success);
        };

        select.addEventListener('change', save);
        select.addEventListener('blur', () => { if (cell.querySelector('select')) save(); });
        select.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') cell.textContent = originalText;
            if (e.key === 'Enter') save();
        });
    };

    rowsBody.addEventListener('click', async (e) => {
        if (e.target.closest('.fold-toggle')) {
            return;
        }

        const useCaseDescBtn = e.target.closest('.usecase-desc-toggle');
        if (useCaseDescBtn) {
            e.preventDefault();
            e.stopPropagation();

            const rect = useCaseDescBtn.getBoundingClientRect();
            const text = useCaseDescBtn.dataset.description?.trim() || 'No description provided.';
            document.getElementById('usecaseDescText').textContent = text;

            const currentlyOpen = usecaseDescCard.style.display === 'block' && usecaseDescCard.dataset.anchorId === useCaseDescBtn.closest('tr')?.dataset.id;
            if (currentlyOpen) {
                usecaseDescCard.style.display = 'none';
                usecaseDescCard.dataset.anchorId = '';
                return;
            }

            usecaseDescCard.style.left = `${Math.max(12, rect.left)}px`;
            usecaseDescCard.style.top = `${rect.bottom + 8}px`;
            usecaseDescCard.style.display = 'block';
            usecaseDescCard.dataset.anchorId = useCaseDescBtn.closest('tr')?.dataset.id || '';
            return;
        }

        const textCell = e.target.closest('.editable');
        if (textCell) {
            startEditText(textCell);
            return;
        }

        const selectCell = e.target.closest('.editable-select');
        if (selectCell) {
            startEditSelect(selectCell);
            return;
        }

        const deleteBtn = e.target.closest('.delete-btn');
        if (deleteBtn) {
            const row = deleteBtn.closest('tr');
            const result = await postJson('Delete', { itemId: row.dataset.id });
            notify(result.message, result.success);
            if (result.success) {
                row.remove();
                location.reload();
            }
        }
    });

    let dragged = null;
    rowsBody.querySelectorAll('tr').forEach(row => {
        row.addEventListener('dragstart', () => { dragged = row; });
        row.addEventListener('dragover', (e) => {
            e.preventDefault();
            row.classList.add('drag-over');
        });
        row.addEventListener('dragleave', () => row.classList.remove('drag-over'));
        row.addEventListener('drop', async () => {
            row.classList.remove('drag-over');
            if (!dragged || dragged === row) return;
            row.parentNode.insertBefore(dragged, row.nextSibling);

            const orderedIds = [...rowsBody.querySelectorAll('tr')].map(r => r.dataset.id);
            const payload = {
                projectId: table.dataset.projectId,
                productId: table.dataset.productId || null,
                itemIds: orderedIds
            };
            const result = await postJson('Reorder', payload);
            notify(result.message, result.success);
            if (result.success) {
                location.reload();
            }
        });
    });

    document.addEventListener('click', (e) => {
        if (e.target.closest('.usecase-desc-toggle')) return;
        if (e.target.closest('#usecaseDescCard')) return;
        usecaseDescCard.style.display = 'none';
        usecaseDescCard.dataset.anchorId = '';
    });

    refreshCreateParentOptions();
    toggleAddBulkBtnState();
})();
</script>
}
