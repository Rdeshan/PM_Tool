@page
@using System.Security.Claims
@model TwoFactorModel
@{
    ViewData["Title"] = "Two-Factor Authentication";
}

@if (!User.Identity?.IsAuthenticated ?? true)
{
    <div class="alert alert-warning" role="alert">
        <h4 class="alert-heading">Access Denied</h4>
        <p>You must be logged in to access this page. <a asp-page="/Auth/Login">Login here</a></p>
    </div>
}
else
{
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-3 mb-4">
                <div class="list-group">
                    <a class="list-group-item list-group-item-action" asp-page="./Settings">Account Settings</a>
                    <a class="list-group-item list-group-item-action" asp-page="./Security">Security</a>
                    <a class="list-group-item list-group-item-action active" asp-page="./TwoFactor">Two-Factor Auth</a>
                </div>
            </div>
            <div class="col-md-9">
                <div class="card">
                    <div class="card-header">
                        <h5>Two-Factor Authentication</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                @Model.SuccessMessage
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        <div class="alert alert-info" role="alert">
                            <h6 class="alert-heading">What is Two-Factor Authentication?</h6>
                            <p class="mb-0">Two-factor authentication adds an extra layer of security to your account. In addition to your password, you'll need to enter a code sent to your email whenever you log in.</p>
                        </div>

                        @if (Model.IsTwoFactorEnabled)
                        {
                            <div class="alert alert-success" role="alert">
                                <i class="bi bi-check-circle"></i> Two-Factor Authentication is <strong>ENABLED</strong>
                            </div>

                            <p class="text-muted">Your account is protected with two-factor authentication. Every time you log in, you'll need to enter a code sent to your email.</p>

                            <form method="post">
                                <button type="submit" asp-page-handler="Disable" class="btn btn-warning">Disable Two-Factor Authentication</button>
                            </form>
                        }
                        else
                        {
                            <div class="alert alert-warning" role="alert">
                                <i class="bi bi-exclamation-triangle"></i> Two-Factor Authentication is <strong>DISABLED</strong>
                            </div>

                            <p class="text-muted mb-3">Two-factor authentication is not currently enabled on your account. Click the button below to enable it.</p>

                            <form method="post">
                                <button type="submit" asp-page-handler="Enable" class="btn btn-success">Enable Two-Factor Authentication</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
