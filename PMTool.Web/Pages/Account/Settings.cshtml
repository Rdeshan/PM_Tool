@page
@using System.Security.Claims
@model SettingsModel
@{
    ViewData["Title"] = "Account Settings";
}

@if (!User.Identity?.IsAuthenticated ?? true)
{
    <div class="alert alert-warning" role="alert">
        <h4 class="alert-heading">Access Denied</h4>
        <p>You must be logged in to access this page. <a asp-page="/Auth/Login">Login here</a></p>
    </div>
}
else
{
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-3 mb-4">
                <div class="list-group">
                    <a class="list-group-item list-group-item-action active" asp-page="./Settings">Account Settings</a>
                    <a class="list-group-item list-group-item-action" asp-page="./Security">Security</a>
                    <a class="list-group-item list-group-item-action" asp-page="./TwoFactor">Two-Factor Auth</a>
                </div>
            </div>
            <div class="col-md-9">
                <div class="card">
                    <div class="card-header">
                        <h5>Account Information</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                @Model.SuccessMessage
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-control" value="@User.FindFirst(ClaimTypes.Email)?.Value" disabled />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">First Name</label>
                                <input type="text" class="form-control" value="@Model.FirstName" disabled />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Last Name</label>
                                <input type="text" class="form-control" value="@Model.LastName" disabled />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Member Since</label>
                            <input type="text" class="form-control" value="@Model.CreatedAt.ToString("MMMM dd, yyyy")" disabled />
                        </div>
                    </div>
                </div>

                <div class="card mt-3">
                    <div class="card-header bg-danger">
                        <h5 class="text-white mb-0">Danger Zone</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Once you delete your account, there is no going back. Please be certain.</p>
                        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
                            Delete Account
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger">
                    <h5 class="modal-title text-white" id="deleteAccountLabel">Delete Account?</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>This action cannot be undone. All your data will be permanently deleted.</p>
                    <p class="text-danger fw-bold">Type your email to confirm:</p>
                    <input type="email" id="confirmEmail" class="form-control" placeholder="@User.FindFirst(ClaimTypes.Email)?.Value" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" onclick="confirmDelete()">Delete My Account</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function confirmDelete() {
            const confirmEmail = document.getElementById('confirmEmail').value;
            const userEmail = '@User.FindFirst(ClaimTypes.Email)?.Value';
            
            if (confirmEmail === userEmail) {
                // TODO: Implement account deletion
                alert('Account deletion not yet implemented');
            } else {
                alert('Email does not match');
            }
        }
    </script>
}
