function toggleCreateCal(e) {
    if (e) e.stopPropagation();
    const panel = document.getElementById('createCalPanel');
    const wasOpen = panel.classList.contains('open');
    closeDds();
    if (!wasOpen) { panel.classList.add('open'); renderCreateCal(); }
}

function renderCreateCal() {
    const panel = document.getElementById('createCalPanel');
    const y = createCalView.getFullYear(), m = createCalView.getMonth();
    const fd = new Date(y, m, 1).getDay();
    const dim = new Date(y, m + 1, 0).getDate();
    const today = new Date();
    let h = `<div class="cal-nav">
        <button onclick="shiftCreateCal(-1);event.stopPropagation()">&#8249;</button>
        <span>${MONTHS[m]} ${y}</span>
        <button onclick="shiftCreateCal(1);event.stopPropagation()">&#8250;</button>
    </div><div class="cal-grid">`;
    WDAYS.forEach(d => h += `<div class="cal-dh">${d}</div>`);
    for (let i = 0; i < fd; i++) h += `<div class="cal-d empty"></div>`;
    for (let d = 1; d <= dim; d++) {
        const isT = today.getFullYear()===y && today.getMonth()===m && today.getDate()===d;
        const isS = createDate && createDate.getFullYear()===y && createDate.getMonth()===m && createDate.getDate()===d;
        h += `<div class="cal-d ${isS?'sel':isT?'today':''}" onclick="pickCreateDate(${y},${m},${d});event.stopPropagation()">${d}</div>`;
    }
    h += '</div>';
    panel.innerHTML = h;
}

function shiftCreateCal(dir) {
    createCalView = new Date(createCalView.getFullYear(), createCalView.getMonth() + dir, 1);
    renderCreateCal();
}

function pickCreateDate(y, m, d) {
    createDate = new Date(y, m, d);
    const fmt = `${SMON[m]} ${d}`;
    document.getElementById('createDateLabel').textContent = fmt;
    const iso = `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    document.getElementById('hiddenDueDate').value = iso;
    closeDds();
    renderCreateCal();
}

// ─── Row: Title inline edit ───────────────────────────────────────────────────
function editTitle(itemId, current) {
    const cell = document.getElementById('titleCell_' + itemId);
    if (!cell) return;
    const shortId = cell.querySelector('.badge-id').outerHTML;
    
    cell.innerHTML = `${shortId}<input class="title-input" type="text" value="${current}" 
        id="titleInput_${itemId}"
        onblur="saveTitle('${itemId}', this.value, '${current}')"
        onkeydown="if(event.key==='Enter')this.blur();if(event.key==='Escape'){ this.dataset.cancel='true'; this.blur(); }" />`;
    const inp = document.getElementById('titleInput_' + itemId);
    if (inp) { inp.focus(); inp.select(); }
}

function saveTitle(itemId, val, original) {
    const inp = document.getElementById('titleInput_' + itemId);
    if (inp && inp.dataset.cancel === 'true') {
        renderTitleCell(itemId, original);
        return;
    }

    const title = val.trim();
    if (title === '' || title === original) {
        renderTitleCell(itemId, original);
        return;
    }

    fetch('?handler=UpdateTitle', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': getToken()
        },
        body: `itemId=${itemId}&title=${encodeURIComponent(title)}`
    }).then(r => {
        if (r.ok) {
            renderTitleCell(itemId, title);
            const row = document.getElementById('row-' + itemId);
            if (row) row.dataset.itemTitle = title;
            if (currentBacklogId === itemId) {
                document.getElementById('sidebarTaskTitle').textContent = title;
            }
            showToast('Title updated', 'Item title has been changed.');
        } else {
            renderTitleCell(itemId, original);
        }
    }).catch(() => {
        renderTitleCell(itemId, original);
    });
}

function renderTitleCell(itemId, title) {
    const cell = document.getElementById('titleCell_' + itemId);
    if (!cell) return;
    
    // We need the shortId. We can get it from the badge-id class if it still exists or reconstruct it.
    // Easiest is to reload if complicated, but let's try to keep it smooth.
    const badge = cell.querySelector('.badge-id');
    const shortIdHtml = badge ? badge.outerHTML : ''; 

    const shortIdText = cell.querySelector('.badge-id')?.textContent || '';
    const titleArg = JSON.stringify(title);

    cell.innerHTML = `${shortIdHtml}
        <a href="#" class="title-link" onclick="openProductSidebar('${itemId}', ${titleArg}, '${shortIdText}', false, event)">${title}</a>
        <button type="button" class="subtask-add-btn" onclick="openProductSidebar('${itemId}', ${titleArg}, '${shortIdText}', true, event)" title="Add subtask">
            <i class="bi bi-plus-lg"></i>
        </button>
        <span class="edit-title-btn" onclick="editTitle('${itemId}', '${title.replace(/'/g, "\\'")}')" title="Edit title">
            <i class="bi bi-pencil" style="font-size:10px;"></i>
        </span>`;
}

// ─── Row: Points inline edit ──────────────────────────────────────────────────
function toggleSubtaskForm(itemId, e, forceClose) {
    if (e) {
        e.preventDefault();
        e.stopPropagation();
    }

    const form = document.getElementById('subtaskForm_' + itemId);
    const input = document.getElementById('subtaskInput_' + itemId);
    if (!form) return;

    if (forceClose || !form.classList.contains('d-none')) {
        form.classList.add('d-none');
        if (input) input.value = '';
        return;
    }

    form.classList.remove('d-none');
    if (input) input.focus();
}

async function createSubtask(itemId, e) {
    if (e) {
        e.preventDefault();
        e.stopPropagation();
    }

    const input = document.getElementById('subtaskInput_' + itemId);
    const title = input?.value.trim();
    if (!title) return;

    const resp = await fetch('?handler=Subtask', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': getToken()
        },
        body: JSON.stringify({
            parentId: itemId,
            title,
            priority: 3,
            status: 1
        })
    });

    const result = await resp.json().catch(() => ({ success: false }));
    if (!result.success) {
        showToast(result.message || 'Failed to add subtask', 'danger');
        return;
    }

    appendSubtaskToRow(itemId, result.subtask);

    updateSubtaskCount(itemId);
    if (currentBacklogId === itemId) renderSidebarSubtasks(itemId);
    toggleSubtaskForm(itemId, e, true);
    showToast('Subtask added', 'success');
}

async function updateProductSubtaskStatus(subtaskId, status, e) {
    if (e) e.stopPropagation();

    const select = e?.target;
    const previousStatus = select ? parseInt(select.dataset.previousStatus || '0') || status : status;
    if (select) select.dataset.previousStatus = select.value;

    const label = select?.closest('.product-subtask, .sidebar-subtask');
    if (label) {
        label.classList.toggle('done', status === 3);
        label.dataset.subtaskStatus = status.toString();
    }
    if (select) applyStatusSelectStyle(select, status);

    const resp = await fetch('?handler=UpdateSubtaskStatus', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': getToken()
        },
        body: JSON.stringify({ subtaskId, status })
    });

    const result = await resp.json().catch(() => ({ success: false }));
    if (!result.success) {
        if (select) {
            select.value = previousStatus.toString();
            applyStatusSelectStyle(select, previousStatus);
        }
        if (label) {
            label.classList.toggle('done', previousStatus === 3);
            label.dataset.subtaskStatus = previousStatus.toString();
        }
        showToast('Failed to update subtask', 'danger');
        return false;
    }

    document.querySelectorAll(`select.subtask-status-select[data-subtask-id="${subtaskId}"]`).forEach(sel => {
        sel.value = status.toString();
        applyStatusSelectStyle(sel, status);
        const subtaskEl = sel.closest('.product-subtask, .sidebar-subtask');
        if (subtaskEl) {
            subtaskEl.classList.toggle('done', status === 3);
            subtaskEl.dataset.subtaskStatus = status.toString();
        }
    });
    return true;
}

function applyStatusSelectStyle(select, status) {
    const bg = status === 1 ? '#dbeafe' : status === 2 ? '#fef3c7' : '#dcfce7';
    const fg = status === 1 ? '#1d4ed8' : status === 2 ? '#92400e' : '#166534';
    select.style.background = bg;
    select.style.color = fg;
}

let currentBacklogId = null;
let currentBacklogTitle = '';
let currentBacklogKey = '';
let currentSidebarTab = 'all';
let currentSidebarComments = [];

function openProductSidebar(id, title, key, focusNewSubtask, e) {
    if (e) {
        e.preventDefault();
        e.stopPropagation();
    }

    currentBacklogId = id;
    currentBacklogTitle = title || '';
    currentBacklogKey = key || '';

    const row = document.getElementById('row-' + id);
    const ds = row?.dataset || {};
    const sprintCard = row?.closest('.sprint-card');
    const sprintName = sprintCard?.querySelector('.sprint-header h6')?.textContent?.trim() || 'Backlog';

    document.getElementById('sidebarTaskTitle').textContent = currentBacklogTitle || 'Subtask';
    document.getElementById('sidebarTaskKey').textContent = currentBacklogKey ? `PB-${currentBacklogKey}` : 'PB';
    document.getElementById('sidebarStatus').value = ds.itemStatus || '1';
    document.getElementById('sidebarDescription').value = ds.itemDescription || '';
    document.getElementById('sidebarAssignee').innerHTML = renderAssigneeValue(ds.itemAssignee || 'Unassigned', ds.itemAssigneeId || '');
    document.getElementById('sidebarDueDate').textContent = formatDate(ds.itemDueDate);
    document.getElementById('sidebarStartDate').textContent = formatDate(ds.itemStartDate);
