    4: { cls: 's-done',     label: 'Done' }
};

// ─── Create bar state ─────────────────────────────────────────────────────────
let createDate = null;
let createCalView = new Date(new Date().getFullYear(), new Date().getMonth(), 1);

// ─── Dropdown helpers ─────────────────────────────────────────────────────────
function closeDds() {
    document.querySelectorAll('.dd-panel, .cal-panel').forEach(el => el.classList.remove('open'));
}

function toggleDd(id, e) {
    if (e) e.stopPropagation();
    const el = document.getElementById(id);
    if (!el) return;
    const wasOpen = el.classList.contains('open');
    closeDds();
    if (!wasOpen) el.classList.add('open');
}

document.addEventListener('click', closeDds);

// ─── Create bar: Type ─────────────────────────────────────────────────────────
function setCreateType(value, key, e) {
    if (e) e.stopPropagation();
    document.getElementById('hiddenType').value = value;
    const iconClass = key || 'bi bi-tag';
    document.getElementById('createTypeIcon').innerHTML = `<i class="${iconClass}"></i>`;
    closeDds();
}

async function submitWorkType() {
    const name = document.getElementById('workTypeName').value.trim();
    const description = document.getElementById('workTypeDescription').value.trim();
    const iconClass = document.getElementById('workTypeIcon').value.trim();
    const btn = document.getElementById('submitWorkTypeBtn');

    if (!name || !iconClass) {
        showToast('Name and icon are required', 'danger');
        return;
    }

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

    try {
        const resp = await fetch('?handler=CreateWorkType', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': getToken()
            },
            body: JSON.stringify({ name, description, iconClass })
        });

        const result = await resp.json();
        if (result.success && result.workType) {
            appendWorkTypeOption(result.workType);
            closeWorkTypeModal();
            showToast('Work type added', 'success');
        } else {
            showToast(result.message || 'Failed to add work type', 'danger');
        }
    } catch (err) {
        showToast('Failed to add work type', 'danger');
    } finally {
        btn.disabled = false;
        btn.innerHTML = 'Add';
    }
}

function appendWorkTypeOption(workType) {
    const iconClass = workType.iconClass || 'bi bi-tag';
    const createOption = document.createElement('div');
    createOption.className = 'dd-item work-type-option';
    createOption.dataset.typeValue = workType.value;
    createOption.dataset.iconClass = iconClass;
    createOption.innerHTML = `<i class="${iconClass}"></i> ${workType.name}`;
    createOption.addEventListener('click', (e) => setCreateType(workType.value, iconClass, e));

    const createDropdown = document.getElementById('createTypeDd');
    const addWorkTypeItem = document.getElementById('addWorkTypeItem');
    if (createDropdown && addWorkTypeItem) {
        createDropdown.insertBefore(createOption, addWorkTypeItem);
    }

    document.querySelectorAll('.type-dropdown').forEach(dropdown => {
        const itemId = dropdown.dataset.itemId;
        if (!itemId) return;
        const option = document.createElement('div');
        option.className = 'dd-item work-type-option';
        option.dataset.typeValue = workType.value;
        option.dataset.iconClass = iconClass;
        option.innerHTML = `<i class="${iconClass}"></i> ${workType.name}`;
        option.addEventListener('click', (e) => updateType(itemId, workType.value, e));

        const addEntry = dropdown.querySelector('.dd-item.text-primary');
        if (addEntry) {
            dropdown.insertBefore(option, addEntry);
        } else {
            dropdown.appendChild(option);
        }
    });
}

// ─── Create bar: Assign ───────────────────────────────────────────────────────
function setCreateOwner(id, name, e) {
    if (e) e.stopPropagation();
    document.getElementById('hiddenOwner').value = id;
    const iconEl = document.getElementById('createAssignIcon');
    if (name) {
        const initials = name.split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();
        iconEl.innerHTML = `<div style="width:20px;height:20px;border-radius:50%;background:#deebff;color:#0747a6;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:600;">${initials}</div>`;
    } else {
        iconEl.innerHTML = `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>`;
