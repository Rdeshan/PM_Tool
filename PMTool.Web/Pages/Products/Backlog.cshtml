@page "{projectId:guid}/{id:guid}/backlog"
@model PMTool.Web.Pages.Products.BacklogModel
@{
    if (Model.IsEmbedded)
    {
        Layout = "_EmbeddedLayout";
    }
    else
    {
        Layout = "_Layout";
    }

    ViewData["Title"] = "Product Backlog";
}

<div class="container-fluid mt-4">
    @if (!Model.IsEmbedded)
    {
        <nav aria-label="breadcrumb" class="mb-3 d-flex justify-content-between align-items-center">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-page="/Projects/Details" asp-route-id="@Model.ProjectId">@Model.ProjectName</a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-page="/Projects/Details" asp-route-id="@Model.ProjectId" asp-route-tab="products">Products</a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-page="./Details" asp-route-projectId="@Model.ProjectId" asp-route-id="@Model.ProductId">@Model.ProductName</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Backlog</li>
            </ol>
            <a asp-page="./Details" asp-route-projectId="@Model.ProjectId" asp-route-id="@Model.ProductId" class="btn btn-sm btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to @Model.ProductName
            </a>
        </nav>
    }

    <div style="background-color: #f5f5f5; padding: 16px; border-radius: 4px;">
        <!-- Backlog Header -->
        <div class="d-flex justify-content-between align-items-center mb-3" style="background-color: white; padding: 12px; border-radius: 4px;">
            <div class="d-flex align-items-center gap-3">
                <div>
                    <h6 class="mb-0 fw-bold">Backlog</h6>
                    <small class="text-muted">(@Model.BacklogItems.Count work items)</small>
                </div>
                <div class="d-flex gap-2 align-items-center ms-3">
                    <span class="badge bg-light text-dark" title="Draft items">@Model.DraftCount</span>
                    <span class="badge bg-primary" title="Approved items">@Model.ApprovedCount</span>
                    <span class="badge bg-light text-dark" title="Other items">@(Model.BacklogItems.Count - Model.DraftCount - Model.ApprovedCount)</span>
                    @if (Model.CanEditBacklog)
                    {
                        <button type="button" class="btn btn-sm btn-link" title="Team members" data-bs-toggle="modal" data-bs-target="#teamModal">
                            <i class="bi bi-people-fill text-primary"></i>
                        </button>
                    }
                </div>
            </div>
            @if (Model.CanEditBacklog)
            {
                <button type="button" class="btn btn-sm btn-primary" id="createSprintBtn">
                    <i class="bi bi-plus-lg"></i> Create sprint
                </button>
            }
        </div>

        <!-- Create Backlog Item Section -->
        @if (Model.CanEditBacklog)
        {
            <div style="background-color: white; padding: 16px; border-radius: 4px; border: 2px solid #e0e0e0; margin-bottom: 16px;">
                <div class="d-flex gap-2 align-items-start">
                    <!-- Type Dropdown -->
                    <div style="flex: 0 0 auto;">
                        <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" title="Select item type">
                            <i class="bi bi-bookmark-fill"></i>
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#" data-type="story">User Story</a></li>
                            <li><a class="dropdown-item" href="#" data-type="task">Task</a></li>
                            <li><a class="dropdown-item" href="#" data-type="bug">Bug</a></li>
                            <li><a class="dropdown-item" href="#" data-type="epic">Epic</a></li>
                        </ul>
                    </div>

                    <!-- Description Input -->
                    <input type="text" class="form-control form-control-sm flex-grow-1" placeholder="Describe what needs to be done, or generate work items from Confluence, Loom, or an image." id="itemDescription" />

                    <!-- Due Date -->
                    <div style="flex: 0 0 auto;">
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="dueDateBtn" title="Set due date">
                            <i class="bi bi-calendar-event"></i>
                        </button>
                    </div>

                    <!-- Team Members Dropdown -->
                    <div style="flex: 0 0 auto;">
                        <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" title="Assign team members">
                            <i class="bi bi-person-plus-fill"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#"><small>Team members will appear here</small></a></li>
                        </ul>
                    </div>

                    <!-- Create Button -->
                    <button type="button" class="btn btn-sm btn-primary" id="createItemBtn" title="Create work item">
                        Create
                        <i class="bi bi-arrow-right"></i>
                    </button>
                </div>
            </div>
        }

        <!-- Backlog Items List -->
        <div style="background-color: white; padding: 16px; border-radius: 4px;">
            @if (Model.BacklogItems.Count == 0)
            {
                <div class="text-center text-muted py-4">
                    <p>Your backlog is empty.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 32px;"><input type="checkbox" id="selectAll" /></th>
                                <th style="width: 36px;"></th>
                                <th>Title</th>
                                <th style="width: 100px;">Type</th>
                                <th style="width: 100px;">Status</th>
                                <th style="width: 100px;">Owner</th>
                                <th style="width: 90px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.BacklogItems.OrderBy(x => x.Priority))
                            {
                                <tr>
                                    <td><input type="checkbox" value="@item.Id" /></td>
                                    <td>
                                        <span class="badge" style="background-color: #d4e6f1;">
                                            @item.Id.ToString("N").Substring(0, 4).ToUpper()
                                        </span>
                                    </td>
                                    <td>
                                        <a href="#" class="text-decoration-none">@item.Title</a>
                                    </td>
                                    <td>
                                        <small class="text-muted">@item.TypeName</small>
                                    </td>
                                    <td>
                                        @{
                                            var statusBadgeClass = item.Status switch
                                            {
                                                1 => "bg-secondary",
                                                2 => "bg-warning",
                                                3 => "bg-info",
                                                4 => "bg-success",
                                                _ => "bg-light text-dark"
                                            };
                                        }
                                        <span class="badge @statusBadgeClass">
                                            @item.StatusName
                                        </span>
                                    </td>
                                    <td>
                                        <small class="text-muted">@item.OwnerName</small>
                                    </td>
                                    <td>
                                        @if (Model.CanEditBacklog)
                                        {
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-link text-muted p-0" type="button" data-bs-toggle="dropdown">
                                                    <i class="bi bi-three-dots-vertical"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                                    <li><a class="dropdown-item" href="#"><i class="bi bi-pencil"></i> Edit</a></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-trash"></i> Delete</a></li>
                                                </ul>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .badge {
        font-size: 0.85rem;
        padding: 4px 8px;
    }

    .dropdown-toggle::after {
        display: none;
    }
</style>

<style>
    .badge {
        font-size: 0.85rem;
        padding: 4px 8px;
    }

    .dropdown-toggle::after {
        display: none;
    }
</style>
