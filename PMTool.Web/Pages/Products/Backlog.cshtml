// ─── Row: Due date calendar ───────────────────────────────────────────────────
const itemCalViews = {};

function toggleItemCal(itemId, e) {
    if (e) e.stopPropagation();
    const panel = document.getElementById('itemCal_' + itemId);
    const wasOpen = panel.classList.contains('open');
    closeDds();
    if (!wasOpen) {
        if (!itemCalViews[itemId]) {
            const stored = panel.dataset.currentDate;
            const d = stored ? new Date(stored + 'T00:00:00') : new Date();
            itemCalViews[itemId] = new Date(d.getFullYear(), d.getMonth(), 1);
        }
        panel.classList.add('open');
        renderItemCal(itemId);
    }
}

function renderItemCal(itemId) {
    const panel = document.getElementById('itemCal_' + itemId);
    const vd = itemCalViews[itemId];
    const y = vd.getFullYear(), m = vd.getMonth();
    const fd = new Date(y, m, 1).getDay();
    const dim = new Date(y, m + 1, 0).getDate();
    const today = new Date();
    const stored = panel.dataset.currentDate;
    const sel = stored ? new Date(stored + 'T00:00:00') : null;

    let h = `<div class="cal-nav">
        <button onclick="shiftItemCal('${itemId}',-1);event.stopPropagation()">&#8249;</button>
        <span>${MONTHS[m]} ${y}</span>
        <button onclick="shiftItemCal('${itemId}',1);event.stopPropagation()">&#8250;</button>
    </div><div class="cal-grid">`;
    WDAYS.forEach(d => h += `<div class="cal-dh">${d}</div>`);
    for (let i = 0; i < fd; i++) h += `<div class="cal-d empty"></div>`;
    for (let d = 1; d <= dim; d++) {
        const isT = today.getFullYear()===y && today.getMonth()===m && today.getDate()===d;
        const isS = sel && sel.getFullYear()===y && sel.getMonth()===m && sel.getDate()===d;
        h += `<div class="cal-d ${isS?'sel':isT?'today':''}" onclick="pickItemDate('${itemId}',${y},${m},${d});event.stopPropagation()">${d}</div>`;
    }
    h += '</div>';
    panel.innerHTML = h;
}

function shiftItemCal(itemId, dir) {
    const vd = itemCalViews[itemId];
    itemCalViews[itemId] = new Date(vd.getFullYear(), vd.getMonth() + dir, 1);
    renderItemCal(itemId);
}
function toggleSprint(id) {

    document.getElementById('sprint_' + id).classList.toggle('collapsed');

}

function pickItemDate(itemId, y, m, d) {
    const dateObj = new Date(y, m, d);
    const iso = `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const fmt = `${SMON[m]} ${d}`;
    const panel = document.getElementById('itemCal_' + itemId);
    panel.dataset.currentDate = iso;
    let lbl = document.getElementById('dateLbl_' + itemId);
    if (lbl) {
        lbl.textContent = fmt;
    } else {
        // Item had no due date — create the label span inside the calendar button
        const calBtn = panel.previousElementSibling;
        if (calBtn) {
            lbl = document.createElement('span');
            lbl.id = 'dateLbl_' + itemId;
            lbl.style.fontSize = '11px';
            lbl.textContent = fmt;
            calBtn.appendChild(lbl);
        }
    }
    const row = document.getElementById('row-' + itemId);
    if (row) row.dataset.itemDueDate = iso;
    if (currentBacklogId === itemId) {
        document.getElementById('sidebarDueDate').textContent = formatDate(iso);
    }
    closeDds();

    fetch('?handler=UpdateDueDate', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': getToken()
        },
        body: `itemId=${itemId}&dueDate=${iso}`
    }).then(r => {
        if (r.ok) {
            signalChange();
        }
    }).catch(() => {});
}

function pickItemDateFromIso(itemId, iso) {
    const [y, m, d] = iso.split('-').map(Number);
    if (!y || !m || !d) return;

    const lbl = document.getElementById('dateLbl_' + itemId);
    if (lbl) lbl.textContent = `${SMON[m - 1]} ${d}`;

    const panel = document.getElementById('itemCal_' + itemId);
    if (panel) panel.dataset.currentDate = iso;

    const row = document.getElementById('row-' + itemId);
    if (row) row.dataset.itemDueDate = iso;
    if (currentBacklogId === itemId) {
        document.getElementById('sidebarDueDate').textContent = formatDate(iso);
    }

    fetch('?handler=UpdateDueDate', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': getToken()
        },
        body: `itemId=${itemId}&dueDate=${iso}`
    }).catch(() => {});
}

// ─── Create form submit ───────────────────────────────────────────────────────
document.getElementById('createBacklogForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('createBtn');
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = `<span class="spinner-border spinner-border-sm"></span>`;

    // Capture the currently selected type icon before the async call clears the form
    const capturedTypeIconHtml = document.getElementById('createTypeIcon').innerHTML;

    try {
        const fd = new FormData(this);
        const resp = await fetch(this.action, {
            method: 'POST',
            body: fd,
            headers: { 'RequestVerificationToken': getToken() }
        });
        const text = await resp.text();
        let result;
        try { result = JSON.parse(text); }
        catch { throw new Error('Server error'); }

        if (result.success) {
            showToast('Item created!', 'success');
            signalChange();
            appendCreatedBacklogItem(result.item, capturedTypeIconHtml);
            document.getElementById('newItemTitle').value = '';
            document.getElementById('hiddenOwner').value = '';
            document.getElementById('hiddenDueDate').value = '';
            createDate = null;
            document.getElementById('createDateLabel').textContent = '';
            document.getElementById('createAssignIcon').innerHTML = `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>`;
        } else {
            showToast(result.message || 'Failed to create item', 'danger');
        }
    } catch (err) {
        showToast('Failed to create item', 'danger');
    } finally {
        btn.disabled = false;
        btn.innerHTML = orig;
    }
});

function appendCreatedBacklogItem(item, typeIconHtml) {
    const body = document.getElementById('backlogTableBody');
    if (!body || !item) return;

    body.querySelector('.drop-placeholder')?.remove();
    const id = item.id;
    const shortId = String(id).replace(/-/g, '').substring(0, 4).toUpperCase();
    const title = item.title || 'Untitled';
    const status = Number(item.status || 1);
    const statusInfo = STATUS_MAP[status] || STATUS_MAP[1];
    const row = document.createElement('tr');
    row.id = `row-${id}`;
    row.dataset.itemId = id;
    row.dataset.status = status.toString();
    row.dataset.itemStatus = status.toString();
    row.dataset.itemTitle = title;
    row.dataset.itemKey = shortId;
    row.dataset.itemDescription = '';
    row.dataset.itemAssignee   = item.ownerName || 'Unassigned';
    row.dataset.itemAssigneeId = item.ownerId   || '';
    row.dataset.itemDueDate    = item.dueDateRaw || '';
    row.dataset.itemStartDate = '';
    row.dataset.itemStoryPoints = String(item.storyPoints || 0);
    row.dataset.itemPriority = String(item.priority || 3);
    row.dataset.itemPriorityLabel = priorityLabel(item.priority || 3);
    row.dataset.itemWorkType = item.typeName || 'Work Item';
    row.dataset.itemCreatedAt = new Date().toISOString();
    const titleArg = JSON.stringify(title);

    // Primary source: server response. Fallback: read from hidden form inputs
    // (they are still set at this point — cleared by the caller AFTER this function returns)
    const ownerId    = item.ownerId    || document.getElementById('hiddenOwner')?.value    || '';
    const dueDateRaw = item.dueDateRaw || document.getElementById('hiddenDueDate')?.value  || '';

    // Resolve owner display name from mentionUsers list when server didn't return it
    const ownerFromList = ownerId ? mentionUsers.find(u => String(u.id) === ownerId) : null;
    const ownerName  = (item.ownerName && item.ownerName !== 'Unassigned')
        ? item.ownerName
        : (ownerFromList?.name || 'Unassigned');

    // Format due date label (e.g. "Jun 30") from ISO date if server didn't return it
    let dueDateLbl = item.dueDate || '';
    if (!dueDateLbl && dueDateRaw) {
        const d = new Date(dueDateRaw + 'T00:00:00');
        if (!isNaN(d.getTime())) dueDateLbl = `${SMON[d.getMonth()]} ${d.getDate()}`;
    }

    // Fix dataset now that we have ownerId / dueDateRaw
    row.dataset.itemAssigneeId = ownerId;
    row.dataset.itemDueDate    = dueDateRaw;
    row.dataset.itemAssignee   = ownerName;

    // Type dropdown — built from the create-bar options already on the page
    const typeOpts = [...document.querySelectorAll('#createTypeDd .dd-item.work-type-option')]
        .map(o => `<div class="dd-item work-type-option" data-type-value="${o.dataset.typeValue}" data-icon-class="${escapeHtml(o.dataset.iconClass||'bi bi-tag')}" onclick="updateType('${id}',${o.dataset.typeValue},event)"><i class="${escapeHtml(o.dataset.iconClass||'bi bi-tag')}"></i> ${escapeHtml(o.textContent.trim())}</div>`)
        .join('');

    // Status dropdown
    const statusDd = `<div class="dd-panel" id="statusDd_${id}">
        <div class="dd-item" onclick="updateStatus('${id}',1,event)"><span class="pill-status s-todo" style="pointer-events:none;font-size:10px;">To do</span></div>
        <div class="dd-item" onclick="updateStatus('${id}',2,event)"><span class="pill-status s-inprog" style="pointer-events:none;font-size:10px;">In progress</span></div>
        <div class="dd-item" onclick="updateStatus('${id}',3,event)"><span class="pill-status s-inreview" style="pointer-events:none;font-size:10px;">In review</span></div>
        <div class="dd-item" onclick="updateStatus('${id}',4,event)"><span class="pill-status s-done" style="pointer-events:none;font-size:10px;">Done</span></div>
    </div>`;

    // Assignee avatar + dropdown
    const avatarHtml = ownerId
        ? `<div class="avatar-circle" style="${avatarStyle(ownerId)}">${getInitials(ownerName)}</div>`
        : `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>`;
    const assignDd = `<div class="dd-panel dd-panel-right" id="assignDd_${id}">
        <div class="dd-item" onclick="updateOwner('${id}','',event)"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg> Unassigned</div>
        ${mentionUsers.map(u => `<div class="dd-item" onclick="updateOwner('${id}','${u.id}',event)"><div class="avatar-circle" style="${avatarStyle(String(u.id))}">${getInitials(u.name)}</div> ${escapeHtml(u.name)}</div>`).join('')}
    </div>`;

    // Due date
    const dateLabel = dueDateLbl ? `<span style="font-size:11px;" id="dateLbl_${id}">${escapeHtml(dueDateLbl)}</span>` : '';

    row.innerHTML = `
        <td><input type="checkbox" value="${id}" /></td>
        <td>
            <div class="rel d-inline-flex align-items-center">
                <button type="button" class="ib" onclick="toggleDd('typeDd_${id}',event)" title="${escapeHtml(item.typeName||'Work Item')}">${typeIconHtml||'<i class="bi bi-tag"></i>'}</button>
                <div class="dd-panel type-dropdown" id="typeDd_${id}" data-item-id="${id}">
                    ${typeOpts}
                    <div class="dd-item text-primary" onclick="openWorkTypeModal(event)"><i class="bi bi-plus-circle"></i> Add work type</div>
                </div>
            </div>
        </td>
        <td>
            <div class="item-title-stack">
                <div class="d-flex align-items-center gap-2" id="titleCell_${id}">
                    <span class="badge-id">${shortId}</span>
                    <a href="#" class="title-link" onclick='openProductSidebar("${id}",${titleArg},"${shortId}",false,event)'>${escapeHtml(title)}</a>
                    <button type="button" class="subtask-add-btn" onclick='openProductSidebar("${id}",${titleArg},"${shortId}",true,event)' title="Add subtask"><i class="bi bi-plus-lg"></i></button>
                    <span class="edit-title-btn" onclick='editTitle("${id}",${titleArg})' title="Edit title"><i class="bi bi-pencil" style="font-size:10px;"></i></span>
                </div>
                <div class="product-subtasks d-none" id="subtaskList_${id}" style="display:none!important;"></div>
            </div>
        </td>
        <td style="text-align:center;">
            <div class="rel d-inline-flex">
                <button type="button" class="subproj-btn" onclick="toggleDd('subProjDd_${id}',event)" style="margin-left:0;"><i class="bi bi-plus"></i> Subprojects</button>
                <div class="dd-panel" id="subProjDd_${id}"><div class="dd-item text-muted">No sub-projects available</div></div>
            </div>
        </td>
        <td>
            <div class="rel">
                <button type="button" class="pill-status ${statusInfo.cls}" data-status="${status}" onclick="toggleDd('statusDd_${id}',event)">${statusInfo.label}</button>
                ${statusDd}
            </div>
        </td>
        <td>
            <div class="rel">
                <button type="button" class="ib" onclick="toggleDd('assignDd_${id}',event)" title="${escapeHtml(ownerName)}">${avatarHtml}</button>
                ${assignDd}
            </div>
        </td>
        <td>
            <div id="ptsCell_${id}">
                <button type="button" class="ib" onclick="editPoints('${id}',0)" title="Add story points">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="6" y1="1" x2="6" y2="11"/><line x1="1" y1="6" x2="11" y2="6"/></svg>
                </button>
            </div>
        </td>
        <td>
            <div class="rel">
                <button type="button" class="ib" onclick="toggleItemCal('${id}',event)" title="${dueDateLbl||'Set due date'}">
                    <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="1" y="3" width="14" height="12" rx="2"/><path d="M5 1v4M11 1v4M1 7h14" stroke-linecap="round"/></svg>
                    ${dateLabel}
                </button>
                <div class="cal-panel" id="itemCal_${id}" data-current-date="${dueDateRaw}"></div>
            </div>
        </td>
        <td>
            <div class="dropdown">
                <button class="ib" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-three-dots-vertical" style="font-size:13px;"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="font-size:12px;min-width:140px;">
                    <li><a class="dropdown-item" href="#"><i class="bi bi-pencil me-2"></i>Edit</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <button type="button" class="dropdown-item text-danger" onclick="deleteBacklogItem('${id}',event)">
                            <i class="bi bi-trash me-2"></i>Delete
                        </button>
                    </li>
                </ul>
            </div>
        </td>`;
    body.appendChild(row);
    updateBacklogStats();
}

// ─── Toast ────────────────────────────────────────────────────────────────────
function showToast(message, type = 'success') {
    const el = document.getElementById('liveToast');
    document.getElementById('toastMessage').textContent = message;
    document.getElementById('toastTitle').textContent = type === 'danger' ? 'Error' : 'Success';
    el.className = `toast align-items-center text-white bg-${type} border-0`;
    new bootstrap.Toast(el).show();
}

// ─── Token helper ─────────────────────────────────────────────────────────────
function getToken() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
}

function signalChange() {
    window.dispatchEvent(new CustomEvent('backlog:updated', { detail: { at: Date.now() } }));
}

// ─── Select all checkbox ──────────────────────────────────────────────────────
const selectAll = document.getElementById('selectAll');
if (selectAll) {
    selectAll.addEventListener('change', function() {
        document.querySelectorAll('#backlogTableBody input[type=checkbox]')
            .forEach(cb => cb.checked = this.checked);
    });
}
