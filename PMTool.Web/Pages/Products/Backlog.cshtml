}

function closeProductSidebar() {
    document.getElementById('productSubtaskSidebar').classList.add('d-none');
    hideSubtaskInput();
}

function setSidebarTab(tab, e) {
    if (e) e.preventDefault();
    currentSidebarTab = tab;
    document.querySelectorAll('.sidebar-tab').forEach(btn => {
        btn.classList.toggle('active', btn.textContent.trim().toLowerCase() === tab);
    });

    const panel = document.getElementById('sidebarActivity');
    if (tab === 'comments') {
        loadSidebarComments(currentBacklogId);
        return;
    }

    if (tab === 'history') {
        panel.textContent = 'No history yet.';
        return;
    }

    renderComments(currentSidebarComments);
}

async function loadSidebarComments(itemId) {
    const panel = document.getElementById('sidebarActivity');
    if (!itemId) {
        panel.textContent = 'No comments yet.';
        return;
    }

    panel.textContent = 'Loading comments...';
    const resp = await fetch(`?handler=Comments&itemId=${itemId}`, {
        headers: { 'Accept': 'application/json' }
    });
    const result = await resp.json().catch(() => ({ success: false, comments: [] }));
    currentSidebarComments = result.success ? result.comments : [];
    renderComments(currentSidebarComments);
}

function renderComments(comments) {
    const panel = document.getElementById('sidebarActivity');
    if (!comments || comments.length === 0) {
        panel.innerHTML = '<div style="font-size:12px;color:#6b778c;padding:8px 0;">No comments yet.</div>';
        return;
    }

    panel.innerHTML = comments.map(comment => `
        <div class="sidebar-comment" id="comment_${comment.id}">
            <div class="avatar-circle" style="${avatarStyle(comment.authorName)}">${escapeHtml(comment.authorInitials || getInitials(comment.authorName))}</div>
            <div class="comment-body-wrap">
                <div class="comment-meta">
                    <span class="comment-author">${escapeHtml(comment.authorName)}</span>
                    <span class="comment-time">${timeAgo(comment.createdAt)}</span>
                    ${comment.isOwn ? `
                        <span class="comment-actions">
                            <button type="button" class="ib" onclick="startEditComment('${comment.id}', '${escapeJs(comment.body)}')" title="Edit comment"><i class="bi bi-pencil"></i></button>
                            <button type="button" class="ib text-danger" onclick="deleteComment('${comment.id}')" title="Delete comment"><i class="bi bi-trash"></i></button>
                        </span>` : ''}
                </div>
                <div class="comment-body" id="commentBody_${comment.id}">${escapeHtml(comment.body)}</div>
            </div>
        </div>`).join('');
}

const mentionUsers = @Html.Raw(JsonSerializer.Serialize(
    Model.ActiveUsers.Select(u => new
    {
        id = u.Id,
        name = string.IsNullOrWhiteSpace(u.DisplayName)
            ? (string.IsNullOrWhiteSpace($"{u.FirstName} {u.LastName}".Trim()) ? u.Email : $"{u.FirstName} {u.LastName}".Trim())
            : u.DisplayName
    }),
    new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }));

let mentionAnchorIndex = -1;

function escapeRegex(value) {
    return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function toggleMentionList(open) {
    const list = document.getElementById('sidebarMentionList');
    if (!list) return;
    list.classList.toggle('open', open);
}

function getMentionQuery(input) {
    const cursor = input.selectionStart ?? input.value.length;
    const text = input.value.slice(0, cursor);
    const atIndex = text.lastIndexOf('@@');
    if (atIndex < 0) return null;

    const fragment = text.slice(atIndex + 1);
    if (fragment.includes(' ') || fragment.includes('\n')) return null;

    mentionAnchorIndex = atIndex;
    return fragment;
}

function buildMentionList(query) {
    const list = document.getElementById('sidebarMentionList');
    if (!list) return;
    list.innerHTML = '';

    const normalized = query.toLowerCase();
    const allowAll = normalized.length === 0 || 'all'.startsWith(normalized);
    if (allowAll) {
        const item = document.createElement('div');
        item.className = 'mention-item';
        item.dataset.mentionValue = 'All';
        item.innerHTML = '<strong>@@All</strong><span class="mention-hint">Notify everyone</span>';
        list.appendChild(item);
    }

    mentionUsers
        .filter(u => u.name.toLowerCase().includes(normalized))
        .slice(0, 12)
        .forEach(u => {
            const item = document.createElement('div');
            item.className = 'mention-item';
            item.dataset.mentionValue = u.name;
            item.dataset.mentionId = u.id;
            item.textContent = `@@${u.name}`;
            list.appendChild(item);
        });

    toggleMentionList(list.children.length > 0);
}

function applyMentionSelection(input, name) {
    const cursor = input.selectionStart ?? input.value.length;
    if (mentionAnchorIndex < 0) return;
    const before = input.value.slice(0, mentionAnchorIndex);
    const after = input.value.slice(cursor);
    const insert = `@@${name} `;
    input.value = `${before}${insert}${after}`;
    const newCursor = before.length + insert.length;
    input.setSelectionRange(newCursor, newCursor);
    mentionAnchorIndex = -1;
    toggleMentionList(false);
    input.focus();
}

function initMentionPicker() {
    const input = document.getElementById('sidebarCommentInput');
    const list = document.getElementById('sidebarMentionList');
    if (!input || !list) return;

    input.addEventListener('input', () => {
        const query = getMentionQuery(input);
        if (query === null) {
            toggleMentionList(false);
            return;
        }
        buildMentionList(query);
    });

    input.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            toggleMentionList(false);
        }
    });

    list.addEventListener('mousedown', (e) => {
        const item = e.target.closest('.mention-item');
        if (!item) return;
        e.preventDefault();
        applyMentionSelection(input, item.dataset.mentionValue || item.textContent.replace('@@', '').trim());
    });

    document.addEventListener('click', (e) => {
        if (e.target === input || list.contains(e.target)) return;
        toggleMentionList(false);
    });
}

function getMentionPayload(body) {
    const userIds = new Set();
    let mentionAll = /(^|\s)@@all(?=\s|$|[.,!?])/i.test(body);

    mentionUsers.forEach(u => {
        const regex = new RegExp(`(^|\\s)@@${escapeRegex(u.name)}(?=\\s|$|[.,!?])`, 'i');
        if (regex.test(body)) {
            userIds.add(u.id);
        }
    });

    return { mentionAll, mentionUserIds: Array.from(userIds) };
}

async function addSidebarComment() {
    if (!currentBacklogId) return;

    const input = document.getElementById('sidebarCommentInput');
    const body = input.value.trim();
    if (!body) return;

    const mentionPayload = getMentionPayload(body);

    const resp = await fetch('?handler=AddComment', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': getToken()
        },
        body: JSON.stringify({
            itemId: currentBacklogId,
            body,
            mentionUserIds: mentionPayload.mentionUserIds,
            mentionAll: mentionPayload.mentionAll
        })
    });
    const result = await resp.json().catch(() => ({ success: false }));
    if (!result.success) {
        showToast(result.message || 'Failed to add comment', 'danger');
        return;
    }

    currentSidebarComments.push(result.comment);
    input.value = '';
    toggleMentionList(false);
    renderComments(currentSidebarComments);
}

function startEditComment(commentId, currentBody) {
    const bodyEl = document.getElementById('commentBody_' + commentId);
    if (!bodyEl) return;
    bodyEl.className = 'comment-edit';
    bodyEl.innerHTML = `
        <textarea id="commentEdit_${commentId}">${escapeHtml(currentBody)}</textarea>
        <div class="d-flex gap-2 mt-2">
            <button type="button" class="btn btn-sm btn-primary" onclick="saveEditComment('${commentId}')">Save</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="renderComments(currentSidebarComments)">Cancel</button>
        </div>`;
    document.getElementById('commentEdit_' + commentId)?.focus();
}

async function saveEditComment(commentId) {
    const textarea = document.getElementById('commentEdit_' + commentId);
    const body = textarea?.value.trim();
    if (!body) return;

    const resp = await fetch('?handler=UpdateComment', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': getToken()
        },
        body: JSON.stringify({ commentId, body })
    });
    const result = await resp.json().catch(() => ({ success: false }));
    if (!result.success) {
        showToast(result.message || 'Failed to update comment', 'danger');
        return;
    }

    const comment = currentSidebarComments.find(c => c.id === commentId);
    if (comment) comment.body = body;
    renderComments(currentSidebarComments);
}

async function deleteComment(commentId) {
    if (!confirm('Delete this comment?')) return;

    const resp = await fetch(`?handler=DeleteComment&commentId=${commentId}`, {
        method: 'POST',
        headers: { 'RequestVerificationToken': getToken() }
    });
    const result = await resp.json().catch(() => ({ success: false }));
    if (!result.success) {
        showToast(result.message || 'Failed to delete comment', 'danger');
        return;
    }

    currentSidebarComments = currentSidebarComments.filter(c => c.id !== commentId);
    document.getElementById('comment_' + commentId)?.remove();
    if (currentSidebarComments.length === 0) renderComments(currentSidebarComments);
}

function escapeHtml(value) {
    const div = document.createElement('div');
    div.textContent = value ?? '';
    return div.innerHTML;
}

function escapeJs(str) {
    return (str || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/"/g, '\\"').replace(/\r?\n/g, '\\n');
}

function formatDate(value) {
    if (!value) return '-';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return '-';
    return date.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
}

function timeAgo(dateStr) {
    const date = new Date(dateStr);
    const seconds = Math.max(0, Math.floor((Date.now() - date.getTime()) / 1000));
    if (seconds < 60) return 'now';
    const minutes = Math.floor(seconds / 60);
    if (minutes < 60) return `${minutes}m ago`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}h ago`;
    return `${Math.floor(hours / 24)}d ago`;
}

function getInitials(name) {
    const parts = (name || '?').trim().split(/\s+/).filter(Boolean);
    if (parts.length >= 2) return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
    return (parts[0] || '?').substring(0, 2).toUpperCase();
}

function avatarStyle(seed) {
    const palettes = [
        ['#deebff', '#0747a6'],
        ['#e3fcef', '#006644'],
        ['#fff0b3', '#974f0c'],
        ['#ffebe6', '#bf2600'],
        ['#e6fcff', '#006c8a'],
        ['#f3f0ff', '#403294'],
        ['#fce4ec', '#880e4f']
    ];
    let hash = 0;
    for (const ch of (seed || '')) hash = ((hash << 5) - hash) + ch.charCodeAt(0);
    const [bg, fg] = palettes[Math.abs(hash) % palettes.length];
    return `background:${bg};color:${fg}`;
}

function renderAssigneeValue(name, id) {
    if (!name || name === 'Unassigned') return 'Unassigned';
    return `<span class="avatar-circle" style="${avatarStyle(id || name)}">${getInitials(name)}</span><span>${escapeHtml(name)}</span>`;
}

function priorityLabel(priority) {
    return ({ 1: 'Highest', 2: 'High', 3: 'Medium', 4: 'Low' })[Number(priority)] || 'Medium';
}

function updateSidebarStatus(status) {
    if (!currentBacklogId) return;
    updateStatus(currentBacklogId, Number(status));
    const row = document.getElementById('row-' + currentBacklogId);
    if (row) {
        row.dataset.itemStatus = status;
        row.dataset.itemStatusLabel = STATUS_MAP[status]?.label || 'To do';
        row.dataset.status = status;
    }
}

function saveSidebarDescription() {
    if (!currentBacklogId) return;
    const description = document.getElementById('sidebarDescription').value;
    const row = document.getElementById('row-' + currentBacklogId);
    if (row) row.dataset.itemDescription = description;

    fetch('?handler=UpdateDescription', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': getToken()
        },
        body: `itemId=${currentBacklogId}&description=${encodeURIComponent(description)}`
    }).catch(() => {});
}

let newSubtaskAssigneeId = '';

function showSubtaskInput() {
    const wrap = document.getElementById('newSubtaskWrap');
    const input = document.getElementById('newSubtaskInput');
    wrap.classList.remove('d-none');
    input.focus();
}

function hideSubtaskInput() {
    const wrap = document.getElementById('newSubtaskWrap');
    const input = document.getElementById('newSubtaskInput');
    wrap.classList.add('d-none');
    input.value = '';
    setSubtaskAssignee('', '', null);
}

function setSubtaskAssignee(id, name, e) {
    if (e) e.stopPropagation();
    newSubtaskAssigneeId = id || '';
    const icon = document.getElementById('subtaskAssignIcon');
    const label = document.getElementById('subtaskAssignLabel');
    if (name) {
        const initials = name.trim().split(/\s+/).map(w => w[0]).join('').substring(0, 2).toUpperCase();
        if (icon) icon.innerHTML = `<div style="width:18px;height:18px;border-radius:50%;background:#deebff;color:#0747a6;display:inline-flex;align-items:center;justify-content:center;font-size:8px;font-weight:600;">${initials}</div>`;
        if (label) { label.textContent = name; label.style.color = '#172b4d'; }
    } else {
        if (icon) icon.innerHTML = `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>`;
        if (label) { label.textContent = 'Assignee'; label.style.color = '#6b778c'; }
    }
    closeDds();
}

function renderSidebarSubtasks(itemId) {
    const sidebarList = document.getElementById('sidebarSubtaskList');
    const rowList = document.getElementById('subtaskList_' + itemId);
    sidebarList.innerHTML = '';

    const subtasks = rowList ? [...rowList.querySelectorAll('.product-subtask')] : [];
    if (subtasks.length === 0) {
        sidebarList.innerHTML = '<div class="text-muted small py-2">No subtasks yet.</div>';
        return;
    }

    subtasks.forEach(subtask => {
        const subtaskId = subtask.dataset.subtaskId;
        const title = subtask.dataset.subtaskTitle || subtask.querySelector('span')?.textContent || '';
        const status = parseInt(subtask.dataset.subtaskStatus);
        const priority = parseInt(subtask.dataset.subtaskPriority);
        const assigneeId = subtask.dataset.subtaskAssigneeId || '';
        const assigneeName = subtask.dataset.subtaskAssigneeName || '';
        const doneClass = status === 3 ? ' done' : '';
        const statusBg = status === 1 ? '#dbeafe' : status === 2 ? '#fef3c7' : '#dcfce7';
        const statusFg = status === 1 ? '#1d4ed8' : status === 2 ? '#92400e' : '#166534';

        const assigneeHtml = assigneeName
            ? `<div class="avatar-circle" style="${avatarStyle(assigneeId || assigneeName)};width:20px;height:20px;font-size:8px;flex-shrink:0;" title="${escapeHtml(assigneeName)}">${getInitials(assigneeName)}</div><span style="font-size:11px;color:#172b4d;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:80px;">${escapeHtml(assigneeName)}</span>`
            : `<span style="font-size:11px;color:#aaa;">—</span>`;

        const item = document.createElement('div');
        item.className = `sidebar-subtask product-subtask${doneClass}`;
        item.style.cssText = 'display:flex;align-items:center;gap:8px;width:100%;';
        item.innerHTML = `
            <select class="subtask-status-select" data-subtask-id="${subtaskId}"
                style="flex-shrink:0;border:none;border-radius:4px;padding:2px 6px;font-size:10px;cursor:pointer;font-weight:600;background:${statusBg};color:${statusFg};outline:none;appearance:none;-webkit-appearance:none;"
                onchange="updateProductSubtaskStatus('${subtaskId}', parseInt(this.value), event)">
                <option value="1" ${status===1?'selected':''}>To Do</option>
                <option value="2" ${status===2?'selected':''}>In Progress</option>
                <option value="3" ${status===3?'selected':''}>Done</option>
            </select>
            <span style="flex:1;min-width:0;font-size:12px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escapeHtml(title)}</span>
            <div style="display:flex;align-items:center;gap:4px;flex-shrink:0;">${assigneeHtml}</div>
            <div style="display:flex;align-items:center;gap:2px;flex-shrink:0;margin-left:4px;">
                <button type="button" class="ib" onclick="openEditSubtaskModal('${subtaskId}', '${escapeJs(title)}', ${priority}, '${assigneeId}', ${status}, event)" title="Edit">
                    <i class="bi bi-pencil"></i>
                </button>
                <button type="button" class="ib text-danger" onclick="deleteSubtaskInSidebar('${subtaskId}', event)" title="Delete">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        `;
        sidebarList.appendChild(item);
    });
}

function openEditSubtaskModal(id, title, priority, assigneeId, status, e) {
    if (e) e.stopPropagation();
    document.getElementById('editSubtaskId').value = id;
    document.getElementById('editSubtaskTitle').value = title;
    document.getElementById('editSubtaskAssignee').value = assigneeId || '';
    document.getElementById('editSubtaskModal').style.display = 'flex';
}

function closeEditSubtaskModal() {
    document.getElementById('editSubtaskModal').style.display = 'none';
}

async function submitEditSubtask() {
    const id = document.getElementById('editSubtaskId').value;
    const title = document.getElementById('editSubtaskTitle').value.trim();
    const assigneeSelect = document.getElementById('editSubtaskAssignee');
    const assigneeId = assigneeSelect.value || null;
    const assigneeName = assigneeId ? (assigneeSelect.options[assigneeSelect.selectedIndex]?.text || '') : '';

    // Preserve existing priority and status from the DOM data attributes
    const subtaskEl = document.querySelector(`.product-subtask[data-subtask-id="${id}"]`);
    const priority = parseInt(subtaskEl?.dataset.subtaskPriority || '3');
    const status = parseInt(subtaskEl?.dataset.subtaskStatus || '1');

    if (!title) { showToast('Title is required', 'danger'); return; }

    try {
        const resp = await fetch('?handler=UpdateSubtask', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': getToken()
            },
            body: JSON.stringify({ subtaskId: id, title, priority, assigneeId, status })
        });

        const result = await resp.json();
        if (result.success) {
            updateSubtaskInRow(id, { title, priority, assigneeId, assigneeName, status });
            renderSidebarSubtasks(currentBacklogId);
            closeEditSubtaskModal();
            showToast('Subtask updated', 'success');
        } else {
            showToast('Failed to update subtask', 'danger');
        }
    } catch (err) {
        showToast('An error occurred', 'danger');
    }
}

function updateSubtaskInRow(id, data) {
    const subtaskEl = document.querySelector(`#subtaskList_${data.parentId || currentBacklogId} .product-subtask[data-subtask-id="${id}"]`);
    if (subtaskEl) {
        subtaskEl.dataset.subtaskTitle = data.title;
        subtaskEl.dataset.subtaskPriority = data.priority;
        subtaskEl.dataset.subtaskAssigneeId = data.assigneeId || '';
        subtaskEl.dataset.subtaskAssigneeName = data.assigneeName || '';
        subtaskEl.dataset.subtaskStatus = data.status;
    }
}

async function deleteSubtaskInSidebar(id, e) {
    if (e) e.stopPropagation();
    if (!confirm('Are you sure you want to delete this subtask?')) return;

    try {
        const resp = await fetch(`?handler=DeleteSubtask&subtaskId=${id}`, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': getToken()
            }
        });

        const result = await resp.json();
        if (result.success) {
            const subtaskEl = document.querySelector(`.product-subtask[data-subtask-id="${id}"]`);
            if (subtaskEl) subtaskEl.remove();
            renderSidebarSubtasks(currentBacklogId);
            updateSubtaskCount(currentBacklogId);
            showToast('Subtask deleted', 'success');
        } else {
            showToast('Failed to delete subtask', 'danger');
        }
    } catch (err) {
        showToast('An error occurred', 'danger');
    }
}

async function createSidebarSubtask(e) {
    if (e) {
        e.preventDefault();
        e.stopPropagation();
    }

    if (!currentBacklogId) return;

    const input = document.getElementById('newSubtaskInput');
    const title = input.value.trim();
    if (!title) return;

    const resp = await fetch('?handler=Subtask', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': getToken()
        },
        body: JSON.stringify({
            parentId: currentBacklogId,
            title,
            priority: 3,
            status: 1,
            assigneeId: newSubtaskAssigneeId || null
        })
    });

    const result = await resp.json().catch(() => ({ success: false }));
    if (!result.success) {
        showToast(result.message || 'Failed to add subtask', 'danger');
        return;
    }

    appendSubtaskToRow(currentBacklogId, result.subtask);
    renderSidebarSubtasks(currentBacklogId);
    updateSubtaskCount(currentBacklogId);
    hideSubtaskInput();
    showToast('Subtask added', 'success');
}

function appendSubtaskToRow(itemId, subtask) {
    const list = document.getElementById('subtaskList_' + itemId);
    if (!list) return;

    const label = document.createElement('div');
    label.className = 'product-subtask';
    label.dataset.subtaskId = subtask.id;
    label.dataset.subtaskTitle = subtask.title;
    label.dataset.subtaskStatus = subtask.status;
    label.dataset.subtaskPriority = subtask.priority;
    label.dataset.subtaskAssigneeId = subtask.assigneeId || '';
    label.dataset.subtaskAssigneeName = subtask.assigneeName || '';
    label.innerHTML = `<span>${escapeHtml(subtask.title)}</span>`;
    list.appendChild(label);
}

function updateSubtaskCount(itemId) {
    const list = document.getElementById('subtaskList_' + itemId);
    const cell = document.getElementById('titleCell_' + itemId);
    if (!list || !cell) return;

    const count = list.querySelectorAll('.product-subtask').length;
    let badge = cell.querySelector('.subtask-count');

    if (count === 0) {
        badge?.remove();
        return;
    }

    if (!badge) {
        badge = document.createElement('span');
        badge.className = 'subtask-count';
        badge.innerHTML = '<i class="bi bi-diagram-2"></i> <span class="subtask-count-value"></span> subtasks';
        const addButton = cell.querySelector('.subtask-add-btn');
        cell.insertBefore(badge, addButton);
    }

    badge.title = `${count} subtask(s)`;
    const value = badge.querySelector('.subtask-count-value');
    if (value) value.textContent = count;
}

function editPoints(itemId, current) {
    const cell = document.getElementById('ptsCell_' + itemId);
    if (!cell) return;
    cell.innerHTML = `<input class="pts-input" type="number" min="0" value="${current || ''}" 
        id="ptsInput_${itemId}"
        onblur="savePoints('${itemId}', this.value)"
        onkeydown="if(event.key==='Enter')this.blur();if(event.key==='Escape'){this.blur();}" />`;
    const inp = document.getElementById('ptsInput_' + itemId);
    if (inp) { inp.focus(); inp.select(); }
}

function savePoints(itemId, val) {
    const pts = val.trim() === '' ? 0 : Math.max(0, parseInt(val) || 0);
    fetch('?handler=UpdateStoryPoints', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': getToken()
        },
        body: `itemId=${itemId}&storyPoints=${pts}`
    }).then(r => {
        if (r.ok) {
            signalChange();
            const cell = document.getElementById('ptsCell_' + itemId);
            if (pts > 0) {
                cell.innerHTML = `<span class="pts-val" onclick="editPoints('${itemId}', ${pts})" title="Click to edit">${pts}</span>`;
            } else {
                cell.innerHTML = `<button type="button" class="ib" onclick="editPoints('${itemId}', 0)" title="Add story points">
                     <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="6" y1="1" x2="6" y2="11"/><line x1="1" y1="6" x2="11" y2="6"/></svg>
                </button>`;
            }
            const row = document.getElementById('row-' + itemId);
            if (row) {
                row.dataset.itemStoryPoints = String(pts);
                updatePoints(row.closest('tbody'));
            }
            if (currentBacklogId === itemId) {
                document.getElementById('sidebarStoryPoints').textContent = String(pts);
            }
        }
    }).catch(() => {});
}

// ─── Row: Status update ───────────────────────────────────────────────────────
function updateStatus(itemId, status, e) {
    if (e) e.stopPropagation();
    closeDds();
    const sm = STATUS_MAP[status] ?? { cls: 's-custom', label: 'Custom' };
    const btn = document.querySelector(`#statusDd_${itemId}`);
    if (btn) {
        const pill = btn.previousElementSibling;
        if (pill) {
            pill.className = `pill-status ${sm.cls}`;
            pill.textContent = sm.label;
            pill.dataset.status = status.toString();
        }
    }
    const row = document.querySelector(`tr[data-item-id="${itemId}"]`);
    if (row) {
        row.dataset.status = status.toString();
        row.dataset.itemStatus = status.toString();
        row.dataset.itemStatusLabel = sm.label;
    }
    if (currentBacklogId === itemId) {
        document.getElementById('sidebarStatus').value = status.toString();
    }
    fetch('?handler=UpdateStatus', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': getToken()
        },
        body: `itemId=${itemId}&status=${status}`
    }).then(() => {
        signalChange();
        updateBacklogStats();
    }).catch(() => {});
}

