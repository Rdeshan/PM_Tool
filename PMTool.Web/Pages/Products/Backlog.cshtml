                        }
                        @if (!sprintItems.Any())
                        {
                            <tr class="drop-placeholder text-center" data-placeholder="true">
                                <td colspan="9" class="text-muted small py-3">Drop items here</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="backlog-wrap">

        <!-- Header -->
