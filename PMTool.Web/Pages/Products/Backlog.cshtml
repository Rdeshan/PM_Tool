@Html.AntiForgeryToken()

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
// ─── Constants ────────────────────────────────────────────────────────────────
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const SMON   = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const WDAYS  = ['Su','Mo','Tu','We','Th','Fr','Sa'];

function toggleBacklog() {
    const wrap = document.querySelector('.backlog-wrap');
    wrap.classList.toggle('collapsed');
}

// ── SPRINT MODAL ─────────────────────────────────────────────────────────────
function openCreateSprintModal(e) {
    if(e) e.stopPropagation();
    document.getElementById('createSprintModal').style.display = 'flex';
}
function closeCreateSprintModal() {
    document.getElementById('createSprintModal').style.display = 'none';
}

function openWorkTypeModal(e) {
    if (e) e.stopPropagation();
    closeDds();
    document.getElementById('workTypeModal').style.display = 'flex';
}

function closeWorkTypeModal() {
    document.getElementById('workTypeModal').style.display = 'none';
    document.getElementById('workTypeName').value = '';
    document.getElementById('workTypeDescription').value = '';
    document.getElementById('workTypeIcon').value = '';
}

async function submitCreateSprint() {
    const name = document.getElementById('sprintName').value;
    const start = document.getElementById('sprintStart').value;
    const end = document.getElementById('sprintEnd').value;
    const goal = document.getElementById('sprintGoal').value;
    const btn = document.getElementById('submitSprintBtn');

    if(!name) { showToast('Name is required', 'danger'); return; }

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Creating...';

    try {
        const resp = await fetch(`?handler=CreateSprint`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': getToken()
            },
            body: JSON.stringify({ name, startDate: start, endDate: end, goal })
        });

        const result = await resp.json();
        if(result.success) {
            showToast('Sprint created successfully');
            appendSprintCard(result.sprint);
            closeCreateSprintModal();
            // Reset modal fields for next use
            document.getElementById('sprintName').value  = '';
            document.getElementById('sprintGoal').value  = '';
            const today = new Date().toISOString().substring(0, 10);
            const twoWeeks = new Date(Date.now() + 14 * 86400000).toISOString().substring(0, 10);
            document.getElementById('sprintStart').value = today;
            document.getElementById('sprintEnd').value   = twoWeeks;
        } else {
            showToast(result.message || 'Failed to create sprint', 'danger');
        }
    } catch(err) {
        showToast('An error occurred', 'danger');
    } finally {
        btn.disabled = false;
        btn.innerHTML = 'Create';
    }
}

// ── START SPRINT MODAL ───────────────────────────────────────────────────────
function openStartSprintModal(id, name, startDate, endDate, goal) {
    document.getElementById('startSprintId').value    = id;
    document.getElementById('startSprintName').value  = decodeURIComponent(name.replace(/\+/g,' '));
    document.getElementById('startSprintStart').value = startDate;
    document.getElementById('startSprintEnd').value   = endDate;
    document.getElementById('startSprintGoal').value  = decodeURIComponent(goal.replace(/\+/g,' '));
    document.getElementById('startSprintModal').style.display = 'flex';
}
function closeStartSprintModal() {
    document.getElementById('startSprintModal').style.display = 'none';
}

async function submitStartSprint() {
    const id    = document.getElementById('startSprintId').value;
    const start = document.getElementById('startSprintStart').value;
    const end   = document.getElementById('startSprintEnd').value;
    const btn   = document.getElementById('submitStartSprintBtn');

    if (!start || !end) { showToast('Please set start and end dates', 'danger'); return; }
    if (new Date(end) <= new Date(start)) { showToast('End date must be after start date', 'danger'); return; }

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Starting...';

    try {
        const resp = await fetch('?handler=StartSprint', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': getToken()
            },
            body: JSON.stringify({ sprintId: id, startDate: start, endDate: end })
        });
        const result = await resp.json();
        if (result.success) {
            closeStartSprintModal();
            showToast('Sprint started! Navigating to Board...');
            setTimeout(() => window.location.href = result.boardUrl, 800);
        } else {
            showToast(result.message || 'Failed to start sprint', 'danger');
        }
    } catch (err) {
        showToast('An error occurred', 'danger');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-play-fill me-1"></i>Start';
    }
}

async function completeSprint(id) {
    if (!confirm('Complete this sprint? All remaining items will stay in the sprint.')) return;
    try {
        const resp = await fetch(`?handler=CompleteSprint&sprintId=${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': getToken() }
        });
        const result = await resp.json();
        if (result.success) {
            showToast('Sprint completed!');
            const card = document.getElementById('sprint_' + id);
            card?.querySelectorAll('.badge.bg-success').forEach(x => x.remove());
            document.getElementById('completeSprintBtn_' + id)?.remove();
        } else {
            showToast('Failed to complete sprint', 'danger');
        }
    } catch (err) {
        showToast('An error occurred', 'danger');
    }
}

async function deleteSprint(id) {
    if(!confirm('Are you sure? Items will be moved back to backlog.')) return;

    const resp = await fetch(`?handler=DeleteSprint&sprintId=${id}`, {
        method: 'POST',
        headers: { 'RequestVerificationToken': getToken() }
    });
    if((await resp.json()).success) {
        const card = document.getElementById('sprint_' + id);
        const backlog = document.getElementById('backlogTableBody');
        card?.querySelectorAll('tbody tr[data-item-id]').forEach(row => backlog?.appendChild(row));
        card?.remove();
        updateBacklogStats();
        updateDropPlaceholders();
    }
}

function appendSprintCard(sprint) {
    const backlogWrap = document.querySelector('.backlog-wrap');
    if (!backlogWrap || !sprint) return;

    const id        = sprint.id        || sprint.Id;
    const name      = sprint.name      || sprint.Name      || 'Sprint';
    const startDate = sprint.startDate || sprint.StartDate || '';
    const endDate   = sprint.endDate   || sprint.EndDate   || '';
    const goal      = sprint.goal      || sprint.Goal      || '';

    // Format dates for display (e.g. "Jun 3 - Jun 17, 2026")
    function fmtDate(d) {
        if (!d) return '';
        const dt = new Date(d);
        return dt.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }
    function fmtDateFull(d) {
        if (!d) return '';
        const dt = new Date(d);
        return dt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    }
    function fmtIso(d) {
        if (!d) return '';
        return new Date(d).toISOString().substring(0, 10);
    }

    const dateRange = (startDate && endDate)
        ? `${fmtDate(startDate)} – ${fmtDateFull(endDate)}`
        : '';

    // Check whether there is already an active sprint (status==2 card present)
    const hasActive = !!document.querySelector('.sprint-card .badge.bg-success');
    const startBtnDisabled = hasActive ? 'disabled' : '';

    // Encode name and goal for safe inline onclick attribute usage
    const encodedName = encodeURIComponent(name);
    const encodedGoal = encodeURIComponent(goal);

    const goalHtml = goal
        ? `<div class="px-2 mb-2 sprint-goal">Goal: ${escapeHtml(goal)}</div>`
        : '';

    const card = document.createElement('div');
    card.className = 'sprint-card';
    card.id = `sprint_${id}`;
    card.innerHTML = `
        <div class="sprint-header" onclick="toggleSprint('${id}')">
            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-chevron-down chevron-toggle"></i>
                <div>
                    <div class="d-flex align-items-center gap-2">
                        <h6 class="mb-0 fw-bold" style="font-size:14px;">${escapeHtml(name)}</h6>
                    </div>
                    <div class="sprint-meta">
                        <span>${dateRange}</span>
                        <span class="capacity-indicator">
                            <i class="bi bi-lightning-charge-fill" style="color:#0052cc"></i>
                            <span class="pts-sum">0</span> pts
                        </span>
                    </div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2" onclick="event.stopPropagation()">
                <button class="btn btn-sm btn-link text-muted" onclick="deleteSprint('${id}')" title="Delete sprint">
                    <i class="bi bi-trash"></i>
                </button>
                <button class="btn btn-sm btn-primary"
                        onclick="openStartSprintModal('${id}','${encodedName}','${fmtIso(startDate)}','${fmtIso(endDate)}','${encodedGoal}')"
                        id="startSprintBtn_${id}"
                        ${startBtnDisabled}>
                    Start sprint
                </button>
            </div>
        </div>
        ${goalHtml}
        <div class="sprint-table-wrap">
            <table class="table-backlog mb-0">
                <colgroup>
                    <col style="width:32px;" />
                    <col style="width:28px;" />
                    <col />
                    <col style="width:35%;" />
                    <col style="width:110px;" />
                    <col style="width:80px;" />
                    <col style="width:64px;" />
                    <col style="width:95px;" />
                    <col style="width:36px;" />
                </colgroup>
                <tbody class="sprint-drop-zone" data-sprint-id="${id}">
                    <tr class="drop-placeholder text-center" data-placeholder="true">
                        <td colspan="9" class="text-muted small py-3">Drop items here</td>
                    </tr>
                </tbody>
            </table>
        </div>`;
    backlogWrap.parentNode.insertBefore(card, backlogWrap);
    initDropZone(card.querySelector('.sprint-drop-zone'));
}

function updateBacklogStats() {
    const backlogZone = document.getElementById('backlogTableBody');
    if (!backlogZone) return;

    const totalCountEl = document.getElementById('backlogTotalCount');
    const availableCountEl = document.getElementById('backlogAvailableCount');
    const todoCountEl = document.getElementById('backlogTodoCount');
    const inProgressCountEl = document.getElementById('backlogInProgressCount');
    const inReviewCountEl = document.getElementById('backlogInReviewCount');

    const backlogRows = [...backlogZone.querySelectorAll('tr[data-item-id]')];
    const totalRows = document.querySelectorAll('.sprint-drop-zone tr[data-item-id]').length;

    if (totalCountEl) totalCountEl.textContent = totalRows.toString();
    if (availableCountEl) availableCountEl.textContent = backlogRows.length.toString();

    let todo = 0;
    let inProgress = 0;
    let inReview = 0;

    backlogRows.forEach(row => {
        const status = row.querySelector('.pill-status');
        if (!status) return;
        if (status.classList.contains('s-todo')) todo += 1;
        if (status.classList.contains('s-inprog')) inProgress += 1;
        if (status.classList.contains('s-inreview')) inReview += 1;
    });

    if (todoCountEl) todoCountEl.textContent = todo.toString();
    if (inProgressCountEl) inProgressCountEl.textContent = inProgress.toString();
    if (inReviewCountEl) inReviewCountEl.textContent = inReview.toString();
}

function updateDropPlaceholders() {
    const zones = document.querySelectorAll('.sprint-drop-zone');
    zones.forEach(zone => {
        const items = [...zone.querySelectorAll('tr')].filter(row => !row.classList.contains('drop-placeholder'));
        const placeholder = zone.querySelector('.drop-placeholder');

        if (items.length === 0) {
            if (!placeholder) {
                const row = document.createElement('tr');
                row.className = 'drop-placeholder text-center';
                row.dataset.placeholder = 'true';
                row.innerHTML = '<td colspan="9" class="text-muted small py-3">Drop items here</td>';
                zone.appendChild(row);
            }
        } else if (placeholder) {
            placeholder.remove();
        }
    });
}

// ── DRAG AND DROP ────────────────────────────────────────────────────────────
function initDropZone(zone) {
    if (!window.Sortable || !zone) return;
    new Sortable(zone, {
        group: 'backlog',
        animation: 150,
        ghostClass: 'sortable-ghost',
        chosenClass: 'sortable-chosen',
        filter: '.drop-placeholder',
        onEnd: async function(evt) {
            if (evt.from === evt.to) return;

            const itemId = evt.item.dataset.itemId;
            const newSprintId = evt.to.dataset.sprintId || '';

            try {
                const resp = await fetch(`?handler=MoveToSprint&itemId=${itemId}&sprintId=${newSprintId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': getToken(),
                        'Accept': 'application/json'
                    }
                });

                if (!resp.ok) throw new Error('Network response was not ok');

                const result = await resp.json();
                if (result.success) {
                    showToast('Moved successfully');
                    signalChange();
                    updatePoints(evt.from);
                    updatePoints(evt.to);
                    updateBacklogStats();
                    updateDropPlaceholders();
                } else {
                    throw new Error('Server returned false');
                }
            } catch(e) {
                showToast('Failed to move item', 'danger');
                if (evt.from.children.length > evt.oldIndex) {
                    evt.from.insertBefore(evt.item, evt.from.children[evt.oldIndex]);
                } else {
                    evt.from.appendChild(evt.item);
                }
                updateDropPlaceholders();
            }
        }
    });
}

document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.sprint-drop-zone').forEach(initDropZone);

    updateBacklogStats();
    updateDropPlaceholders();
    initMentionPicker();
});

function updatePoints(container) {
    if(!container) return;
    let total = 0;
    container.querySelectorAll('tr').forEach(tr => {
        const pts = parseInt(tr.querySelector('.pts-pill')?.textContent) || 0;
        total += pts;
    });
    
    // Find parent sprint-card and updatepts-sum
    const card = container.closest('.sprint-card');
    if(card) {
        const ptsSpan = card.querySelector('.pts-sum');
        if(ptsSpan) ptsSpan.textContent = total;
    }
}

