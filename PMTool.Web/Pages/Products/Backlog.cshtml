// ─── Create bar: Calendar ─────────────────────────────────────────────────────
function toggleCreateCal(e) {
    if (e) e.stopPropagation();
    const panel = document.getElementById('createCalPanel');
    const wasOpen = panel.classList.contains('open');
    closeDds();
    if (!wasOpen) { panel.classList.add('open'); renderCreateCal(); }
}

function renderCreateCal() {
    const panel = document.getElementById('createCalPanel');
    const y = createCalView.getFullYear(), m = createCalView.getMonth();
    const fd = new Date(y, m, 1).getDay();
    const dim = new Date(y, m + 1, 0).getDate();
    const today = new Date();
    let h = `<div class="cal-nav">
        <button onclick="shiftCreateCal(-1);event.stopPropagation()">&#8249;</button>
        <span>${MONTHS[m]} ${y}</span>
        <button onclick="shiftCreateCal(1);event.stopPropagation()">&#8250;</button>
    </div><div class="cal-grid">`;
    WDAYS.forEach(d => h += `<div class="cal-dh">${d}</div>`);
    for (let i = 0; i < fd; i++) h += `<div class="cal-d empty"></div>`;
    for (let d = 1; d <= dim; d++) {
        const isT = today.getFullYear()===y && today.getMonth()===m && today.getDate()===d;
        const isS = createDate && createDate.getFullYear()===y && createDate.getMonth()===m && createDate.getDate()===d;
        h += `<div class="cal-d ${isS?'sel':isT?'today':''}" onclick="pickCreateDate(${y},${m},${d});event.stopPropagation()">${d}</div>`;
    }
    h += '</div>';
    panel.innerHTML = h;
}

function shiftCreateCal(dir) {
    createCalView = new Date(createCalView.getFullYear(), createCalView.getMonth() + dir, 1);
    renderCreateCal();
}

function pickCreateDate(y, m, d) {
    createDate = new Date(y, m, d);
    const fmt = `${SMON[m]} ${d}`;
    document.getElementById('createDateLabel').textContent = fmt;
    const iso = `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    document.getElementById('hiddenDueDate').value = iso;
    closeDds();
    renderCreateCal();
}

// ─── Row: Title inline edit ───────────────────────────────────────────────────
function editTitle(itemId, current) {
    const cell = document.getElementById('titleCell_' + itemId);
    if (!cell) return;
    const shortId = cell.querySelector('.badge-id').outerHTML;
    
    cell.innerHTML = `${shortId}<input class="title-input" type="text" value="${current}" 
        id="titleInput_${itemId}"
        onblur="saveTitle('${itemId}', this.value, '${current}')"
        onkeydown="if(event.key==='Enter')this.blur();if(event.key==='Escape'){ this.dataset.cancel='true'; this.blur(); }" />`;
    const inp = document.getElementById('titleInput_' + itemId);
    if (inp) { inp.focus(); inp.select(); }
}

function saveTitle(itemId, val, original) {
    const inp = document.getElementById('titleInput_' + itemId);
    if (inp && inp.dataset.cancel === 'true') {
        renderTitleCell(itemId, original);
        return;
    }

    const title = val.trim();
    if (title === '' || title === original) {
        renderTitleCell(itemId, original);
        return;
    }

    fetch('?handler=UpdateTitle', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': getToken()
        },
        body: `itemId=${itemId}&title=${encodeURIComponent(title)}`
    }).then(r => {
        if (r.ok) {
            renderTitleCell(itemId, title);
            showToast('Title updated', 'Item title has been changed.');
        } else {
            renderTitleCell(itemId, original);
        }
    }).catch(() => {
        renderTitleCell(itemId, original);
    });
}

function renderTitleCell(itemId, title) {
    const cell = document.getElementById('titleCell_' + itemId);
    if (!cell) return;
    
    // We need the shortId. We can get it from the badge-id class if it still exists or reconstruct it.
    // Easiest is to reload if complicated, but let's try to keep it smooth.
    const badge = cell.querySelector('.badge-id');
    const shortIdHtml = badge ? badge.outerHTML : ''; 

    cell.innerHTML = `${shortIdHtml}
        <a href="#" class="title-link">${title}</a>
        <span class="edit-title-btn" onclick="editTitle('${itemId}', '${title.replace(/'/g, "\\'")}')" title="Edit title">
            <i class="bi bi-pencil" style="font-size:10px;"></i>
        </span>`;
}

// ─── Row: Points inline edit ──────────────────────────────────────────────────
function editPoints(itemId, current) {
    const cell = document.getElementById('ptsCell_' + itemId);
    if (!cell) return;
    cell.innerHTML = `<input class="pts-input" type="number" min="0" value="${current || ''}" 
        id="ptsInput_${itemId}"
        onblur="savePoints('${itemId}', this.value)"
        onkeydown="if(event.key==='Enter')this.blur();if(event.key==='Escape'){this.blur();}" />`;
    const inp = document.getElementById('ptsInput_' + itemId);
    if (inp) { inp.focus(); inp.select(); }
}

function savePoints(itemId, val) {
    const pts = val.trim() === '' ? 0 : Math.max(0, parseInt(val) || 0);
    fetch('?handler=UpdateStoryPoints', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': getToken()
        },
        body: `itemId=${itemId}&storyPoints=${pts}`
    }).then(r => {
        if (r.ok) {
            const cell = document.getElementById('ptsCell_' + itemId);
            if (pts > 0) {
                cell.innerHTML = `<span class="pts-val" onclick="editPoints('${itemId}', ${pts})" title="Click to edit">${pts}</span>`;
            } else {
                cell.innerHTML = `<button type="button" class="ib" onclick="editPoints('${itemId}', 0)" title="Add story points">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="6" y1="1" x2="6" y2="11"/><line x1="1" y1="6" x2="11" y2="6"/></svg>
                </button>`;
            }
        }
    }).catch(() => {});
}

