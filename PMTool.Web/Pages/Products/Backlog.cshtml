@page "{projectId:guid}/{id:guid}/backlog"
@model PMTool.Web.Pages.Products.BacklogModel
@{
    if (Model.IsEmbedded)
    {
        Layout = "_EmbeddedLayout";
    }
    else
    {
        Layout = "_Layout";
    }

    ViewData["Title"] = "Product Backlog";
}

<div class=" mt-5">
    @if (!Model.IsEmbedded)
    {
        <nav aria-label="breadcrumb" class="mb-3 d-flex justify-content-between align-items-center">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-page="/Projects/Details" asp-route-id="@Model.ProjectId">@Model.ProjectName</a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-page="/Projects/Details" asp-route-id="@Model.ProjectId" asp-route-tab="products">Products</a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-page="./Details" asp-route-projectId="@Model.ProjectId" asp-route-id="@Model.ProductId">@Model.ProductName</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Backlog</li>
            </ol>
            <a asp-page="./Details" asp-route-projectId="@Model.ProjectId" asp-route-id="@Model.ProductId" class="btn btn-sm btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to @Model.ProductName
            </a>
        </nav>
    }

    <div style="background-color: #ffffffff; padding: 16px; border-radius: 4px;">
        <!-- Backlog Header -->
        <div class="d-flex justify-content-between align-items-center mb-3" style="background-color: white; padding: 12px; border-radius: 4px;">
            <div class="d-flex align-items-center gap-3">
                <div>
                    <h6 class="mb-0 fw-bold">Backlog</h6>
                    <small class="text-muted">(@Model.BacklogItems.Count work items)</small>
                </div>
                <div class="d-flex gap-2 align-items-center ms-3">
                    <span class="badge bg-light text-dark" title="Draft items">@Model.DraftCount</span>
                    <span class="badge bg-primary" title="Approved items">@Model.ApprovedCount</span>
                    <span class="badge bg-light text-dark" title="Other items">@(Model.BacklogItems.Count - Model.DraftCount - Model.ApprovedCount)</span>
                    @if (Model.CanEditBacklog)
                    {
                        <button type="button" class="btn btn-sm btn-link" title="Team members" data-bs-toggle="modal" data-bs-target="#teamModal">
                            <i class="bi bi-people-fill text-primary"></i>
                        </button>
                    }
                </div>
            </div>
            @if (Model.CanEditBacklog)
            {
                <button type="button" class="btn btn-sm btn-primary" id="createSprintBtn">
                    <i class="bi bi-plus-lg"></i> Create sprint
                </button>
            }
        </div>

        <!-- Create Backlog Item Section -->
        @if (Model.CanEditBacklog)
        {
            <div style="background-color: white; padding: 16px; border-radius: 4px; border: 2px solid #e0e0e0; margin-bottom: 16px;">
                <div class="d-flex gap-2 align-items-start">
                    <!-- Type Dropdown -->
                    <div style="flex: 0 0 auto;">
                        <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" title="Select item type">
                            <i class="bi bi-bookmark-fill"></i>
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#" data-type="feature">Feature</a></li>
                            <li><a class="dropdown-item" href="#" data-type="improvement">Improvement</a></li>
                            <li><a class="dropdown-item" href="#" data-type="changerequest">Change Request</a></li>
                            <li><a class="dropdown-item" href="#" data-type="testcase">Test Case</a></li>
                            <li><a class="dropdown-item" href="#" data-type="story">User Story</a></li>
                            <li><a class="dropdown-item" href="#" data-type="bug">Bug</a></li>
                            <li><a class="dropdown-item" href="#" data-type="task">Task</a></li>
                        </ul>
                    </div>

                    <!-- Description Input -->
                    <input type="text" class="form-control form-control-sm flex-grow-1" placeholder="Describe what needs to be done, or generate work items from Confluence, Loom, or an image." id="itemDescription" />

                    <!-- Due Date -->
                    <div style="flex: 0 0 auto;">
                        <input type="hidden" id="newItemDueDate" />
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="dueDateBtn" title="Set due date">
                            <i class="bi bi-calendar-event"></i>
                            <span id="dueDateStatus" class="d-none"></span>
                        </button>
                    </div>

                    <!-- Team Members Dropdown -->
                    <div style="flex: 0 0 auto;">
                        <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" title="Assign team members">
                            <i class="bi bi-person-plus-fill"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#"><small>Team members will appear here</small></a></li>
                        </ul>
                    </div>

                    <!-- Create Button -->
                    <button type="button" class="btn btn-sm btn-primary" id="createItemBtn" title="Create work item">
                        Create
                        <i class="bi bi-arrow-right"></i>
                    </button>
                </div>
            </div>
        }

        <!-- Backlog Items List -->
        <div style="background-color: white; padding: 16px; border-radius: 4px;">
            @if (Model.BacklogItems.Count == 0)
            {
                <div class="text-center text-muted py-4">
                    <p>Your backlog is empty.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 32px;"><input type="checkbox" id="selectAll" /></th>
                                <th style="width: 36px;"></th>
                                <th>Title</th>
                                <th style="width: 100px;">Type</th>
                                <th style="width: 100px;">Status</th>
                                <th style="width: 100px;">Owner</th>
                                <th style="width: 110px;">Due Date</th>
                                <th style="width: 90px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.BacklogItems.OrderBy(x => x.Priority))
                            {
                                <tr>
                                    <td><input type="checkbox" value="@item.Id" /></td>
                                    <td>
                                        <span class="badge" style="background-color: #d4e6f1;">
                                            @item.Id.ToString("N").Substring(0, 4).ToUpper()
                                        </span>
                                    </td>
                                    <td>
                                        <a href="#" class="text-decoration-none">@item.Title</a>
                                    </td>
                                    <td>
                                        <small class="text-muted">@item.TypeName</small>
                                    </td>
                                    <td>
                                        @{
                                            var statusBadgeClass = item.Status switch
                                            {
                                                1 => "bg-secondary",
                                                2 => "bg-warning",
                                                3 => "bg-info",
                                                4 => "bg-success",
                                                _ => "bg-light text-dark"
                                            };
                                        }
                                        <span class="badge @statusBadgeClass">
                                            @item.StatusName
                                        </span>
                                    </td>
                                    <td>
                                        <small class="text-muted">@item.OwnerName</small>
                                    </td>
                                    <td class="due-date-cell" data-due="@(item.DueDate?.ToString("yyyy-MM-dd") ?? "")">
                                        <button type="button" class="btn btn-sm btn-link p-0 due-date-btn text-decoration-none" title="Set due date">
                                            @if (item.DueDate.HasValue)
                                            {
                                                <span class="due-date-label text-@(item.DueDate.Value < DateTime.Today ? "danger" : "secondary")">
                                                    <i class="bi bi-calendar3"></i> @item.DueDate.Value.ToString("MMM d")
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="due-date-label text-muted">
                                                    <i class="bi bi-calendar3"></i>
                                                </span>
                                            }
                                        </button>
                                    </td>
                                    <td>
                                        @if (Model.CanEditBacklog)
                                        {
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-link text-muted p-0" type="button" data-bs-toggle="dropdown">
                                                    <i class="bi bi-three-dots-vertical"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                                    <li><a class="dropdown-item" href="#"><i class="bi bi-pencil"></i> Edit</a></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-trash"></i> Delete</a></li>
                                                </ul>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<style>
    .badge {
        font-size: 0.85rem;
        padding: 4px 8px;
    }

    .dropdown-toggle::after {
        display: none;
    }

    #dueDatePicker {
        position: fixed;
        z-index: 9999;
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        padding: 12px 14px;
        min-width: 230px;
        display: none;
    }
    #dueDatePicker h6 { font-size: 0.78rem; color: #6c757d; margin-bottom: 8px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }
    #dueDatePicker input[type=date] { border-radius: 6px; font-size: 0.85rem; }
</style>

@section Scripts {
    <script>
    (() => {
        // Due Date Picker UI
        const dueDatePicker = document.createElement('div');
        dueDatePicker.id = 'dueDatePicker';
        dueDatePicker.innerHTML = `
            <h6><i class="bi bi-calendar3 me-1"></i>Set Due Date</h6>
            <input type="date" class="form-control form-control-sm mb-2" id="dueDateInput" />
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-primary flex-grow-1" id="dueDateSave">Apply</button>
                <button class="btn btn-sm btn-link text-danger p-0 text-decoration-none small" id="dueDateClear">Clear</button>
            </div>`;
        document.body.appendChild(dueDatePicker);

        let activeRow = null;
        let isCreationCalendar = false;

        const positionPicker = (anchor) => {
            const rect = anchor.getBoundingClientRect();
            const pickerH = 140;
            const spaceBelow = window.innerHeight - rect.bottom;
            const top = spaceBelow >= pickerH ? rect.bottom + window.scrollY + 4 : rect.top + window.scrollY - pickerH - 4;
            dueDatePicker.style.top = top + 'px';
            dueDatePicker.style.left = Math.min(rect.left, window.innerWidth - 250) + 'px';
            dueDatePicker.style.position = 'absolute';
        };

        const closePicker = () => {
            dueDatePicker.style.display = 'none';
            activeRow = null;
            isCreationCalendar = false;
        };

        const postJson = async (handler, payload) => {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const response = await fetch(`?handler=${handler}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify(payload)
            });
            return response.json();
        };

        const saveDueDate = async (value) => {
            if (isCreationCalendar) {
                const input = document.getElementById('newItemDueDate');
                const btn = document.getElementById('dueDateBtn');
                input.value = value;
                if (value) {
                    const d = new Date(value + 'T00:00:00');
                    btn.classList.replace('btn-outline-secondary', 'btn-primary');
                    btn.innerHTML = `<i class="bi bi-calendar-check-fill"></i> <small>${d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</small>`;
                } else {
                    btn.classList.replace('btn-primary', 'btn-outline-secondary');
                    btn.innerHTML = `<i class="bi bi-calendar-event"></i>`;
                }
                closePicker();
                return;
            }

            if (!activeRow) return;
            const itemId = activeRow.querySelector('input[type="checkbox"]')?.value;
            if (!itemId) return;
            const cell = activeRow.querySelector('.due-date-cell');
            
            try {
                const result = await postJson('UpdateField', { itemId, field: 'duedate', value: value || '' });
                if (result.success) {
                    cell.dataset.due = value;
                    const lbl = cell.querySelector('.due-date-label');
                    if (value) {
                        const d = new Date(value + 'T00:00:00');
                        const isPast = d < new Date(new Date().toDateString());
                        lbl.className = `due-date-label text-${isPast ? 'danger' : 'secondary'}`;
                        lbl.innerHTML = `<i class="bi bi-calendar3"></i> ${d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}`;
                    } else {
                        lbl.className = 'due-date-label text-muted';
                        lbl.innerHTML = '<i class="bi bi-calendar3"></i>';
                    }
                } else {
                    alert(result.message || "Failed to update date");
                }
            } catch (err) {
                console.error("Update error:", err);
            }
            closePicker();
        };

        document.addEventListener('click', (e) => {
            const btn = e.target.closest('.due-date-btn');
            const creationBtn = e.target.closest('#dueDateBtn');
            
            if (btn || creationBtn) {
                e.stopPropagation();
                e.preventDefault();
                
                if (creationBtn) {
                    if (isCreationCalendar && dueDatePicker.style.display === 'block') { closePicker(); return; }
                    isCreationCalendar = true;
                    activeRow = null;
                    document.getElementById('dueDateInput').value = document.getElementById('newItemDueDate').value;
                    positionPicker(creationBtn);
                } else {
                    const row = btn.closest('tr');
                    const cell = row.querySelector('.due-date-cell');
                    if (activeRow === row && dueDatePicker.style.display === 'block') { closePicker(); return; }
                    activeRow = row;
                    isCreationCalendar = false;
                    document.getElementById('dueDateInput').value = cell.dataset.due || '';
                    positionPicker(btn);
                }
                
                dueDatePicker.style.display = 'block';
                document.getElementById('dueDateInput').focus();
                return;
            }

            if (!e.target.closest('#dueDatePicker')) closePicker();
        });

        document.getElementById('dueDateSave').addEventListener('click', (e) => {
            e.preventDefault();
            saveDueDate(document.getElementById('dueDateInput').value);
        });

        document.getElementById('dueDateClear').addEventListener('click', (e) => {
            e.preventDefault();
            saveDueDate('');
        });

        document.getElementById('dueDateInput').addEventListener('keydown', (e) => {
            if (e.key === 'Enter') { e.preventDefault(); saveDueDate(e.target.value); }
            if (e.key === 'Escape') closePicker();
        });

        // Item Type Selection
        document.querySelectorAll('.dropdown-item[data-type]').forEach(item => {
            item.addEventListener('click', (e) => {
                e.preventDefault();
                const type = item.dataset.type;
                const btn = item.closest('.dropdown').querySelector('.dropdown-toggle');
                btn.dataset.selectedType = type;
                btn.innerHTML = item.innerHTML;
            });
        });

        // Create Item Logic
        const createItemBtn = document.getElementById('createItemBtn');
        if (createItemBtn) {
            createItemBtn.addEventListener('click', async () => {
                const titleInput = document.getElementById('itemDescription');
                const title = titleInput.value.trim();
                if (!title) { alert("Please enter a description"); return; }
                
                const typeBtn = document.querySelector('[data-bs-toggle="dropdown"][title="Select item type"]');
                const type = typeBtn.dataset.selectedType || 'story';
                const typeMap = { 
                    'story': 2, 
                    'task': 3, 
                    'bug': 9, 
                    'epic': 4,
                    'feature': 6,
                    'improvement': 7,
                    'testcase': 8,
                    'changerequest': 5
                };
                
                const payload = {
                    projectId: '@Model.ProjectId',
                    productId: '@Model.ProductId',
                    title: title,
                    type: typeMap[type] || 2,
                    dueDate: document.getElementById('newItemDueDate').value || null,
                    status: 1 // Draft
                };
                
                createItemBtn.disabled = true;
                const originalContent = createItemBtn.innerHTML;
                createItemBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
                
                try {
                    const result = await postJson('Create', payload);
                    if (result.success) {
                        location.reload();
                    } else {
                        alert(result.message || "Failed to create item");
                        createItemBtn.disabled = false;
                        createItemBtn.innerHTML = originalContent;
                    }
                } catch (err) {
                    console.error("Create error:", err);
                    createItemBtn.disabled = false;
                    createItemBtn.innerHTML = originalContent;
                }
            });
        }
    })();
    </script>
}
