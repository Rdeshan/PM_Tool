// ─── Row: Due date calendar ───────────────────────────────────────────────────
const itemCalViews = {};

function toggleItemCal(itemId, e) {
    if (e) e.stopPropagation();
    const panel = document.getElementById('itemCal_' + itemId);
    const wasOpen = panel.classList.contains('open');
    closeDds();
    if (!wasOpen) {
        if (!itemCalViews[itemId]) {
            const stored = panel.dataset.currentDate;
            const d = stored ? new Date(stored + 'T00:00:00') : new Date();
            itemCalViews[itemId] = new Date(d.getFullYear(), d.getMonth(), 1);
        }
        panel.classList.add('open');
        renderItemCal(itemId);
    }
}

function renderItemCal(itemId) {
    const panel = document.getElementById('itemCal_' + itemId);
    const vd = itemCalViews[itemId];
    const y = vd.getFullYear(), m = vd.getMonth();
    const fd = new Date(y, m, 1).getDay();
    const dim = new Date(y, m + 1, 0).getDate();
    const today = new Date();
    const stored = panel.dataset.currentDate;
    const sel = stored ? new Date(stored + 'T00:00:00') : null;

    let h = `<div class="cal-nav">
        <button onclick="shiftItemCal('${itemId}',-1);event.stopPropagation()">&#8249;</button>
        <span>${MONTHS[m]} ${y}</span>
        <button onclick="shiftItemCal('${itemId}',1);event.stopPropagation()">&#8250;</button>
    </div><div class="cal-grid">`;
    WDAYS.forEach(d => h += `<div class="cal-dh">${d}</div>`);
    for (let i = 0; i < fd; i++) h += `<div class="cal-d empty"></div>`;
    for (let d = 1; d <= dim; d++) {
        const isT = today.getFullYear()===y && today.getMonth()===m && today.getDate()===d;
        const isS = sel && sel.getFullYear()===y && sel.getMonth()===m && sel.getDate()===d;
        h += `<div class="cal-d ${isS?'sel':isT?'today':''}" onclick="pickItemDate('${itemId}',${y},${m},${d});event.stopPropagation()">${d}</div>`;
    }
    h += '</div>';
    panel.innerHTML = h;
}

function shiftItemCal(itemId, dir) {
    const vd = itemCalViews[itemId];
    itemCalViews[itemId] = new Date(vd.getFullYear(), vd.getMonth() + dir, 1);
    renderItemCal(itemId);
}
function toggleSprint(id) {

    document.getElementById('sprint_' + id).classList.toggle('collapsed');

}

function pickItemDate(itemId, y, m, d) {
    const dateObj = new Date(y, m, d);
    const iso = `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const fmt = `${SMON[m]} ${d}`;
    const panel = document.getElementById('itemCal_' + itemId);
    panel.dataset.currentDate = iso;
    const lbl = document.getElementById('dateLbl_' + itemId);
    if (lbl) lbl.textContent = fmt;
    closeDds();

    fetch('?handler=UpdateDueDate', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': getToken()
        },
        body: `itemId=${itemId}&dueDate=${iso}`
    }).catch(() => {});
}

// ─── Create form submit ───────────────────────────────────────────────────────
document.getElementById('createBacklogForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('createBtn');
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = `<span class="spinner-border spinner-border-sm"></span>`;

    try {
        const fd = new FormData(this);
        const resp = await fetch(this.action, {
            method: 'POST',
            body: fd,
            headers: { 'RequestVerificationToken': getToken() }
        });
        const text = await resp.text();
        let result;
        try { result = JSON.parse(text); }
        catch { throw new Error('Server error'); }

        if (result.success) {
            showToast('Item created!', 'success');
            document.getElementById('newItemTitle').value = '';
            document.getElementById('hiddenOwner').value = '';
            document.getElementById('hiddenDueDate').value = '';
            createDate = null;
            document.getElementById('createDateLabel').textContent = '';
            document.getElementById('createAssignIcon').innerHTML = `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>`;
            setTimeout(() => location.reload(), 600);
        } else {
            showToast(result.message || 'Failed to create item', 'danger');
        }
    } catch (err) {
        showToast('Failed to create item', 'danger');
    } finally {
        btn.disabled = false;
        btn.innerHTML = orig;
    }
});

// ─── Toast ────────────────────────────────────────────────────────────────────
function showToast(message, type = 'success') {
    const el = document.getElementById('liveToast');
    document.getElementById('toastMessage').textContent = message;
    document.getElementById('toastTitle').textContent = type === 'danger' ? 'Error' : 'Success';
    el.className = `toast align-items-center text-white bg-${type} border-0`;
    new bootstrap.Toast(el).show();
}

// ─── Token helper ─────────────────────────────────────────────────────────────
function getToken() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
}

// ─── Select all checkbox ──────────────────────────────────────────────────────
const selectAll = document.getElementById('selectAll');
if (selectAll) {
    selectAll.addEventListener('change', function() {
        document.querySelectorAll('#backlogTableBody input[type=checkbox]')
            .forEach(cb => cb.checked = this.checked);
    });
}
</script>
