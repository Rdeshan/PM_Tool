@model PMTool.Application.DTOs.Backlog.ProductBacklogItemDTO
@{
    var item = Model;
    var itemId = item.Id.ToString();
    var shortId = item.Id.ToString("N").Substring(0, 4).ToUpper();
    var statusCls = item.Status switch {
        1 => "s-todo",
        2 => "s-inprog",
        3 => "s-inreview",
        4 => "s-done",
        _ => "s-todo"
    };
    var statusLabel = item.Status switch {
        1 => "To do",
        2 => "In progress",
        3 => "In review",
        4 => "Done",
        _ => "To do"
    };

    string GetInitials(string name) {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name.Substring(0, Math.Min(2, name.Length)).ToUpper();
    }

    (string bg, string fg) GetAvatarBg(string id) {
        var palettes = new[] {
            (bg: "#deebff", fg: "#0747a6"),
            (bg: "#e3fcef", fg: "#006644"),
            (bg: "#fff0b3", fg: "#974f0c"),
            (bg: "#ffebe6", fg: "#bf2600"),
            (bg: "#e6fcff", fg: "#006c8a"),
            (bg: "#f3f0ff", fg: "#403294"),
            (bg: "#fce4ec", fg: "#880e4f"),
        };
        var idx = Math.Abs((id ?? "").GetHashCode()) % palettes.Length;
        return palettes[idx];
    }

    var ownerInitials = item.OwnerName != null ? GetInitials(item.OwnerName) : "";
    var ownerColors = item.OwnerId.HasValue ? GetAvatarBg(item.OwnerId.Value.ToString()) : (bg: "#dfe1e6", fg: "#42526e");
    var isOverdue = item.DueDate.HasValue && item.DueDate.Value.Date < DateTime.Today;
}

<tr id="row-@item.Id" data-item-id="@item.Id">
    <td><input type="checkbox" value="@item.Id" /></td>
    <td>
        <!-- Type icon with dropdown -->
        <div class="rel d-inline-flex align-items-center">
            <button type="button" class="ib" onclick="toggleDd('typeDd_@itemId', event)" title="@item.TypeName">
                @switch(item.Type)
                {
                    case 1: <!-- Story -->
                        <svg width="16" height="16" viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="12" height="12" rx="2" fill="#63BA3C"/><path d="M4 7h6M7 4v6" stroke="#fff" stroke-width="1.2" stroke-linecap="round"/></svg>
                        break;
                    case 3: <!-- Bug -->
                        <svg width="16" height="16" viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="12" height="12" rx="2" fill="#FF5630"/><circle cx="7" cy="7" r="3" stroke="#fff" stroke-width="1.2"/></svg>
                        break;
                    case 4: <!-- Epic -->
                        <svg width="16" height="16" viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="12" height="12" rx="2" fill="#998DD9"/><path d="M7 3l1.5 3.5H12l-2.8 2 1.1 3.5L7 10.2 4.7 12.5l1.1-3.5L3 7h3.5z" fill="#fff"/></svg>
                        break;
                    default: <!-- Task -->
                        <svg width="16" height="16" viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="12" height="12" rx="2" fill="#4C9AFF"/><path d="M4 7.5l2 2 4-4" stroke="#fff" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        break;
                }
            </button>

            <!-- Type dropdown -->
            <div class="dd-panel" id="typeDd_@itemId">
                <div class="dd-item" onclick="updateType('@item.Id', 1, event)">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="12" height="12" rx="2" fill="#63BA3C"/><path d="M4 7h6M7 4v6" stroke="#fff" stroke-width="1.2" stroke-linecap="round"/></svg>Story
                </div>
                <div class="dd-item" onclick="updateType('@item.Id', 2, event)">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="12" height="12" rx="2" fill="#4C9AFF"/><path d="M4 7.5l2 2 4-4" stroke="#fff" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>Task
                </div>
                <div class="dd-item" onclick="updateType('@item.Id', 3, event)">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="12" height="12" rx="2" fill="#FF5630"/><circle cx="7" cy="7" r="3" stroke="#fff" stroke-width="1.2"/></svg>Bug
                </div>
                <div class="dd-item" onclick="updateType('@item.Id', 4, event)">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="12" height="12" rx="2" fill="#998DD9"/><path d="M7 3l1.5 3.5H12l-2.8 2 1.1 3.5L7 10.2 4.7 12.5l1.1-3.5L3 7h3.5z" fill="#fff"/></svg>Epic
                </div>
            </div>
        </div>
    </td>
    <td>
        <div class="d-flex align-items-center gap-2" id="titleCell_@itemId">
            <span class="badge-id">@shortId</span>
            <a href="#" class="title-link">@item.Title</a>
            <span class="edit-title-btn" onclick="editTitle('@itemId', '@System.Web.HttpUtility.JavaScriptStringEncode(item.Title)')" title="Edit title">
                <i class="bi bi-pencil" style="font-size:10px;"></i>
            </span>
        </div>
    </td>
    <td style="text-align:center;">
        @if (item.SubProjectId.HasValue)
        {
            <div class="rel d-inline-flex">
                <span class="subproj-badge" onclick="toggleDd('subProjDd_@itemId', event)" 
                      style="margin-left:0; background:@(item.SubProjectColor ?? "#EAE6FF");">
                    <i class="bi bi-diagram-3"></i> @item.SubProjectName
                </span>
                <div class="dd-panel" id="subProjDd_@itemId">
                    <div class="dd-item text-danger" onclick="updateSubProject('@item.Id', '', event)">
                        <i class="bi bi-x-circle me-1"></i> Remove from sub-project
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="rel d-inline-flex">
                <button type="button" class="subproj-btn" onclick="toggleDd('subProjDd_@itemId', event)" style="margin-left:0;">
                    <i class="bi bi-plus"></i> Subprojects
                </button>
            </div>
        }
    </td>
    <td>
        <!-- Status pill with dropdown -->
        <div class="rel">
            <button type="button" class="pill-status @statusCls" onclick="toggleDd('statusDd_@itemId', event)">
                @statusLabel
            </button>
            <div class="dd-panel" id="statusDd_@itemId">
                <div class="dd-item" onclick="updateStatus('@item.Id', 1, event)">
                    <span class="pill-status s-todo" style="pointer-events:none;font-size:10px;">To do</span>
                </div>
                <div class="dd-item" onclick="updateStatus('@item.Id', 2, event)">
                    <span class="pill-status s-inprog" style="pointer-events:none;font-size:10px;">In progress</span>
                </div>
                <div class="dd-item" onclick="updateStatus('@item.Id', 3, event)">
                    <span class="pill-status s-inreview" style="pointer-events:none;font-size:10px;">In review</span>
                </div>
                <div class="dd-item" onclick="updateStatus('@item.Id', 4, event)">
                    <span class="pill-status s-done" style="pointer-events:none;font-size:10px;">Done</span>
                </div>
            </div>
        </div>
    </td>
    <td>
        <!-- Assignee avatar with dropdown -->
        <div class="rel">
            <button type="button" class="ib" onclick="toggleDd('assignDd_@itemId', event)"
                    title="@(item.OwnerName ?? "Unassigned")">
                @if (item.OwnerName != null)
                {
                    <div class="avatar-circle" style="background:@ownerColors.bg;color:@ownerColors.fg;">@ownerInitials</div>
                }
                else
                {
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>
                }
            </button>
        </div>
    </td>
    <td>
        <!-- Inline editable story points -->
        <div id="ptsCell_@itemId">
            @if (item.StoryPoints > 0)
            {
                <span class="pts-val" onclick="editPoints('@itemId', @item.StoryPoints)" title="Click to edit">@item.StoryPoints</span>
            }
            else
            {
                <button type="button" class="ib" onclick="editPoints('@itemId', 0)" title="Add story points">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="6" y1="1" x2="6" y2="11"/><line x1="1" y1="6" x2="11" y2="6"/></svg>
                </button>
            }
        </div>
    </td>
    <td>
        <!-- Calendar icon -->
        <div class="rel">
            <button type="button" class="ib" onclick="toggleItemCal('@itemId', event)"
                    title="@(item.DueDate.HasValue ? item.DueDate.Value.ToString("MMM d") : "Set due date")"
                    style="@(isOverdue ? "color:#E24B4A;" : "")">
                <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="1" y="3" width="14" height="12" rx="2"/><path d="M5 1v4M11 1v4M1 7h14" stroke-linecap="round"/></svg>
                @if (item.DueDate.HasValue)
                {
                    <span style="font-size:11px;" id="dateLbl_@itemId">@item.DueDate.Value.ToString("MMM d")</span>
                }
            </button>
            <div class="cal-panel" id="itemCal_@itemId" data-current-date="@(item.DueDate?.ToString("yyyy-MM-dd") ?? "")"></div>
        </div>
    </td>
    <td>
        <div class="dropdown">
            <button class="ib" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-three-dots-vertical" style="font-size:13px;"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="font-size:12px;min-width:140px;">
                <li><a class="dropdown-item" href="#"><i class="bi bi-pencil me-2"></i>Edit</a></li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form asp-page-handler="Delete" method="post" asp-antiforgery="true"
                          style="display:inline;" onsubmit="return confirm('Delete this item?');">
                        <input type="hidden" name="itemId" value="@item.Id" />
                        <button type="submit" class="dropdown-item text-danger"
                                style="border:none;background:none;width:100%;text-align:left;padding:6px 16px;cursor:pointer;">
                            <i class="bi bi-trash me-2"></i>Delete
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </td>
</tr>
