@model PMTool.Application.DTOs.Backlog.ProductBacklogItemDTO
@using PMTool.Application.DTOs.SubProject
@using PMTool.Application.DTOs.Backlog
@using PMTool.Application.DTOs.Board
@{
    var item = Model;
    var itemId = item.Id.ToString();
    var shortId = item.Id.ToString("N").Substring(0, 4).ToUpper();
    var customStatuses = ViewData["CustomStatuses"] as List<BoardColumnDTO> ?? new List<BoardColumnDTO>();
    var customStatus = customStatuses.FirstOrDefault(x => x.StatusValue == item.Status);
    var statusCls = customStatus != null ? "s-custom" : item.Status switch {
        1 => "s-todo",
        2 => "s-inprog",
        3 => "s-inreview",
        4 => "s-done",
        _ => "s-todo"
    };
    var statusLabel = customStatus?.Name ?? item.Status switch {
        1 => "To do",
        2 => "In progress",
        3 => "In review",
        4 => "Done",
        _ => "To do"
    };

    string GetInitials(string name) {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name.Substring(0, Math.Min(2, name.Length)).ToUpper();
    }

    (string bg, string fg) GetAvatarBg(string id) {
        var palettes = new[] {
            (bg: "#deebff", fg: "#0747a6"),
            (bg: "#e3fcef", fg: "#006644"),
            (bg: "#fff0b3", fg: "#974f0c"),
            (bg: "#ffebe6", fg: "#bf2600"),
            (bg: "#e6fcff", fg: "#006c8a"),
            (bg: "#f3f0ff", fg: "#403294"),
            (bg: "#fce4ec", fg: "#880e4f"),
        };
        var idx = (uint)(id ?? "").GetHashCode() % (uint)palettes.Length;
        return palettes[idx];
    }

    var ownerInitials = item.OwnerName != null ? GetInitials(item.OwnerName) : "";
    var ownerColors = item.OwnerId.HasValue ? GetAvatarBg(item.OwnerId.Value.ToString()) : (bg: "#dfe1e6", fg: "#42526e");
    var isOverdue = item.DueDate.HasValue && item.DueDate.Value.Date < DateTime.Today;
    var subProjects = ViewData["SubProjects"] as List<SubProjectDTO> ?? new List<SubProjectDTO>();
    var workTypes = ViewData["WorkTypes"] as List<WorkTypeOptionDTO> ?? new List<WorkTypeOptionDTO>();
    var currentWorkType = workTypes.FirstOrDefault(x => x.Value == item.Type);
    var currentWorkIcon = currentWorkType?.IconClass ?? "bi bi-tag";
    var currentWorkName = currentWorkType?.Name ?? "Work Item";
    var priorityLabel = item.Priority switch {
        1 => "Highest",
        2 => "High",
        3 => "Medium",
        4 => "Low",
        _ => "Medium"
    };
    var subtasksByItem = ViewData["SubtasksByItem"] as Dictionary<Guid, List<BacklogSubtaskDto>>;
    var itemSubtasks = subtasksByItem != null && subtasksByItem.TryGetValue(item.Id, out var fromDictionary)
        ? fromDictionary
        : item.Subtasks;

    // ── Access control ──────────────────────────────────────────────────────────
    var isAdminOrPM    = (bool)(ViewData["IsAdminOrPM"] ?? false);
    var currentUserId  = ViewData["CurrentUserId"] as string ?? string.Empty;
    var isAssignedUser = !string.IsNullOrEmpty(currentUserId)
                         && item.OwnerId.HasValue
                         && item.OwnerId.Value.ToString() == currentUserId;
    var canChangeStatus = isAdminOrPM || isAssignedUser;
}

<tr id="row-@item.Id"
    data-item-id="@item.Id"
    data-item-title="@item.Title"
    data-item-key="@shortId"
    data-item-description="@item.Description"
    data-item-status="@item.Status"
    data-item-status-label="@statusLabel"
    data-item-assignee="@(item.OwnerName ?? "Unassigned")"
    data-item-assignee-id="@(item.OwnerId?.ToString() ?? "")"
    data-item-priority="@item.Priority"
    data-item-priority-label="@priorityLabel"
    data-item-work-type="@currentWorkName"
    data-item-due-date="@(item.DueDate?.ToString("yyyy-MM-dd") ?? "")"
    data-item-start-date="@(item.StartDate?.ToString("yyyy-MM-dd") ?? "")"
    data-item-story-points="@item.StoryPoints"
    data-item-created-at="@item.CreatedAt.ToString("yyyy-MM-ddTHH:mm:ssZ")"
    data-status="@item.Status">
    <td><input type="checkbox" value="@item.Id" /></td>
    <td>
        @if (isAdminOrPM)
        {
            <div class="rel d-inline-flex align-items-center">
                <button type="button" class="ib" onclick="toggleDd('typeDd_@itemId', event)" title="@currentWorkName">
                    <i class="@currentWorkIcon"></i>
                </button>
                <div class="dd-panel type-dropdown" id="typeDd_@itemId" data-item-id="@item.Id">
                    @foreach (var workType in workTypes)
                    {
                        <div class="dd-item work-type-option" data-type-value="@workType.Value" data-icon-class="@workType.IconClass" onclick="updateType('@item.Id', @workType.Value, event)">
                            <i class="@workType.IconClass"></i> @workType.Name
                        </div>
                    }
                    <div class="dd-item text-primary" onclick="openWorkTypeModal(event)">
                        <i class="bi bi-plus-circle"></i> Add work type
                    </div>
                </div>
            </div>
        }
        else
        {
            <i class="@currentWorkIcon" title="@currentWorkName" style="font-size:14px;color:#6b778c;"></i>
        }
    </td>
    <td>
        <div class="item-title-stack">
            <div class="d-flex align-items-center gap-2" id="titleCell_@itemId">
                <span class="badge-id">@shortId</span>
                <a href="#"
                   class="title-link"
                   onclick="openProductSidebar('@itemId', '@System.Web.HttpUtility.JavaScriptStringEncode(item.Title)', '@shortId', false, event)">@item.Title</a>
                @if (itemSubtasks.Any())
                {
                    <span class="subtask-count"
                          style="cursor:pointer;"
                          onclick="openProductSidebar('@itemId', '@System.Web.HttpUtility.JavaScriptStringEncode(item.Title)', '@shortId', false, event)"
                          title="@itemSubtasks.Count subtask(s)">
                        <i class="bi bi-diagram-2"></i> <span class="subtask-count-value">@itemSubtasks.Count</span> subtasks
                    </span>
                }
                @if (isAdminOrPM)
                {
                    <button type="button"
                            class="subtask-add-btn"
                            onclick="openProductSidebar('@itemId', '@System.Web.HttpUtility.JavaScriptStringEncode(item.Title)', '@shortId', true, event)"
                            title="Add subtask">
                        <i class="bi bi-plus-lg"></i>
                    </button>
                    <span class="edit-title-btn" onclick="editTitle('@itemId', '@System.Web.HttpUtility.JavaScriptStringEncode(item.Title)')" title="Edit title">
                        <i class="bi bi-pencil" style="font-size:10px;"></i>
                    </span>
                }
            </div>
            <div class="product-subtasks d-none" id="subtaskList_@itemId" style="display:none!important;">
                @if (itemSubtasks.Any())
                {
                    @foreach (var subtask in itemSubtasks)
                    {
                        <div class="product-subtask @(subtask.Status == 3 ? "done" : "")"
                             data-subtask-id="@subtask.Id"
                             data-subtask-title="@subtask.Title"
                             data-subtask-status="@subtask.Status"
                             data-subtask-priority="@subtask.Priority"
                             data-subtask-assignee-id="@(subtask.AssigneeId?.ToString() ?? "")"
                             data-subtask-assignee-name="@(subtask.AssigneeName ?? "")">
                            <span>@subtask.Title</span>
                        </div>
                    }
                }
            </div>
        </div>
    </td>
    <td style="text-align:center;">
        @if (isAdminOrPM)
        {
            @if (item.SubProjectId.HasValue)
            {
                <div class="rel d-inline-flex">
                    <span class="subproj-badge" onclick="toggleDd('subProjDd_@itemId', event)"
                          style="margin-left:0; background:@(item.SubProjectColor ?? "#EAE6FF");">
                        <i class="bi bi-diagram-3"></i> @item.SubProjectName
                    </span>
                    <div class="dd-panel" id="subProjDd_@itemId">
                        <div class="dd-item text-danger" onclick="updateSubProject('@item.Id', '', event)">
                            <i class="bi bi-x-circle me-1"></i> Remove from sub-project
                        </div>
                        @foreach (var subProject in subProjects)
                        {
                            <div class="dd-item" onclick="updateSubProject('@item.Id', '@subProject.Id', event)">
                                <i class="bi bi-diagram-3"></i> @subProject.Name
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="rel d-inline-flex">
                    <button type="button" class="subproj-btn" onclick="toggleDd('subProjDd_@itemId', event)" style="margin-left:0;">
                        <i class="bi bi-plus"></i> Subprojects
                    </button>
                    <div class="dd-panel" id="subProjDd_@itemId">
                        @if (subProjects.Count == 0)
                        {
                            <div class="dd-item text-muted">No sub-projects available</div>
                        }
                        else
                        {
                            @foreach (var subProject in subProjects)
                            {
                                <div class="dd-item" onclick="updateSubProject('@item.Id', '@subProject.Id', event)">
                                    <i class="bi bi-diagram-3"></i> @subProject.Name
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        }
        else
        {
            @if (item.SubProjectId.HasValue)
            {
                <span class="subproj-badge" style="margin-left:0;cursor:default;background:@(item.SubProjectColor ?? "#EAE6FF");">
                    <i class="bi bi-diagram-3"></i> @item.SubProjectName
                </span>
            }
        }
    </td>
    <td>
        @if (canChangeStatus)
        {
            <div class="rel">
                <button type="button" class="pill-status @statusCls" data-status="@item.Status" onclick="toggleDd('statusDd_@itemId', event)">
                    @statusLabel
                </button>
                <div class="dd-panel" id="statusDd_@itemId">
                    <div class="dd-item" onclick="updateStatus('@item.Id', 1, event)">
                        <span class="pill-status s-todo" style="pointer-events:none;font-size:10px;">To do</span>
                    </div>
                    <div class="dd-item" onclick="updateStatus('@item.Id', 2, event)">
                        <span class="pill-status s-inprog" style="pointer-events:none;font-size:10px;">In progress</span>
                    </div>
                    <div class="dd-item" onclick="updateStatus('@item.Id', 3, event)">
                        <span class="pill-status s-inreview" style="pointer-events:none;font-size:10px;">In review</span>
                    </div>
                    <div class="dd-item" onclick="updateStatus('@item.Id', 4, event)">
                        <span class="pill-status s-done" style="pointer-events:none;font-size:10px;">Done</span>
                    </div>
                    @foreach (var status in customStatuses)
                    {
                        <div class="dd-item" onclick="updateStatus('@item.Id', @status.StatusValue, event)">
                            <span class="pill-status s-custom" style="pointer-events:none;font-size:10px;">@status.Name</span>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <span class="pill-status @statusCls" style="cursor:default;">@statusLabel</span>
        }
    </td>
    <td>
        @if (isAdminOrPM)
        {
            <div class="rel">
                <button type="button" class="ib" onclick="toggleDd('assignDd_@itemId', event)"
                        title="@(item.OwnerName ?? "Unassigned")">
                    @if (item.OwnerName != null)
                    {
                        <div class="avatar-circle" style="background:@ownerColors.bg;color:@ownerColors.fg;">@ownerInitials</div>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>
                    }
                </button>
                <div class="dd-panel dd-panel-right" id="assignDd_@itemId">
                    <div class="dd-item" onclick="updateOwner('@item.Id', '', event)">
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>
                        Unassigned
                    </div>
                    @{
                        var activeUsers = ViewData["ActiveUsers"] as IEnumerable<PMTool.Application.DTOs.User.UserDTO> ?? new List<PMTool.Application.DTOs.User.UserDTO>();
                    }
                    @foreach (var user in activeUsers)
                    {
                        var uName = user.DisplayName ?? $"{user.FirstName} {user.LastName}";
                        var initials = GetInitials(uName);
                        var bg = GetAvatarBg(user.Id.ToString());
                        <div class="dd-item" onclick="updateOwner('@item.Id', '@user.Id', event)">
                            <div class="avatar-circle" style="background:@bg.bg;color:@bg.fg">@initials</div>
                            @uName
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            @if (item.OwnerName != null)
            {
                <div class="avatar-circle" title="@item.OwnerName" style="background:@ownerColors.bg;color:@ownerColors.fg;cursor:default;">@ownerInitials</div>
            }
            else
            {
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#aaa" stroke-width="1.3" title="Unassigned"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>
            }
        }
    </td>
    <td>
        @if (isAdminOrPM)
        {
            <div id="ptsCell_@itemId">
                @if (item.StoryPoints > 0)
                {
                    <span class="pts-val" onclick="editPoints('@itemId', @item.StoryPoints)" title="Click to edit">@item.StoryPoints</span>
                }
                else
                {
                    <button type="button" class="ib" onclick="editPoints('@itemId', 0)" title="Add story points">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="6" y1="1" x2="6" y2="11"/><line x1="1" y1="6" x2="11" y2="6"/></svg>
                    </button>
                }
            </div>
        }
        else
        {
            <div id="ptsCell_@itemId">
                @if (item.StoryPoints > 0)
                {
                    <span class="pts-val" style="cursor:default;">@item.StoryPoints</span>
                }
                else
                {
                    <span style="color:#aaa;font-size:11px;">—</span>
                }
            </div>
        }
    </td>
    <td>
        @if (isAdminOrPM)
        {
            <div class="rel">
                <button type="button" class="ib" onclick="toggleItemCal('@itemId', event)"
                        title="@(item.DueDate.HasValue ? item.DueDate.Value.ToString("MMM d") : "Set due date")"
                        style="@(isOverdue ? "color:#E24B4A;" : "")">
                    <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="1" y="3" width="14" height="12" rx="2"/><path d="M5 1v4M11 1v4M1 7h14" stroke-linecap="round"/></svg>
                    @if (item.DueDate.HasValue)
                    {
                        <span style="font-size:11px;" id="dateLbl_@itemId">@item.DueDate.Value.ToString("MMM d")</span>
                    }
                </button>
                <div class="cal-panel" id="itemCal_@itemId" data-current-date="@(item.DueDate?.ToString("yyyy-MM-dd") ?? "")"></div>
            </div>
        }
        else
        {
            @if (item.DueDate.HasValue)
            {
                <span id="dateLbl_@itemId" style="font-size:11px;@(isOverdue ? "color:#E24B4A;" : "")">
                    <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" style="vertical-align:middle;"><rect x="1" y="3" width="14" height="12" rx="2"/><path d="M5 1v4M11 1v4M1 7h14" stroke-linecap="round"/></svg>
                    @item.DueDate.Value.ToString("MMM d")
                </span>
            }
        }
    </td>
    <td>
        @if (isAdminOrPM)
        {
            <div class="dropdown">
                <button class="ib" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-three-dots-vertical" style="font-size:13px;"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="font-size:12px;min-width:140px;">
                    <li><a class="dropdown-item" href="#"><i class="bi bi-pencil me-2"></i>Edit</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form asp-page-handler="Delete" method="post" asp-antiforgery="true"
                              style="display:inline;" onsubmit="return confirm('Delete this item?');">
                            <input type="hidden" name="itemId" value="@item.Id" />
                            <button type="submit" class="dropdown-item text-danger"
                                    style="border:none;background:none;width:100%;text-align:left;padding:6px 16px;cursor:pointer;">
                                <i class="bi bi-trash me-2"></i>Delete
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        }
    </td>
</tr>
