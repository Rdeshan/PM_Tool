@page "{projectId}"
@model PMTool.Web.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-box2"></i> Products</h1>
        @if (Model.CanCreateProduct)
        {
            <a asp-page="./Create" asp-route-projectId="@Model.ProjectId" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> New Product
            </a>
        }
       
    </div>

    @if (string.IsNullOrEmpty(Model.ErrorMessage) == false)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Tabs for filtering -->
    <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link @(Model.FilterStatus == "all" ? "active" : "")" 
                    asp-route-projectId="@Model.ProjectId" 
                    asp-route-status="all" 
                    id="all-tab" 
                    type="button" 
                    role="tab">
                All Products
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(Model.FilterStatus == "active" ? "active" : "")" 
                    asp-route-projectId="@Model.ProjectId" 
                    asp-route-status="active" 
                    id="active-tab" 
                    type="button" 
                    role="tab">
                Active
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(Model.FilterStatus == "released" ? "active" : "")" 
                    asp-route-projectId="@Model.ProjectId" 
                    asp-route-status="released" 
                    id="released-tab" 
                    type="button" 
                    role="tab">
                Released
            </button>
        </li>
    </ul>

    <!-- Products Grid -->
    <div class="row">
        @if (Model.Products.Count == 0)
        {
            <div class="col-12">
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle"></i> No products found. @(Model.CanCreateProduct ? "Create your first product to get started." : "")
                </div>
            </div>
        }
        else
        {
            @foreach (var product in Model.Products)
            {
               
                <div class="col-md-6 col-lg-4 mb-4">
                    <a asp-page="./Details" 
       asp-route-id="@product.Id"
       asp-route-projectId="@Model.ProjectId"
       class="text-decoration-none text-dark">

                    <div class="card h-100 shadow-sm product-card">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <span class="badge bg-info">v@product.VersionName</span>
                            <span class="badge @GetStatusBadgeClass(product.Status)">@GetStatusLabel(product.Status)</span>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@product.VersionName</h5>
                            <p class="card-text text-muted">@(product.Description?.Length > 100 ? product.Description.Substring(0, 100) + "..." : product.Description)</p>
                            
                            <div class="mb-3">
                                <small class="text-muted">
                                    <i class="bi bi-calendar-event"></i> 
                                    Planned: @product.PlannedReleaseDate.ToShortDateString()
                                </small>
                                @if (product.ActualReleaseDate.HasValue)
                                {
                                    <br />
                                    <small class="text-success">
                                        <i class="bi bi-check-circle"></i> 
                                        Released: @product.ActualReleaseDate.Value.ToShortDateString()
                                    </small>
                                }
                            </div>

                            <div class="row text-center mb-3">
                                <div class="col-6">
                                    <small class="text-muted">Backlog Items</small>
                                    <br />
                                    <strong>@product.BacklogItemCount</strong>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">Release Notes</small>
                                    <br />
                                    <strong>@product.ReleaseNotesCount</strong>
                                </div>
                            </div>

                            <div class="d-grid gap-2 d-sm-flex">
                                @*
                                <a asp-page="./Details" 
                                   asp-route-id="@product.Id" 
                                   asp-route-projectId="@Model.ProjectId" 
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                  *@
                                <a href="/SubProjects/@product.Id" 
                                   class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-diagram-3"></i> Sub-Projects
                                </a>
                                @if (Model.CanCreateProduct)
                                {
                                    <a asp-page="./Edit" 
                                       asp-route-id="@product.Id" 
                                       asp-route-projectId="@Model.ProjectId" 
                                       class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-warning" disabled title="Only Project Managers and Administrators can edit products">
                                        <i class="bi bi-pencil"></i> Edit
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-light">
                            <small class="text-muted">Created @product.CreatedAt.ToString("MMM dd, yyyy")</small>
                        </div>
                    </div>
                    </a>
                </div>
               
            }
        }
    </div>
</div>

@functions {
    private string GetStatusLabel(int status)
    {
        return status switch
        {
            1 => "Planned",
            2 => "In Development",
            3 => "In Testing",
            4 => "Released",
            5 => "Deprecated",
            _ => "Unknown"
        };
    }

    private string GetStatusBadgeClass(int status)
    {
        return status switch
        {
            1 => "bg-secondary",
            2 => "bg-info",
            3 => "bg-warning",
            4 => "bg-success",
            5 => "bg-danger",
            _ => "bg-secondary"
        };
    }
}

<style>
    .product-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1) !important;
    }
</style>
