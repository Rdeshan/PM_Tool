@page "{projectId}"
@model PMTool.Web.Pages.Products.IndexModel
@{
    Layout = "_EmbeddedLayout";

    ViewData["Title"] = "Products";
}

<div class="container-fluid mt-1">
    <div class="d-flex justify-content-end align-items-center mb-1">
       
        @if (Model.CanCreateProduct)
        {
            <button type="button"
                    class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#createProductModal"
                    data-projectid="@Model.ProjectId">
                <i class="bi bi-plus-circle"></i> New Product
            </button>
        }
    </div>

    <div class="modal fade" id="createProductModal" tabindex="-1" aria-labelledby="createProductModalLabel" aria-hidden="true">
        <div class="modal-dialog" style="max-width:600px; margin-top:1rem;">
            <div class="modal-content">
                <div class="modal-header py-2" style="background: linear-gradient(90deg, #03045e 0%, #0077b6 100%); color: #fff;">
                    <h6 class="modal-title" id="createProductModalLabel" style="color:#fff;">Add New Product</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0">
                    <iframe src="@Url.Page("./Create", new { projectId = Model.ProjectId, embedded = true })"
                            title="Create Product"
                            style="width:100%; height:500px; border:0;"></iframe>
                </div>
            </div>
        </div>
    </div>

    @if (string.IsNullOrEmpty(Model.ErrorMessage) == false)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (string.IsNullOrEmpty(Model.SuccessMessage) == false)
    {
        <div id="successMessageAlert" class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Tabs for filtering -->
    <div class="opms-tabs mb-3">
        <a class="opms-tab @(Model.FilterStatus == "all" ? "active" : "")"
           asp-route-projectId="@Model.ProjectId"
           asp-route-status="all">All Products</a>
        <a class="opms-tab @(Model.FilterStatus == "active" ? "active" : "")"
           asp-route-projectId="@Model.ProjectId"
           asp-route-status="active">Active</a>
        <a class="opms-tab @(Model.FilterStatus == "released" ? "active" : "")"
           asp-route-projectId="@Model.ProjectId"
           asp-route-status="released">Released</a>
    </div>

    <!-- Products Grid -->
    <div class="row">
        @if (Model.Products.Count == 0)
        {
            <div class="col-12">
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle"></i> No products found. @(Model.CanCreateProduct ? "Create your first product to get started." : "")
                </div>
            </div>
        }
        else
        {
            @foreach (var product in Model.Products)
            {
               
                <div class="col-md-6 col-lg-4 mb-4">
                    <a asp-page="./Details"
                       asp-route-id="@product.Id"
                       asp-route-projectId="@Model.ProjectId"
                       class="text-decoration-none text-dark"
                       target="_top">

                        <div class="opms-card h-100 product-card" style="cursor:pointer;">
                            <div class="opms-card__header">
                                <div class="opms-card__title">@product.VersionName</div>
                                <span class="badge-opms badge-opms--@(product.Status == 4 ? "success" : product.Status == 3 ? "warning" : product.Status == 5 ? "danger" : "info")">
                                    <span class="dot"></span>@GetStatusLabel(product.Status)
                                </span>
                            </div>
                            <div class="opms-card--pad">
                                <p style="font-size: var(--fs-sm); color: var(--text-muted); margin-bottom: var(--space-3); min-height: 2.5em;">
                                    @(product.Description?.Length > 100 ? product.Description.Substring(0, 100) + "…" : product.Description)
                                </p>
                                <div style="font-size: var(--fs-xs); color: var(--text-muted); margin-bottom: var(--space-2);">
                                    <i class="bi bi-calendar-event me-1"></i>Planned: @product.PlannedReleaseDate.ToShortDateString()
                                </div>
                                @if (product.ActualReleaseDate.HasValue)
                                {
                                    <div style="font-size: var(--fs-xs); color: var(--success-text); margin-bottom: var(--space-3);">
                                        <i class="bi bi-check-circle me-1"></i>Released: @product.ActualReleaseDate.Value.ToShortDateString()
                                    </div>
                                }
                                <div class="d-flex gap-3 mb-3" style="font-size: var(--fs-xs); text-align:center;">
                                    <div style="flex:1; background: var(--slate-50); border-radius: var(--radius-sm); padding: var(--space-2);">
                                        <div style="color: var(--text-muted);">Backlog</div>
                                        <strong style="color: var(--text-heading);">@product.BacklogItemCount</strong>
                                    </div>
                                    <div style="flex:1; background: var(--slate-50); border-radius: var(--radius-sm); padding: var(--space-2);">
                                        <div style="color: var(--text-muted);">Rel. Notes</div>
                                        <strong style="color: var(--text-heading);">@product.ReleaseNotesCount</strong>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center justify-content-between">
                                    <span style="font-size: var(--fs-xs); color: var(--text-faint);">@product.CreatedAt.ToString("MMM dd, yyyy")</span>
                                    <a href="/SubProjects/@product.Id" class="btn-opms btn-opms--ghost btn-opms--sm" target="_top" onclick="event.stopPropagation()">
                                        <i class="bi bi-diagram-3"></i> Sub-Projects
                                    </a>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
               
            }
        }
    </div>
</div>

@functions {
    private string GetStatusLabel(int status)
    {
        return status switch
        {
            1 => "Planned",
            2 => "In Development",
            3 => "In Testing",
            4 => "Released",
            5 => "Deprecated",
            _ => "Unknown"
        };
    }

    private string GetStatusBadgeClass(int status)
    {
        return status switch
        {
            1 => "bg-secondary",
            2 => "bg-info",
            3 => "bg-warning",
            4 => "bg-success",
            5 => "bg-danger",
            _ => "bg-secondary"
        };
    }
}

<style>
    .product-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 32px rgba(0, 119, 182, 0.16), 0 3px 10px rgba(0, 150, 199, 0.08) !important;
    }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const successAlert = document.getElementById('successMessageAlert');
            if (successAlert) {
                setTimeout(() => {
                    const alert = bootstrap.Alert.getOrCreateInstance(successAlert);
                    alert.close();
                }, 3000);
            }
        });
    </script>
}
