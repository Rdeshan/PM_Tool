@page "{projectId}/{id}"
@model PMTool.Web.Pages.Products.EditModel
@{
    ViewData["Title"] = "Edit Product";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0"><i class="bi bi-pencil"></i> Edit Product</h4>
        </div>
        <div class="card-body">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    <strong>Please fix the following errors:</strong>
                    <ul class="mb-0">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }

            @if (Model.Product != null)
            {
                <form method="post">
                    <div class="mb-3">
                        <label asp-for="Input.VersionName" class="form-label">Version Name <span class="text-danger">*</span></label>
                        <input asp-for="Input.VersionName" type="text" class="form-control" />
                        <small class="form-text text-muted">Use semantic versioning format</small>
                        <span asp-validation-for="Input.VersionName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label">Description</label>
                        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Input.PlannedReleaseDate" class="form-label">Planned Release Date <span class="text-danger">*</span></label>
                            <input asp-for="Input.PlannedReleaseDate" type="date" class="form-control" />
                            <span asp-validation-for="Input.PlannedReleaseDate" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Input.ActualReleaseDate" class="form-label">Actual Release Date</label>
                            <input asp-for="Input.ActualReleaseDate" type="date" class="form-control" />
                            <span asp-validation-for="Input.ActualReleaseDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Input.Status" class="form-label">Status <span class="text-danger">*</span></label>
                            <select asp-for="Input.Status" class="form-select">
                                <option value="1">Planned</option>
                                <option value="2">In Development</option>
                                <option value="3">In Testing</option>
                                <option value="4">Released</option>
                                <option value="5">Deprecated</option>
                            </select>
                            <span asp-validation-for="Input.Status" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Input.ReleaseType" class="form-label">Release Type <span class="text-danger">*</span></label>
                            <select asp-for="Input.ReleaseType" class="form-select">
                                <option value="1">Major</option>
                                <option value="2">Minor</option>
                                <option value="3">Patch</option>
                                <option value="4">Hotfix</option>
                            </select>
                            <span asp-validation-for="Input.ReleaseType" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-between">
                        <a asp-page="./Details" asp-route-projectId="@Model.ProjectId" asp-route-id="@Model.Product.Id" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-check-circle"></i> Update Product
                        </button>
                    </div>
                </form>
            }
            else
            {
                <div class="alert alert-warning">Product not found.</div>
                <a asp-page="/Projects/Details" asp-route-id="@Model.ProjectId" asp-route-tab="products" class="btn btn-secondary">
                    Back to @(string.IsNullOrEmpty(Model.ProjectName) ? "Project" : Model.ProjectName)
                </a>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
