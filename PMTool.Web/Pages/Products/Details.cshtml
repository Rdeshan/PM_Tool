@page "{projectId}/{id}"
@model PMTool.Web.Pages.Products.DetailsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.Product?.VersionName ?? "Product Details";
}

<div class="container-fluid mt-4">
    @* Breadcrumb *@
    <nav aria-label="breadcrumb" class="mb-2 d-flex justify-content-between align-items-center">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-page="/Projects/Details" asp-route-id="@Model.ProjectId">@Model.ProjectName</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-page="/Projects/Details" asp-route-id="@Model.ProjectId" asp-route-tab="products">Products</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@(Model.Product?.VersionName ?? "Product")</li>
        </ol>
         <a asp-page="/Projects/Details" 
            asp-route-id="@Model.ProjectId" 
            asp-route-tab="products"
            class="btn btn-sm btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to @Model.ProjectName
        </a>
    </nav>

    @if (Model.Product != null)
    {

        <div class="row">
            <div class="col-md-8">
                <div class="card mb-4">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><strong>@Model.ProjectName</strong> <span class="mx-2 fs-2">&rsaquo;</span> @Model.Product.VersionName &mdash; Product Information</h5>
                       
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label text-muted">Version</label>
                                <p class="h6">@Model.Product.VersionName</p>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted">Status</label>
                                <p>
                                    <span class="badge @Model.GetStatusBadgeClass(Model.Product.Status)">
                                        @Model.GetStatusLabel(Model.Product.Status)
                                    </span>
                                </p>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted">Release Type</label>
                                <p>
                                    <span class="badge bg-secondary">
                                        @Model.GetReleaseTypeLabel(Model.Product.ReleaseType)
                                    </span>
                                </p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label text-muted">Planned Release Date</label>
                                <p>@Model.Product.PlannedReleaseDate.ToShortDateString()</p>
                            </div>
                            <div class="col-md-8">
                                <label class="form-label text-muted">Description</label>
                                <p>@Model.Product.Description</p>
                            </div>
                        </div>

                        @if (Model.Product.ActualReleaseDate.HasValue)
                        {
                            <div class="row mb-3">
                                <div class="col-md-4">
                                    <label class="form-label text-muted">Actual Release Date</label>
                                    <p class="text-success">
                                        <i class="bi bi-check-circle"></i>
                                        @Model.Product.ActualReleaseDate.Value.ToShortDateString()
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-white d-flex justify-content-end">
                        @if (Model.CanEditProduct)
                        {
                            <a asp-page="./Edit" asp-route-projectId="@Model.ProjectId" asp-route-id="@Model.Product.Id" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                        }
                    </div>
                </div>

                <!-- Release Notes Section -->
                <div class="card">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Release Notes (@Model.ReleaseNotes.Count)</h5>
                        @if (Model.CanEditProduct)
                        {
                            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addReleaseNotesModal">
                                <i class="bi bi-plus"></i> Add Notes
                            </button>
                        }
                    </div>
                    <div class="card-body">
                        @if (Model.ReleaseNotes.Count == 0)
                        {
                            <p class="text-muted">No release notes yet.</p>
                        }
                        else
                        {
                            @foreach (var notes in Model.ReleaseNotes)
                            {
                                <div class="mb-3 pb-3 border-bottom">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="mb-1">@notes.Title</h6>
                                            @if (notes.IsPublished)
                                            {
                                                <span class="badge bg-success me-2">Published</span>
                                                <small class="text-muted">on @notes.PublishedDate?.ToShortDateString()</small>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning me-2">Draft</span>
                                            }
                                        </div>
                                        @if (Model.CanEditProduct)
                                        {
                                            <div>
                                                @if (!notes.IsPublished)
                                                {
                                                    <button type="button" class="btn btn-sm btn-success" 
                                                            onclick="publishReleaseNotes(@notes.Id)">
                                                        <i class="bi bi-check"></i> Publish
                                                    </button>
                                                }
                                                <button type="button" class="btn btn-sm btn-danger" 
                                                        onclick="deleteReleaseNotes(@notes.Id)">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </div>
                                        }
                                    </div>
                                    <p class="mt-2 mb-0 text-wrap">@Html.Raw(System.Net.WebUtility.HtmlEncode(notes.Content).Replace("\n", "<br>"))</p>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <!-- Summary Card -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label text-muted">Backlog Items</label>
                            <p class="h5">@Model.Product.BacklogItemCount</p>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted">Release Notes</label>
                            <p class="h5">@Model.ReleaseNotes.Count</p>
                        </div>
                        <div>
                            <label class="form-label text-muted">Created</label>
                            <p>@Model.Product.CreatedAt.ToString("MMM dd, yyyy HH:mm")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">Product not found.</div>
        <a asp-page="/Projects/Details" asp-route-id="@Model.ProjectId" asp-route-tab="products" class="btn btn-secondary">
            Back to @(string.IsNullOrEmpty(Model.ProjectName) ? "Project" : Model.ProjectName)
        </a>
    }

    <!-- Delete Modal -->
    @if (Model.Product != null)
    {
        <div class="modal fade" id="deleteModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">Delete Product</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to delete this product? This action cannot be undone.</p>
                        <p class="text-muted"><strong>Product:</strong> @Model.Product.VersionName</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <form method="post" asp-page-handler="Delete" style="display: inline;">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Add Release Notes Modal -->
        <div class="modal fade" id="addReleaseNotesModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title">Add Release Notes</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form method="post" asp-page-handler="AddReleaseNotes">
                        <div class="modal-body">
                            <div class="mb-3">
                                <label for="releaseNotesTitle" class="form-label">Title <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="releaseNotesTitle" name="title" required />
                            </div>
                            <div class="mb-3">
                                <label for="releaseNotesContent" class="form-label">Content <span class="text-danger">*</span></label>
                                <textarea class="form-control" id="releaseNotesContent" name="content" rows="5" required></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Add Release Notes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        
        @if (Model.CanEditProduct)
        {
            <div class="d-flex justify-content-end mt-4 mb-4">
                <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                    <i class="bi bi-trash"></i> Delete Product
                </button>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        function publishReleaseNotes(releaseNotesId) {
            if (confirm('Publish these release notes?')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Html.Raw(Url.Page("./Details", new { handler = "PublishReleaseNotes" }))';
                
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'releaseNotesId';
                input.value = releaseNotesId;
                
                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            }
        }

        function deleteReleaseNotes(releaseNotesId) {
            if (confirm('Delete these release notes?')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Html.Raw(Url.Page("./Details", new { handler = "DeleteReleaseNotes" }))';
                
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'releaseNotesId';
                input.value = releaseNotesId;
                
                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}
